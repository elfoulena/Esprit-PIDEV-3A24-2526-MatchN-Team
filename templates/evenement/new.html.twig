{% extends 'back/base_employee.html.twig' %}

{% block title %}New Evenement{% endblock %}

{% block employee_content %}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div class="section-header" style="display: flex; align-items: center; gap: 8px; color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            <h3 style="font-size: 13px; font-weight: 700; margin: 0; text-transform: uppercase;">Nouvel Événement</h3>
        </div>
        <a href="{{ path('app_evenement_index') }}" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: #f1f5f9; color: #334155; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Retour à la liste
        </a>
    </div>

    {{ include('evenement/_form.html.twig') }}
{% endblock %}
