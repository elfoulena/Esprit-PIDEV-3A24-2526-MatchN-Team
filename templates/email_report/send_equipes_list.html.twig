{% extends 'back/base_admin.html.twig' %}

{% block title %}Envoyer la liste des équipes{% endblock %}
{% block page_title %}Envoyer la liste par email{% endblock %}

{% block content %}
<div style="max-width: 600px; margin: 0 auto;">
    <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden;">
        <div style="padding: 24px; border-bottom: 1px solid var(--border-color); background: #f8fafc;">
            <h3 style="margin: 0; font-size: 18px;">📋 Envoyer la liste des équipes</h3>
            <p style="margin: 5px 0 0; font-size: 13px; color: var(--text-secondary);">Toutes les équipes seront incluses dans le PDF</p>
        </div>
        
        <form method="post" style="padding: 24px;">
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px; font-size: 13px;">Adresse email du destinataire</label>
                <input type="email" name="email" required 
                       value="{{ admin_email }}"
                       style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px; font-size: 14px;">
            </div>
            
            {% if current_filters|filter((v, k) => v != '' and k not in ['sortBy', 'sortDir']) %}
            <div style="background: #fef3c7; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                <p style="margin: 0 0 5px; font-size: 12px; font-weight: 600;">⚠️ Filtres actifs :</p>
                <ul style="margin: 0; padding-left: 20px; font-size: 12px;">
                    {% if current_filters.search %}
                        <li>Recherche : {{ current_filters.search }}</li>
                    {% endif %}
                    {% if current_filters.statut %}
                        <li>Statut : {{ current_filters.statut }}</li>
                    {% endif %}
                    {% if current_filters.departement %}
                        <li>Département : {{ current_filters.departement }}</li>
                    {% endif %}
                </ul>
                <p style="margin: 8px 0 0; font-size: 11px;">La liste sera générée avec ces filtres appliqués.</p>
            </div>
            {% endif %}
            
            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <a href="{{ path('app_equipe_index') }}" 
                   style="padding: 10px 20px; background: #e2e8f0; color: #475569; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: 600;">Annuler</a>
                <button type="submit" 
                        style="padding: 10px 24px; background: #10b981; color: white; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;">
                    📧 Envoyer la liste
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}