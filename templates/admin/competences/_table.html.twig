{# templates/admin/competences/_table.html.twig — partial for AJAX reload #}
<table class="data-table">
    <thead>
        <tr>
            <th>#</th>
            <th>Nom de la compétence</th>
            <th>Type</th>
            <th>Description</th>
            <th>Projets</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
    {% for c in competences %}
        <tr>
            <td style="color:var(--text-secondary); font-size:12px;">#{{ c.idCompetence }}</td>
            <td style="font-weight:700;">
                <span style="display:inline-block; background:rgba(139,92,246,0.08); color:#7c3aed; padding:4px 12px; border-radius:20px; font-size:13px; font-weight:700;">{{ c.nomCompetence }}</span>
            </td>
            <td>
                {% if c.type == 'Hard skill' %}
                    <span style="display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(59,130,246,0.1); color:#1d4ed8;">⚙ Hard skill</span>
                {% elseif c.type == 'Soft skill' %}
                    <span style="display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(16,185,129,0.1); color:#059669;">✦ Soft skill</span>
                {% elseif c.type == 'Langue' %}
                    <span style="display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(245,158,11,0.1); color:#d97706;">🌐 Langue</span>
                {% elseif c.type == 'Outil' %}
                    <span style="display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; background:rgba(139,92,246,0.1); color:#7c3aed;">🛠 Outil</span>
                {% else %}
                    <span style="font-size:12px; color:var(--text-secondary);">{{ c.type }}</span>
                {% endif %}
            </td>
            <td style="font-size:12px; color:var(--text-secondary); max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">
                {{ c.descriptionCompetence ?: '—' }}
            </td>
            <td style="font-size:12px; color:var(--text-secondary);">
                {% if c.projets|length > 0 %}
                    <span style="font-weight:600;">{{ c.projets|length }}</span> projet{{ c.projets|length > 1 ? 's' : '' }}
                {% else %}
                    <span style="font-style:italic;">Aucun</span>
                {% endif %}
            </td>
            <td>
                <div class="actions">
                    <a href="{{ path('admin_competences_edit', {'id': c.idCompetence}) }}" class="action-btn edit" title="Modifier">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                    <form method="post" action="{{ path('admin_competences_delete', {'id': c.idCompetence}) }}" style="margin:0;" onsubmit="return confirm('Supprimer cette compétence ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_competence_'~c.idCompetence) }}">
                        <button type="submit" class="action-btn delete" title="Supprimer">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                        </button>
                    </form>
                </div>
            </td>
        </tr>
    {% else %}
        <tr><td colspan="6" class="empty-state">Aucune compétence trouvée.</td></tr>
    {% endfor %}
    </tbody>
</table>
