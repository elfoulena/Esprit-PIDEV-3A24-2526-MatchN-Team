{# templates/admin/users/create_employe.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Créer un employé — MatchNTeam{% endblock %}
{% block page_title %}Créer un compte employé{% endblock %}

{% block extra_styles %}
.page-banner {
    background: linear-gradient(135deg, #064e3b 0%, #059669 60%, #2563eb 100%);
    border-radius: var(--radius-lg); padding: 28px 32px; color: #fff;
    position: relative; overflow: hidden; margin-bottom: 28px;
    display: flex; align-items: center; justify-content: space-between; gap: 16px;
}
.page-banner::before {
    content: ''; position: absolute; top: -50px; right: -50px;
    width: 200px; height: 200px; border-radius: 50%;
    background: rgba(255,255,255,0.06); pointer-events: none;
}
.banner-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
.banner-sub   { font-size: 13px; opacity: 0.72; }
.btn-back {
    display: inline-flex; align-items: center; gap: 7px; padding: 9px 18px;
    background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.28);
    border-radius: var(--radius-md); color: #fff; font-size: 13px; font-weight: 700;
    text-decoration: none; backdrop-filter: blur(4px); transition: background 0.18s;
    position: relative; z-index: 1;
}
.btn-back:hover { background: rgba(255,255,255,0.25); }

.form-layout { display: grid; grid-template-columns: 1fr 320px; gap: 24px; align-items: start; }
@media (max-width: 960px) { .form-layout { grid-template-columns: 1fr; } }

.data-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
    margin-bottom: 20px;
}
.card-header {
    padding: 16px 22px; border-bottom: 1px solid var(--border-color);
    font-size: 13px; font-weight: 800; color: var(--text-primary);
    display: flex; align-items: center; gap: 8px;
}
.card-header .dot { width: 8px; height: 8px; border-radius: 50%; }
.card-body { padding: 22px; }

.form-row   { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
@media (max-width: 600px) { .form-row { grid-template-columns: 1fr; } }

.form-group { margin-bottom: 16px; }
.form-group:last-child { margin-bottom: 0; }

.form-label {
    display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 6px;
}
.form-label .required { color: #dc2626; margin-left: 2px; }
.form-label .optional { font-size: 10px; font-weight: 500; opacity: 0.55; margin-left: 4px; text-transform: none; letter-spacing: 0; }

.form-control {
    width: 100%; padding: 9px 12px;
    border: 1px solid var(--border-color); border-radius: var(--radius-sm);
    background: var(--bg-surface); color: var(--text-primary); font-size: 13.5px;
    outline: none; transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box; font-family: inherit;
}
.form-control:focus { border-color: var(--accent-green); box-shadow: 0 0 0 3px rgba(5,150,105,0.10); }
select.form-control { cursor: pointer; }
.form-hint { font-size: 11px; color: var(--text-secondary); margin-top: 4px; }

.form-actions {
    display: flex; gap: 10px; margin-top: 4px;
}
.btn-create {
    flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 7px;
    padding: 11px 16px; background: var(--accent-green); color: #fff;
    border: none; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 700; cursor: pointer; transition: opacity 0.15s;
}
.btn-create:hover { opacity: 0.88; }
.btn-cancel {
    display: inline-flex; align-items: center; gap: 6px; padding: 11px 16px;
    background: var(--bg-surface); color: var(--text-secondary);
    border: 1px solid var(--border-color); border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 600; text-decoration: none; transition: all 0.15s;
}
.btn-cancel:hover { border-color: var(--accent-green); color: var(--accent-green); }

/* Info panel */
.info-panel { position: sticky; top: 24px; }
.info-item { display: flex; gap: 12px; padding: 13px 0; border-bottom: 1px solid var(--border-color); }
.info-item:last-child { border-bottom: none; }
.info-icon {
    width: 32px; height: 32px; border-radius: var(--radius-sm); flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
}
.info-icon.green  { background: rgba(16,185,129,0.12); color: #059669; }
.info-icon.blue   { background: rgba(59,130,246,0.12);  color: var(--accent-blue); }
.info-icon.orange { background: rgba(245,158,11,0.12);  color: var(--accent-orange); }
.info-title { font-size: 12px; font-weight: 700; color: var(--text-primary); margin-bottom: 2px; }
.info-desc  { font-size: 11.5px; color: var(--text-secondary); line-height: 1.5; }

.badge-preview { display: flex; flex-wrap: wrap; gap: 6px; padding: 14px 22px; border-top: 1px solid var(--border-color); }
.badge { padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; }
.badge.active   { background: rgba(16,185,129,0.12); color: #059669; }
.badge.verified { background: rgba(59,130,246,0.12);  color: var(--accent-blue); }
.badge.employe  { background: rgba(16,185,129,0.12);  color: #059669; }

.flash-error {
    display: flex; align-items: center; gap: 10px; padding: 12px 18px; margin-bottom: 20px;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.24);
    border-radius: var(--radius-md); font-size: 13px; font-weight: 600; color: #dc2626;
}
{% endblock %}

{% block content %}

{% for msg in app.flashes('error') %}
    <div class="flash-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        {{ msg }}
    </div>
{% endfor %}

<div class="page-banner">
    <div>
        <div class="banner-title">Créer un compte Employé</div>
        <div class="banner-sub">Le mot de passe sera généré automatiquement et envoyé par email</div>
    </div>
    <a href="{{ path('admin_user_index') }}" class="btn-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Retour
    </a>
</div>

<form method="post" action="{{ path('admin_user_create_employe') }}" id="employe-form">
<div class="form-layout">

    {# ── Formulaire ── #}
    <div>

        {# Identité #}
        <div class="data-card">
            <div class="card-header">
                <span class="dot" style="background: var(--accent-blue);"></span>
                Identité
            </div>
            <div class="card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Nom <span class="required">*</span></label>
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Dupont'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Prénom <span class="required">*</span></label>
                        {{ form_widget(form.prenom, {'attr': {'class': 'form-control', 'placeholder': 'Jean'}}) }}
                        {{ form_errors(form.prenom) }}
                    </div>
                </div>
                <div class="form-group">
                    <label class="form-label">Email professionnel <span class="required">*</span></label>
                    {{ form_widget(form.email, {'attr': {'class': 'form-control', 'placeholder': 'jean.dupont@matchnteam.com'}}) }}
                    {{ form_errors(form.email) }}
                    <div class="form-hint">Les identifiants de connexion seront envoyés à cette adresse.</div>
                </div>
            </div>
        </div>

        {# Infos professionnelles #}
        <div class="data-card">
            <div class="card-header">
                <span class="dot" style="background: var(--accent-green);"></span>
                Informations professionnelles
            </div>
            <div class="card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Poste</label>
                        {{ form_widget(form.poste, {'attr': {'class': 'form-control', 'placeholder': 'Développeur Backend'}}) }}
                        {{ form_errors(form.poste) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Département</label>
                        {{ form_widget(form.departement, {'attr': {'class': 'form-control', 'placeholder': 'Informatique'}}) }}
                        {{ form_errors(form.departement) }}
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Type de contrat</label>
                        {{ form_widget(form.typeContrat, {'attr': {'class': 'form-control'}}) }}
                        {{ form_errors(form.typeContrat) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Salaire <span class="optional">(optionnel, en TND)</span></label>
                        {{ form_widget(form.salaire, {'attr': {'class': 'form-control', 'placeholder': '2500.00'}}) }}
                        {{ form_errors(form.salaire) }}
                    </div>
                </div>
            </div>
        </div>

        {# Contact #}
        <div class="data-card">
            <div class="card-header">
                <span class="dot" style="background: var(--accent-purple);"></span>
                Contact
                <span style="font-size:11px; font-weight:500; opacity:0.5; margin-left:4px;">optionnel</span>
            </div>
            <div class="card-body">
                <div class="form-row">
                    <div class="form-group">
                        <label class="form-label">Téléphone</label>
                        {{ form_widget(form.telephone, {'attr': {'class': 'form-control', 'placeholder': '+216 XX XXX XXX'}}) }}
                        {{ form_errors(form.telephone) }}
                    </div>
                    <div class="form-group">
                        <label class="form-label">Adresse</label>
                        {{ form_widget(form.adresse, {'attr': {'class': 'form-control', 'placeholder': 'Tunis, Tunisie'}}) }}
                        {{ form_errors(form.adresse) }}
                    </div>
                </div>
            </div>
        </div>

        {{ form_rest(form) }}

        <div class="form-actions">
            <button type="submit" class="btn-create">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.6 3.18h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L7.91 10.91a16 16 0 0 0 5.55 5.55l.94-.94a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 21 18z"/></svg>
                Créer le compte et envoyer par email
            </button>
            <a href="{{ path('admin_user_index') }}" class="btn-cancel">Annuler</a>
        </div>

    </div>

    {# ── Panneau info ── #}
    <div class="info-panel">
        <div class="data-card">
            <div class="card-header">
                <span class="dot" style="background: var(--accent-blue);"></span>
                Ce qui va se passer
            </div>
            <div class="card-body" style="padding: 4px 22px;">
                <div class="info-item">
                    <div class="info-icon green">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                    </div>
                    <div>
                        <div class="info-title">Compte créé immédiatement</div>
                        <div class="info-desc">Rôle Employé, actif et vérifié dès la création.</div>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon orange">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                    </div>
                    <div>
                        <div class="info-title">Mot de passe généré</div>
                        <div class="info-desc">Mot de passe sécurisé aléatoire de 10 caractères.</div>
                    </div>
                </div>
                <div class="info-item">
                    <div class="info-icon blue">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    </div>
                    <div>
                        <div class="info-title">Email envoyé</div>
                        <div class="info-desc">L'employé reçoit son email et son mot de passe temporaire.</div>
                    </div>
                </div>
            </div>
            <div class="badge-preview">
                <span class="badge active">● Actif</span>
                <span class="badge verified">✓ Vérifié</span>
                <span class="badge employe">Employé</span>
            </div>
        </div>
    </div>

</div>
</form>

{% endblock %}
