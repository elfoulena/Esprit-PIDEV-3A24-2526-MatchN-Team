{# templates/affectation/_form.html.twig #}
<style>
.form-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    max-width: 700px;
}
.form-card-header {
    padding: 20px 28px;
    border-bottom: 1px solid var(--border-color);
    background: #f8fafc;
    display: flex; align-items: center; gap: 10px;
}
.form-card-header h3 {
    font-size: 12px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 1px; margin: 0;
}
.form-card-body { padding: 28px; }
.form-group { margin-bottom: 20px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.form-label {
    display: block; font-size: 12px; font-weight: 700;
    color: var(--text-primary); margin-bottom: 7px; letter-spacing: 0.3px;
}
.form-control {
    width: 100%; padding: 10px 14px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm); font-size: 13.5px;
    color: var(--text-primary); background: #fff;
    font-family: inherit; transition: all var(--transition);
    box-sizing: border-box;
}
.form-control:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(59,130,246,0.10); }
textarea.form-control { min-height: 96px; resize: vertical; }
.form-control.is-invalid { border-color: var(--accent-red); box-shadow: 0 0 0 3px rgba(239,68,68,0.10); }
.form-control.is-valid   { border-color: var(--accent-green); }
.field-error { color: var(--accent-red); font-size: 11.5px; font-weight: 600; margin-top: 4px; display: block; }
.form-actions {
    display: flex; justify-content: flex-end; gap: 10px;
    margin-top: 28px; padding-top: 20px;
    border-top: 1px solid var(--border-color);
}
.btn-cancel {
    padding: 10px 22px; background: var(--bg-surface); color: var(--text-primary);
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: none;
    display: inline-flex; align-items: center;
}
.btn-save {
    padding: 10px 24px; background: var(--accent-blue); color: #fff;
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    font-weight: 700; cursor: pointer; font-family: inherit;
    transition: background var(--transition);
}
.btn-save:hover { background: #2563eb; }
</style>

<div class="form-card">
    <div class="form-card-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
        <h3>Informations de l'affectation</h3>
    </div>
    <div class="form-card-body">

        {{ form_start(form, {'attr': {'id': 'affectation_form', 'novalidate': 'novalidate'}}) }}

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.User, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.User, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.User) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.projet, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.projet, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.projet) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.dateDebut, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateDebut, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateDebut) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dateFin, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateFin) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.statut, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.statut, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.statut) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.tauxHoraire, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.tauxHoraire, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 25.00'}}) }}
                    {{ form_errors(form.tauxHoraire) }}
                </div>
            </div>

            <div class="form-actions">
                <a href="{{ path('app_affectation_index') }}" class="btn-cancel">Annuler</a>
                <button type="submit" class="btn-save">{{ button_label|default('Enregistrer') }}</button>
            </div>

        {{ form_end(form) }}

    </div>
</div>

{# ── AI Matching Recommendation Panel ── #}
<div id="matching-panel" style="display:none; margin-top: 20px; max-width: 700px;">
    <style>
    .matching-card-header {
        padding: 16px 24px;
        border-bottom: 1px solid var(--border-color);
        background: linear-gradient(135deg, rgba(139,92,246,0.06), rgba(59,130,246,0.04));
        display: flex; align-items: center; gap: 10px;
    }
    .matching-card-header h3 {
        font-size: 12px; font-weight: 700;
        color: var(--accent-purple);
        text-transform: uppercase; letter-spacing: 1px; margin: 0;
    }
    .matching-card-body { padding: 20px 24px; }
    .rec-card {
        padding: 14px 18px; margin-bottom: 10px;
        border: 1px solid var(--border-color); border-radius: var(--radius-md);
        cursor: pointer; transition: all 0.15s ease;
        background: #fff;
    }
    .rec-card:hover { border-color: var(--accent-blue); box-shadow: 0 2px 8px rgba(59,130,246,0.1); transform: translateY(-1px); }
    .rec-card.selected { border-color: var(--accent-green); background: rgba(16,185,129,0.04); }
    .rec-score-bar {
        height: 4px; border-radius: 2px; background: #e2e8f0;
        width: 100%; margin-top: 8px; overflow: hidden;
    }
    .rec-score-fill { height: 4px; border-radius: 2px; transition: width 0.3s ease; }
    .rec-badge {
        display: inline-flex; align-items: center; gap: 3px;
        padding: 2px 8px; border-radius: 12px; font-size: 10px; font-weight: 700;
    }
    .rec-badge.green { background: rgba(16,185,129,0.12); color: #059669; }
    .rec-badge.red { background: rgba(239,68,68,0.10); color: #dc2626; }
    .rec-badge.blue { background: rgba(59,130,246,0.10); color: #3b82f6; }
    .rec-badge.purple { background: rgba(139,92,246,0.10); color: #7c3aed; }
    </style>

    <div class="form-card">
        <div class="matching-card-header">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <h3>Recommandations IA</h3>
            <span id="matching-loading" style="display:none; margin-left:auto; font-size: 11px; color: var(--text-secondary);">
                Analyse en cours...
            </span>
        </div>
        <div class="matching-card-body" id="matching-results"></div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('affectation_form');
    if (!form) return;
    function showError(field, msg) {
        field.classList.add('is-invalid'); field.classList.remove('is-valid');
        let err = field.parentNode.querySelector('.field-error');
        if (!err) { err = document.createElement('span'); err.className = 'field-error'; field.parentNode.appendChild(err); }
        err.textContent = msg;
    }
    function clearError(field) {
        field.classList.remove('is-invalid'); field.classList.add('is-valid');
        const err = field.parentNode.querySelector('.field-error');
        if (err) err.remove();
    }
    function validateField(field) {
        if (!field) return true;
        const val = field.value.trim(), id = field.id || '';
        if (id.includes('tauxHoraire') || id.includes('taux_horaire')) {
            const num = parseFloat(val);
            if (val && num > 0 && num < 5) { showError(field, 'Minimum 5 DT/h.'); return false; }
            if (val && num > 1000) { showError(field, 'Maximum 1000 DT/h.'); return false; }
        }
        clearError(field); return true;
    }
    form.querySelectorAll('.form-control').forEach(f => {
        f.addEventListener('blur', () => validateField(f));
        f.addEventListener('input', () => { if (f.classList.contains('is-invalid')) validateField(f); });
    });
    form.addEventListener('submit', function(e) {
        let valid = true;
        form.querySelectorAll('.form-control').forEach(f => { if (!validateField(f)) valid = false; });
        if (!valid) e.preventDefault();
    });

    // ── AI Matching Logic ──
    const projetSelect = document.getElementById('affectation_projet_projet');
    const userSelect = document.getElementById('affectation_projet_User');
    const matchingPanel = document.getElementById('matching-panel');
    const matchingResults = document.getElementById('matching-results');
    const matchingLoading = document.getElementById('matching-loading');

    if (projetSelect && matchingPanel) {
        projetSelect.addEventListener('change', function() {
            const projetId = this.value;
            if (!projetId) {
                matchingPanel.style.display = 'none';
                return;
            }

            matchingPanel.style.display = 'block';
            matchingLoading.style.display = 'inline';
            matchingResults.innerHTML = '';

            fetch('/admin/affectation/api/matching/' + projetId)
                .then(function(r) { return r.json(); })
                .then(function(data) {
                    matchingLoading.style.display = 'none';

                    if (!data.recommendations || data.recommendations.length === 0) {
                        matchingResults.innerHTML = '<p style="color:var(--text-secondary);font-size:13px;text-align:center;padding:20px;">Aucun freelancer disponible pour ce projet.</p>';
                        return;
                    }

                    var html = '';
                    data.recommendations.forEach(function(r, idx) {
                        var scoreColor = r.totalScore >= 60 ? '#059669' : (r.totalScore >= 30 ? '#b45309' : '#dc2626');
                        var scoreBarColor = r.totalScore >= 60 ? '#10b981' : (r.totalScore >= 30 ? '#f59e0b' : '#ef4444');

                        html += '<div class="rec-card" data-user-id="' + r.userId + '">'
                            + '<div style="display:flex;justify-content:space-between;align-items:center;">'
                            + '  <div>'
                            + '    <strong style="font-size:14px;color:var(--text-primary);">' + r.prenom + ' ' + r.nom + '</strong>'
                            + (idx < 3 ? ' <span class="rec-badge purple">#' + (idx + 1) + '</span>' : '')
                            + '    <div style="font-size:11px;color:var(--text-secondary);margin-top:2px;">' + r.email + '</div>'
                            + '  </div>'
                            + '  <div style="text-align:right;">'
                            + '    <div style="font-size:20px;font-weight:800;color:' + scoreColor + ';">' + Math.round(r.totalScore) + '%</div>'
                            + '    <div style="font-size:10px;color:var(--text-secondary);">Score global</div>'
                            + '  </div>'
                            + '</div>'
                            + '<div class="rec-score-bar"><div class="rec-score-fill" style="width:' + Math.round(r.totalScore) + '%;background:' + scoreBarColor + ';"></div></div>'
                            + '<div style="display:flex;gap:6px;flex-wrap:wrap;margin-top:10px;">'
                            + '  <span class="rec-badge blue">Compétences ' + Math.round(r.matchPercent) + '%</span>'
                            + '  <span class="rec-badge ' + (r.available ? 'green' : 'red') + '">' + (r.available ? 'Disponible' : 'Occupé') + '</span>'
                            + '  <span class="rec-badge ' + (r.budgetFit ? 'green' : 'red') + '">Budget ' + (r.budgetFit ? 'OK' : 'Dépassé') + '</span>'
                            + (r.leaderboardScore > 0 ? '  <span class="rec-badge purple">Score LB: ' + r.leaderboardScore + '</span>' : '')
                            + '</div>';

                        if (r.matchedCompetences && r.matchedCompetences.length > 0) {
                            html += '<div style="font-size:11px;color:var(--text-secondary);margin-top:6px;">Compétences matchées : <strong>' + r.matchedCompetences.join(', ') + '</strong></div>';
                        }

                        if (r.aiExplanation) {
                            html += '<div style="font-size:12px;color:var(--accent-purple);margin-top:8px;font-style:italic;padding:8px 12px;background:rgba(139,92,246,0.04);border-radius:6px;border-left:3px solid var(--accent-purple);">'
                                + r.aiExplanation
                                + '</div>';
                        }

                        html += '</div>';
                    });

                    matchingResults.innerHTML = html;

                    // Click to auto-select freelancer
                    matchingResults.querySelectorAll('.rec-card').forEach(function(card) {
                        card.addEventListener('click', function() {
                            var userId = card.dataset.userId;
                            if (userSelect) {
                                userSelect.value = userId;
                                // Visual feedback
                                matchingResults.querySelectorAll('.rec-card').forEach(function(c) { c.classList.remove('selected'); });
                                card.classList.add('selected');
                            }
                        });
                    });
                })
                .catch(function() {
                    matchingLoading.style.display = 'none';
                    matchingResults.innerHTML = '<p style="color:var(--accent-red);font-size:13px;text-align:center;padding:20px;">Erreur lors du chargement des recommandations.</p>';
                });
        });
    }
});
</script>
