{# templates/registration/register.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Inscription Freelancer{% endblock %}

{% block stylesheets %}
<style>
    .auth-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f4f0;
        padding: 2rem 1rem;
    }
    .auth-card {
        background: #fff;
        border: 0.5px solid #ddd;
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 540px;
    }
    .auth-header {
        margin-bottom: 2rem;
    }
    .auth-badge {
        display: inline-block;
        background: #e1f5ee;
        color: #0f6e56;
        font-size: 12px;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 20px;
        margin-bottom: 0.75rem;
        letter-spacing: 0.5px;
        text-transform: uppercase;
    }
    .auth-title {
        font-size: 26px;
        font-weight: 500;
        color: #1a1a1a;
        margin: 0 0 0.4rem;
        font-family: Georgia, serif;
    }
    .auth-sub {
        font-size: 14px;
        color: #888;
        margin: 0;
    }
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1rem;
    }
    .form-group {
        margin-bottom: 1.25rem;
    }
    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #444;
        margin-bottom: 6px;
    }
    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 10px 14px;
        border: 0.5px solid #ccc;
        border-radius: 8px;
        font-size: 14px;
        color: #1a1a1a;
        background: #fff;
        box-sizing: border-box;
        transition: border-color 0.15s;
        font-family: inherit;
    }
    .form-group input:focus,
    .form-group textarea:focus {
        outline: none;
        border-color: #1d9e75;
        box-shadow: 0 0 0 3px rgba(29,158,117,0.1);
    }
    .form-group textarea {
        resize: vertical;
        min-height: 90px;
    }
    .form-hint {
        font-size: 12px;
        color: #aaa;
        margin-top: 4px;
    }
    .form-error {
        font-size: 12px;
        color: #a32d2d;
        margin-top: 4px;
    }
    .section-label {
        font-size: 11px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.8px;
        color: #aaa;
        margin: 1.75rem 0 1rem;
        padding-bottom: 6px;
        border-bottom: 0.5px solid #eee;
    }
    .btn-submit {
        width: 100%;
        padding: 12px;
        background: #1d9e75;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        margin-top: 0.5rem;
        transition: background 0.15s, transform 0.1s;
        font-family: inherit;
    }
    .btn-submit:hover { background: #0f6e56; }
    .btn-submit:active { transform: scale(0.99); }
    .auth-footer {
        text-align: center;
        margin-top: 1.5rem;
        font-size: 13px;
        color: #888;
    }
    .auth-footer a {
        color: #1d9e75;
        text-decoration: none;
        font-weight: 500;
    }
    .flash-error {
        background: #fcebeb;
        border: 0.5px solid #f09595;
        color: #791f1f;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 1.5rem;
    }
    @media (max-width: 520px) {
        .form-row { grid-template-columns: 1fr; }
        .auth-card { padding: 1.5rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card">

        <div class="auth-header">
            <span class="auth-badge">Freelancer</span>
            <h1 class="auth-title">Créer un compte</h1>
            <p class="auth-sub">Rejoignez la plateforme et trouvez des missions</p>
        </div>

        {# Affichage des erreurs globales du formulaire #}
        {% for error in app.flashes('error') %}
            <div class="flash-error">{{ error }}</div>
        {% endfor %}

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="section-label">Informations personnelles</div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.nom) }}
                    {{ form_widget(form.nom, {'attr': {'placeholder': 'Test'}}) }}
                    {{ form_errors(form.nom) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.prenom) }}
                    {{ form_widget(form.prenom, {'attr': {'placeholder': 'Test'}}) }}
                    {{ form_errors(form.prenom) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.email) }}
                {{ form_widget(form.email, {'attr': {'placeholder': 'test@exemple.com'}}) }}
                {{ form_errors(form.email) }}
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.telephone) }}
                    {{ form_widget(form.telephone, {'attr': {'placeholder': '+216 XX XXX XXX'}}) }}
                    {{ form_errors(form.telephone) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.adresse) }}
                    {{ form_widget(form.adresse, {'attr': {'placeholder': 'Tunis, Tunisie'}}) }}
                    {{ form_errors(form.adresse) }}
                </div>
            </div>

            <div class="section-label">Profil professionnel</div>

            <div class="form-group">
                {{ form_label(form.description) }}
                {{ form_widget(form.description, {'attr': {'placeholder': 'Ex: Développeur full-stack expert React, Node.js et Python avec 5 ans d\'expérience...'}}) }}
                <p class="form-hint">Mentionnez vos technologies pour que vos compétences soient détectées automatiquement.</p>
                {{ form_errors(form.description) }}
            </div>

            <div class="section-label">Sécurité</div>

            <div class="form-group">
                {{ form_label(form.plainPassword.first) }}
                {{ form_widget(form.plainPassword.first, {'attr': {'placeholder': '••••••••'}}) }}
                {{ form_errors(form.plainPassword.first) }}
            </div>
            <div class="form-group">
                {{ form_label(form.plainPassword.second) }}
                {{ form_widget(form.plainPassword.second, {'attr': {'placeholder': '••••••••'}}) }}
                <p class="form-hint">Minimum 8 caractères, une majuscule et un chiffre.</p>
                {{ form_errors(form.plainPassword) }}
            </div>

            <button type="submit" class="btn-submit">Créer mon compte</button>

        {{ form_end(form) }}

        <div class="auth-footer">
            Déjà inscrit ? <a href="{{ path('app_login') }}">Se connecter</a>
        </div>

    </div>
</div>
{% endblock %}
