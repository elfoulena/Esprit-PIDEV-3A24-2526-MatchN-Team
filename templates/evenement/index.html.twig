{% extends 'back/base_admin.html.twig' %}

{% block title %}Gestion des Événements — MatchNTeam{% endblock %}
{% block page_title %}Gestion des Événements{% endblock %}

{% block extra_styles %}
.page-actions { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.btn-primary {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px; background: var(--accent-blue); color: #fff;
    border-radius: var(--radius-md); text-decoration: none;
    font-size: 13px; font-weight: 700;
    transition: all var(--transition); box-shadow: 0 2px 8px rgba(59,130,246,0.3);
}
.btn-primary:hover { background: #2563eb; transform: translateY(-1px); }

.btn-ai {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px; background: linear-gradient(135deg, var(--accent-purple), var(--ai-purple2, #6d28d9)); color: #fff;
    border-radius: var(--radius-md); text-decoration: none;
    font-size: 13px; font-weight: 700; border: none;
    transition: all var(--transition); box-shadow: 0 4px 12px rgba(139,92,246,0.3);
}
.btn-ai:hover { transform: translateY(-1px); filter: brightness(1.1); box-shadow: 0 6px 16px rgba(139,92,246,0.4); color: #fff; }

.filter-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); padding: 18px 22px; margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
}
.filter-form { display: flex; gap: 14px; flex-wrap: wrap; align-items: flex-end; }
.filter-group { display: flex; flex-direction: column; gap: 5px; }
.filter-label { font-size: 10px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; }
.filter-input {
    padding: 9px 13px; border: 1px solid var(--border-color);
    border-radius: var(--radius-sm); font-size: 13px; color: var(--text-primary);
    background: #fff; font-family: inherit; min-width: 250px;
    transition: border-color var(--transition);
}
.filter-input:focus { outline: none; border-color: var(--accent-blue); }

.btn-filter {
    padding: 9px 18px; background: var(--text-secondary); color: #fff;
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    font-weight: 600; cursor: pointer; font-family: inherit;
    transition: background var(--transition);
}
.btn-filter:hover { background: #475569; }

.btn-archive-toggle {
    padding: 9px 14px; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;
}

.data-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 12px 18px; text-align: left; font-size: 10.5px; font-weight: 700;
    color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc; border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 18px; font-size: 13px; border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }

.progress-bar { background: #e2e8f0; border-radius: 4px; height: 4px; width: 80px; margin-top: 4px; }
.progress-fill { height: 4px; border-radius: 4px; background: var(--accent-blue); }

.badge-status {
    padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; display: inline-block;
}
.badge-status.prevu   { background: rgba(16,185,129,0.12); color: #059669; }
.badge-status.en-cours { background: rgba(59,130,246,0.12); color: #2563eb; }
.badge-status.termine  { background: rgba(239,68,68,0.10); color: #dc2626; }

.action-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 8px;
    text-decoration: none; border: none; cursor: pointer;
    transition: all var(--transition);
}
.action-btn:hover { filter: brightness(0.9); transform: scale(1.05); }
.action-btn.view   { background: rgba(139,92,246,0.12); color: var(--accent-purple); }
.action-btn.edit   { background: rgba(59,130,246,0.12); color: var(--accent-blue); }
{% endblock %}

{% block content %}
    {# ── Header ── #}
    <div class="page-actions">
        <div>
            <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Événements</h2>
            <p style="font-size: 13px; color: var(--text-secondary); margin-top: 2px;">Liste complète des événements</p>
        </div>
        <div style="display: flex; gap: 12px;">
            <a href="{{ path('app_evenement_stats') }}" class="btn-ai">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 12V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h7"/><path d="M9 11l3 3L22 4"/><path d="M15 19l2 2 4-4"/></svg>
                Statistiques & IA
            </a>
            <a href="{{ path('app_evenement_new') }}" class="btn-primary">
                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                Nouvel Événement
            </a>
        </div>
    </div>

    {# ── Filters ── #}
    <div class="filter-card">
        <form method="get" action="{{ path('app_evenement_index') }}" class="filter-form">
            <div class="filter-group">
                <label class="filter-label">Rechercher</label>
                <input type="text" name="q" class="filter-input" value="{{ q|default('') }}" placeholder="Nom, type ou lieu...">
                <input type="hidden" name="archived" value="{{ archived ? 1 : 0 }}">
            </div>
            <div style="display: flex; gap: 8px; align-items: flex-end;">
                <button type="submit" class="btn-filter">Rechercher</button>
                <a href="{{ path('app_evenement_index', {archived: archived ? 0 : 1, q: q}) }}" 
                   class="btn-archive-toggle" 
                   style="background: {{ archived ? 'rgba(239,68,68,0.10)' : 'rgba(16,185,129,0.12)' }}; color: {{ archived ? '#dc2626' : '#059669' }};">
                    {{ archived ? 'Masquer archives' : 'Afficher archives' }}
                </a>
                {% if q or archived %}
                    <a href="{{ path('app_evenement_index') }}" style="font-size: 13px; color: var(--text-secondary); text-decoration: none; margin-left: 8px;">Réinitialiser</a>
                {% endif %}
            </div>
        </form>
    </div>

    {# ── Table ── #}
    <div class="data-card">
        <div style="overflow-x: auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Date & Heure</th>
                        <th>Lieu</th>
                        <th>Capacité</th>
                        <th>Statut</th>
                        <th style="text-align:right; padding-right: 22px;">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for evenement in evenements %}
                    <tr>
                        <td>
                            <div style="font-weight: 700; color: var(--text-primary);">{{ evenement.titre }}</div>
                        </td>
                        <td style="color: var(--text-secondary);">{{ evenement.typeEvenement }}</td>
                        <td>
                            <div style="font-weight: 600;">{{ evenement.dateDebut ? evenement.dateDebut|date('d/m/Y') : '—' }}</div>
                            <div style="font-size: 11px; color: var(--text-secondary);">{{ evenement.dateDebut ? evenement.dateDebut|date('H:i') : '' }}</div>
                        </td>
                        <td>
                            <a href="https://www.google.com/maps/search/?api=1&query={{ evenement.lieu|url_encode }}" target="_blank" style="color: var(--text-secondary); text-decoration: none; border-bottom: 1px dashed #cbd5e1; display: inline-flex; align-items: center; gap: 4px;">
                                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                                {{ evenement.lieu }}
                            </a>
                        </td>
                        <td>
                            <div style="display: flex; align-items: center; gap: 8px;">
                                <span style="font-weight: 700; color: var(--accent-blue);">{{ evenement.nombreActuel }}</span>
                                <span style="color: var(--text-secondary);">/ {{ evenement.capaciteMax }}</span>
                                <div class="progress-bar">
                                    {% set pct = evenement.capaciteMax > 0 ? ((evenement.nombreActuel / evenement.capaciteMax) * 100)|round : 0 %}
                                    <div class="progress-fill" style="width: {{ pct > 100 ? 100 : pct }}%;"></div>
                                </div>
                            </div>
                        </td>
                        <td>
                            {% if evenement.dateFin < date() %}
                                <span class="badge-status termine">● Terminé</span>
                            {% elseif evenement.statut == 'en_cours' %}
                                <span class="badge-status en-cours">● En cours</span>
                            {% else %}
                                <span class="badge-status prevu">● Prévu</span>
                            {% endif %}
                        </td>
                        <td>
                            <div style="display: flex; gap: 6px; justify-content: flex-end;">
                                <a href="{{ path('app_evenement_show', {'id_evenement': evenement.id_evenement}) }}" class="action-btn view" title="Voir">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                </a>
                                <a href="{{ path('app_evenement_edit', {'id_evenement': evenement.id_evenement}) }}" class="action-btn edit" title="Modifier">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div style="padding: 60px; text-align: center; color: var(--text-secondary);">
                                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="opacity: 0.3; margin-bottom: 14px;"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                                <p style="font-size: 14px;">Aucun événement trouvé</p>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
