{% extends 'front/base_front.html.twig' %}

{% block title %}Nos Événements - Matchup{% endblock %}

{% block body %}

<!-- Page Title -->
<div class="page-title dark-background" data-aos="fade" style="background-image: url({{ asset('assets/img/page-title-bg.webp') }});">
  <div class="container position-relative">
    <h1>Événements Disponibles</h1>
    <p>Découvrez et participez à nos prochains meetups, workshops et conférences.</p>
    <nav class="breadcrumbs">
      <ol>
        <li><a href="{{ path('app_dashboard') }}">Home</a></li>
        <li class="current">Événements</li>
      </ol>
    </nav>
  </div>
</div><!-- End Page Title -->

<section id="events" class="events section">
  <div class="container" data-aos="fade-up">

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('error') %}
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('warning') %}
        <div class="alert alert-warning alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}
    {% for message in app.flashes('info') %}
        <div class="alert alert-info alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    {% endfor %}

    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 mb-4">
            <div class="filter-card shadow-sm">
                <div class="filter-section">
                    <h5 class="filter-title">Filtrer</h5>
                    <div class="search-box">
                        <input type="text" id="sidebar-search" class="form-control" placeholder="Rechercher..." value="{{ q }}">
                    </div>
                </div>

                <div class="filter-divider"></div>

                <div class="filter-section">
                    <h5 class="filter-title">Type d'événement</h5>
                    <div class="filter-options">
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-all" value="ALL" {% if type == 'ALL' %}checked{% endif %}>
                            <label class="form-check-label" for="type-all">Tous</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-workshop" value="WORKSHOP" {% if type == 'WORKSHOP' %}checked{% endif %}>
                            <label class="form-check-label" for="type-workshop">Workshop</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-meetup" value="MEETUP" {% if type == 'MEETUP' %}checked{% endif %}>
                            <label class="form-check-label" for="type-meetup">Meetup</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-conference" value="CONFERENCE" {% if type == 'CONFERENCE' %}checked{% endif %}>
                            <label class="form-check-label" for="type-conference">Conférence</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-competition" value="COMPETITION" {% if type == 'COMPETITION' %}checked{% endif %}>
                            <label class="form-check-label" for="type-competition">Compétition</label>
                        </div>
                        <div class="form-check mb-2">
                            <input class="form-check-input type-filter" type="radio" name="eventType" id="type-formation" value="FORMATION" {% if type == 'FORMATION' %}checked{% endif %}>
                            <label class="form-check-label" for="type-formation">Formation</label>
                        </div>
                    </div>
                </div>

                <div class="filter-divider"></div>

                <div class="filter-section">
                    <h5 class="filter-title">Trier par</h5>
                    <select id="sort-select" class="form-select">
                        <option value="date_asc" {% if sort == 'date_asc' %}selected{% endif %}>Date la plus proche</option>
                        <option value="date_desc" {% if sort == 'date_desc' %}selected{% endif %}>Date la plus lointaine</option>
                        <option value="titre_asc" {% if sort == 'titre_asc' %}selected{% endif %}>Titre (A-Z)</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Event List Container -->
        <div class="col-lg-9">
            <div id="event-list-container">
                {% include 'front/evenement/_list.html.twig' %}
            </div>
        </div>
    </div>

  </div>
</section>

<style>
.filter-card {
    background: #fff;
    border-radius: 20px;
    padding: 25px;
    border: 1px solid rgba(0,0,0,0.05);
    position: sticky;
    top: 100px;
}
.filter-section {
    margin-bottom: 20px;
}
.filter-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: #1a1f2e;
    margin-bottom: 15px;
}
.filter-divider {
    height: 1px;
    background: #eee;
    margin: 20px 0;
}
.search-box .form-control {
    border-radius: 12px;
    padding: 10px 15px;
    border: 1px solid #ddd;
    font-size: 0.9rem;
}
.form-check-input:checked {
    background-color: #3b82f6;
    border-color: #3b82f6;
}
.form-check-label {
    font-size: 0.9rem;
    color: #4b5563;
    cursor: pointer;
}
.form-select {
    border-radius: 12px;
    padding: 10px 15px;
    font-size: 0.9rem;
    cursor: pointer;
}
</style>

{% endblock %}

{% block modals %}
<!-- Event Detail Modal -->
<div class="modal fade" id="eventDetailModal" tabindex="-1" aria-labelledby="eventDetailModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow" style="border-radius: 20px;">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-bold" id="eventDetailModalLabel">Détails de l'événement</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body p-4">
        <div class="badge bg-primary-subtle text-primary mb-3" id="modal-event-type">TYPE</div>
        <h3 class="fw-bold mb-3" id="modal-event-title" style="color: #1a1f2e;">Titre</h3>
        
        <div class="info-item mb-3">
          <i class="bi bi-calendar3 text-primary me-2"></i>
          <span id="modal-event-date">Date</span>
        </div>
        <div class="info-item mb-3">
          <i class="bi bi-geo-alt text-primary me-2"></i>
          <span id="modal-event-lieu">Lieu</span>
        </div>
        <div class="info-item mb-4">
          <i class="bi bi-people text-primary me-2"></i>
          <span id="modal-event-capacity">Participants</span>
        </div>

        <div class="description-box bg-light p-3 rounded-3 mb-4">
           <p class="mb-0 text-muted small" id="modal-event-desc">Description...</p>
        </div>
      </div>
      <div class="modal-footer border-0">
        <button type="button" class="btn btn-secondary px-4 rounded-pill" data-bs-dismiss="modal">Fermer</button>
      </div>
    </div>
  </div>
</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Existing filter logic...
    const listContainer = document.getElementById('event-list-container');
    const searchInput = document.getElementById('sidebar-search');
    const typeFilters = document.querySelectorAll('.type-filter');
    const sortSelect = document.getElementById('sort-select');
    
    let timeout = null;

    function refreshEvents() {
        const q = searchInput.value;
        const type = document.querySelector('.type-filter:checked').value;
        const sort = sortSelect.value;
        
        const params = new URLSearchParams({
            q: q,
            type: type,
            sort: sort
        });

        fetch(`{{ path('app_front_evenement_search') }}?${params.toString()}`)
            .then(response => response.text())
            .then(html => {
                listContainer.innerHTML = html;
                if (typeof AOS !== 'undefined') AOS.refresh();
            })
            .catch(err => console.error('Erreur filtrage:', err));
    }

    if (searchInput) {
        searchInput.addEventListener('input', () => {
            clearTimeout(timeout);
            timeout = setTimeout(refreshEvents, 300);
        });
    }

    typeFilters.forEach(radio => {
        radio.addEventListener('change', refreshEvents);
    });

    if (sortSelect) {
        sortSelect.addEventListener('change', refreshEvents);
    }

    // Modal Logic
    const eventDetailModal = document.getElementById('eventDetailModal');
    if (eventDetailModal) {
        eventDetailModal.addEventListener('show.bs.modal', function (event) {
            const button = event.relatedTarget;
            
            // Extract info from data attributes
            const title = button.getAttribute('data-title');
            const type = button.getAttribute('data-type');
            const date = button.getAttribute('data-date');
            const lieu = button.getAttribute('data-lieu');
            const desc = button.getAttribute('data-desc');
            const capacity = button.getAttribute('data-capacity');

            // Update modal content
            eventDetailModal.querySelector('#modal-event-title').textContent = title;
            eventDetailModal.querySelector('#modal-event-type').textContent = type;
            eventDetailModal.querySelector('#modal-event-date').textContent = date;
            eventDetailModal.querySelector('#modal-event-lieu').textContent = lieu;
            eventDetailModal.querySelector('#modal-event-desc').textContent = desc;
            eventDetailModal.querySelector('#modal-event-capacity').textContent = capacity;
        });
    }
});
</script>
{% endblock %}


