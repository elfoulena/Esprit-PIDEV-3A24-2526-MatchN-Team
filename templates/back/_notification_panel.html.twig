{% set notificationCount = unread_notifications_count(app.user) %}
{% set latestNotifications = latest_notifications(app.user, 6) %}

<div class="notif-wrap">
    <button type="button" class="notif-btn" id="notifToggle">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor">
            <path d="M15 17h5l-1.4-1.4A2 2 0 0 1 18 14.2V11a6 6 0 1 0-12 0v3.2a2 2 0 0 1-.6 1.4L4 17h5"/>
            <path d="M9.5 17a2.5 2.5 0 0 0 5 0"/>
        </svg>
        {% if notificationCount > 0 %}
            <span class="notif-badge">{{ notificationCount > 99 ? '99+' : notificationCount }}</span>
        {% endif %}
    </button>

    <div class="notif-menu" id="notifMenu">
        <div class="notif-head">
            <span>Notifications</span>
            {% if notificationCount > 0 %}
                <form method="post" action="{{ path('app_notification_mark_all_read') }}">
                    <input type="hidden" name="_token" value="{{ csrf_token('mark_all_notifications') }}">
                    <button class="notif-link-btn" type="submit">Tout lire</button>
                </form>
            {% endif %}
        </div>

        {% if latestNotifications is empty %}
            <div class="notif-empty">Aucune notification.</div>
        {% else %}
            <div class="notif-list">
                {% for notification in latestNotifications %}
                    <article class="notif-item {% if not notification.isRead %}notif-item-unread{% endif %}">
                        <div class="notif-title">{{ notification.titre }}</div>
                        <div class="notif-text">{{ notification.message }}</div>
                        <div class="notif-foot">
                            <span>{{ notification.createdAt|date('d/m/Y H:i') }}</span>
                            <div class="notif-actions">
                                {% if notification.lien %}
                                    <a href="{{ notification.lien }}">Ouvrir</a>
                                {% endif %}
                                {% if not notification.isRead %}
                                    <form method="post" action="{{ path('app_notification_mark_read', {'id': notification.id}) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('mark_notification_' ~ notification.id) }}">
                                        <button class="notif-link-btn" type="submit">Marquer lu</button>
                                    </form>
                                {% endif %}
                            </div>
                        </div>
                    </article>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</div>
