{# templates/admin/users/show.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}{{ user.nom }} {{ user.prenom }} — MatchNTeam{% endblock %}
{% block page_title %}Détails utilisateur{% endblock %}

{% block extra_styles %}
.profile-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    max-width: 680px;
}
.profile-banner {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 60%, #7c3aed 100%);
    padding: 28px 32px;
    display: flex;
    align-items: center;
    gap: 20px;
}
.profile-avatar {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    display: flex; align-items: center; justify-content: center;
    font-size: 22px; font-weight: 800; color: #fff;
    border: 3px solid rgba(255,255,255,0.35);
    flex-shrink: 0;
}
.profile-name { font-size: 20px; font-weight: 800; color: #fff; }
.profile-email { font-size: 13px; color: rgba(255,255,255,0.75); margin-top: 3px; }
.profile-body { padding: 28px 32px; }
.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
}
.info-item {}
.info-item .label {
    font-size: 11px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 4px;
}
.info-item .value {
    font-size: 14px; font-weight: 600;
    color: var(--text-primary);
}
.badge {
    display: inline-flex;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 12px; font-weight: 700;
}
.badge-admin    { background: rgba(139,92,246,0.12); color: #7c3aed; }
.badge-rh       { background: rgba(59,130,246,0.12); color: #2563eb; }
.badge-employe  { background: rgba(16,185,129,0.12); color: #059669; }
.badge-freelancer { background: rgba(245,158,11,0.12); color: #d97706; }
.status-dot {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 700;
}
.status-dot.active   { background: rgba(16,185,129,0.12); color: #059669; }
.status-dot.inactive { background: rgba(239,68,68,0.10); color: #dc2626; }
.status-dot.pending  { background: rgba(245,158,11,0.12); color: #d97706; }
.profile-actions {
    display: flex; gap: 10px;
    padding: 20px 32px;
    border-top: 1px solid var(--border-color);
}
.btn-edit {
    padding: 10px 20px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    color: #fff; border-radius: var(--radius-md);
    text-decoration: none; font-size: 13px; font-weight: 700;
    display: inline-flex; align-items: center; gap: 7px;
}
.btn-back {
    padding: 10px 20px;
    background: var(--bg-surface);
    color: var(--text-secondary);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    text-decoration: none; font-size: 13px; font-weight: 600;
    display: inline-flex; align-items: center; gap: 7px;
}
{% endblock %}

{% block content %}

<div style="margin-bottom: 20px;">
    <a href="{{ path('admin_users_index') }}" style="color:var(--text-secondary); text-decoration:none; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux utilisateurs
    </a>
</div>

<div class="profile-card">
    <div class="profile-banner">
        <div class="profile-avatar">
            {{ (user.nom|slice(0,1) ~ user.prenom|slice(0,1))|upper }}
        </div>
        <div>
            <div class="profile-name">{{ user.nom }} {{ user.prenom }}</div>
            <div class="profile-email">{{ user.email }}</div>
        </div>
    </div>

    <div class="profile-body">
        <div class="info-grid">
            <div class="info-item">
                <div class="label">Rôle</div>
                <div class="value">
                    {% if user.role.value == 'ADMIN_RH' %}
                        <span class="badge badge-admin">Administrateur</span>
                    {% elseif user.role.value == 'EMPLOYE' %}
                        <span class="badge badge-employe">Employé</span>
                    {% else %}
                        <span class="badge badge-freelancer">Freelancer</span>
                    {% endif %}
                </div>
            </div>
            <div class="info-item">
                <div class="label">Statut du compte</div>
                <div class="value">
                    <span class="status-dot {{ user.actif ? 'active' : 'inactive' }}">
                        ● {{ user.actif ? 'Actif' : 'Inactif' }}
                    </span>
                </div>
            </div>
            <div class="info-item">
                <div class="label">Vérification email</div>
                <div class="value">
                    {% if user.verified %}
                        <span class="status-dot active">✓ Vérifié</span>
                    {% elseif user.role.value == 'ADMIN_RH' %}
                        <span class="status-dot active">✓ Admin</span>
                    {% else %}
                        <span class="status-dot pending">⏳ En attente</span>
                    {% endif %}
                </div>
            </div>
            <div class="info-item">
                <div class="label">Téléphone</div>
                <div class="value">{{ user.telephone ?: '—' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Adresse</div>
                <div class="value">{{ user.adresse ?: '—' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Créé le</div>
                <div class="value">{{ user.createdAt ? user.createdAt|date('d/m/Y à H:i') : '—' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Mis à jour le</div>
                <div class="value">{{ user.updatedAt ? user.updatedAt|date('d/m/Y à H:i') : '—' }}</div>
            </div>
            {% if user.role.value == 'EMPLOYE' %}
            <div class="info-item">
                <div class="label">Poste</div>
                <div class="value">{{ user.poste ?: '—' }}</div>
            </div>
            <div class="info-item">
                <div class="label">Département</div>
                <div class="value">{{ user.departement ?: '—' }}</div>
            </div>
            {% endif %}
        </div>
    </div>

    <div class="profile-actions">
        <a href="{{ path('admin_users_edit', {'id': user.id}) }}" class="btn-edit">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Modifier
        </a>
        <a href="{{ path('admin_users_index') }}" class="btn-back">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Retour
        </a>
    </div>
</div>

{% endblock %}
