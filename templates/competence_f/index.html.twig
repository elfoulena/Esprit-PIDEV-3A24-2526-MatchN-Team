{# templates/competence_f/index.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Compétences — MatchNTeam{% endblock %}
{% block page_title %}Compétences Freelancers{% endblock %}

{% block extra_styles %}
/* ── Page header ── */
.page-banner {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 60%, #7c3aed 100%);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    color: #fff;
    position: relative;
    overflow: hidden;
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
}
.page-banner::before {
    content: '';
    position: absolute;
    top: -50px; right: -50px;
    width: 220px; height: 220px;
    border-radius: 50%;
    background: rgba(255,255,255,0.06);
    pointer-events: none;
}
.page-banner::after {
    content: '';
    position: absolute;
    bottom: -30px; right: 180px;
    width: 130px; height: 130px;
    border-radius: 50%;
    background: rgba(255,255,255,0.05);
    pointer-events: none;
}
.banner-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
.banner-sub   { font-size: 13px; opacity: 0.72; }
.btn-add {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px;
    background: rgba(255,255,255,0.15);
    border: 1px solid rgba(255,255,255,0.30);
    border-radius: var(--radius-md);
    color: #fff; font-size: 13px; font-weight: 700;
    text-decoration: none; white-space: nowrap;
    backdrop-filter: blur(4px);
    transition: background 0.18s;
    position: relative; z-index: 1;
}
.btn-add:hover { background: rgba(255,255,255,0.25); }

/* ── Layout ── */
.competence-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 24px;
    align-items: start;
}
@media (max-width: 1100px) {
    .competence-layout { grid-template-columns: 1fr; }
}

/* ── Data card (same as dashboard) ── */
.data-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}

.section-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 18px 22px 14px;
    border-bottom: 1px solid var(--border-color);
}
.section-title {
    font-size: 14px; font-weight: 800; color: var(--text-primary);
    display: flex; align-items: center; gap: 8px;
}
.section-title .badge {
    font-size: 11px; font-weight: 700; padding: 2px 9px;
    border-radius: 20px; background: var(--bg-surface); color: var(--text-secondary);
}
.search-wrap {
    position: relative;
}
.search-wrap svg {
    position: absolute; left: 10px; top: 50%; transform: translateY(-50%);
    color: var(--text-secondary); pointer-events: none;
}
.search-input {
    padding: 7px 12px 7px 32px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    color: var(--text-primary);
    font-size: 12px;
    width: 200px;
    outline: none;
    transition: border-color 0.15s;
}
.search-input:focus { border-color: var(--accent-blue); }

/* ── Table ── */
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 11px 20px;
    text-align: left;
    font-size: 11px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 20px;
    font-size: 13.5px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-primary);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }
.data-table tbody tr.selected-row { background: rgba(37,99,235,0.06); }

.skill-name { font-weight: 700; color: var(--text-primary); }
.skill-desc {
    font-size: 12px; color: var(--text-secondary);
    max-width: 320px;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
}
.ia-badge {
    display: inline-flex; align-items: center; gap: 4px;
    font-size: 10px; font-weight: 700; padding: 2px 7px;
    border-radius: 20px;
    background: rgba(139,92,246,0.10); color: #7c3aed;
}

.actions-cell { display: flex; align-items: center; gap: 6px; }
.btn-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: var(--radius-sm);
    border: none; cursor: pointer; transition: all 0.15s;
    text-decoration: none;
}
.btn-icon.edit   { background: rgba(59,130,246,0.10); color: var(--accent-blue); }
.btn-icon.delete { background: rgba(239,68,68,0.10); color: #dc2626; }
.btn-icon:hover  { filter: brightness(0.88); transform: scale(1.08); }

/* ── Form panel ── */
.form-panel {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    position: sticky;
    top: 24px;
}
.form-panel-header {
    padding: 18px 22px 14px;
    border-bottom: 1px solid var(--border-color);
    display: flex; align-items: center; justify-content: space-between;
}
.form-panel-title {
    font-size: 14px; font-weight: 800; color: var(--text-primary);
    display: flex; align-items: center; gap: 8px;
}
.form-panel-title .dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent-blue);
}
.form-panel-title .dot.edit { background: var(--accent-purple); }
.form-panel-body { padding: 22px; }

.form-group { margin-bottom: 18px; }
.form-label {
    display: block;
    font-size: 11px; font-weight: 700; color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.6px;
    margin-bottom: 7px;
}
.form-control {
    width: 100%;
    padding: 9px 12px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    background: var(--bg-surface);
    color: var(--text-primary);
    font-size: 13.5px;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    box-sizing: border-box;
    font-family: inherit;
}
.form-control:focus {
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(37,99,235,0.10);
}
textarea.form-control { resize: vertical; min-height: 90px; }

.ia-hint {
    display: flex; align-items: flex-start; gap: 8px;
    padding: 10px 12px;
    background: rgba(139,92,246,0.07);
    border: 1px solid rgba(139,92,246,0.18);
    border-radius: var(--radius-sm);
    margin-top: 8px;
    font-size: 12px; color: #6d28d9; line-height: 1.5;
}
.ia-hint svg { flex-shrink: 0; margin-top: 1px; }

.form-actions {
    display: flex; gap: 10px; margin-top: 22px; padding-top: 18px;
    border-top: 1px solid var(--border-color);
}
.btn-primary {
    flex: 1; display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 16px;
    background: var(--accent-blue); color: #fff;
    border: none; border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 700; cursor: pointer;
    transition: opacity 0.15s;
}
.btn-primary.purple { background: var(--accent-purple); }
.btn-primary:hover { opacity: 0.88; }
.btn-reset {
    display: inline-flex; align-items: center; justify-content: center; gap: 6px;
    padding: 10px 14px;
    background: var(--bg-surface); color: var(--text-secondary);
    border: 1px solid var(--border-color); border-radius: var(--radius-sm);
    font-size: 13px; font-weight: 600; cursor: pointer;
    text-decoration: none;
    transition: all 0.15s;
}
.btn-reset:hover { border-color: var(--accent-blue); color: var(--accent-blue); }

/* ── Flash messages ── */
.flash-success {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 18px; margin-bottom: 20px;
    background: rgba(16,185,129,0.10);
    border: 1px solid rgba(16,185,129,0.28);
    border-radius: var(--radius-md);
    font-size: 13px; font-weight: 600; color: #059669;
}
.flash-error {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 18px; margin-bottom: 20px;
    background: rgba(239,68,68,0.08);
    border: 1px solid rgba(239,68,68,0.24);
    border-radius: var(--radius-md);
    font-size: 13px; font-weight: 600; color: #dc2626;
}
.empty-state {
    text-align: center; padding: 48px 24px;
    color: var(--text-secondary); font-size: 13px;
}
.empty-state svg { opacity: 0.3; margin-bottom: 12px; }
{% endblock %}

{% block content %}

{# ── Flash messages ── #}
{% for msg in app.flashes('success') %}
    <div class="flash-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        {{ msg }}
    </div>
{% endfor %}
{% for msg in app.flashes('error') %}
    <div class="flash-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        {{ msg }}
    </div>
{% endfor %}

{# ── Banner ── #}
<div class="page-banner">
    <div>
        <div class="banner-title">Gestion des Compétences</div>
        <div class="banner-sub">Référentiel des compétences disponibles pour les freelancers</div>
    </div>
    <a href="#formPanel" class="btn-add">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle compétence
    </a>
</div>

{# ── Main layout ── #}
<div class="competence-layout">

    {# ── Left : table ── #}
    <div>
        <div class="data-card">
            <div class="section-header">
                <div class="section-title">
                    Toutes les compétences
                    <span class="badge">{{ competences|length }}</span>
                </div>
                <div class="search-wrap">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
                    <input type="text" class="search-input" id="searchInput" placeholder="Rechercher…" oninput="filterTable(this.value)">
                </div>
            </div>

            <table class="data-table" id="competenceTable">
                <thead>
                    <tr>
                        <th>Nom</th>
                        <th>Description</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for competence in competences %}
                    <tr data-search="{{ (competence.nom ~ ' ' ~ competence.description)|lower }}">
                        <td>
                            <div class="skill-name">{{ competence.nom }}</div>
                        </td>
                        <td>
                            <div class="skill-desc" title="{{ competence.description }}">
                                {{ competence.description ?? 'Aucune description.' }}
                            </div>
                        </td>
                        <td>
                            <div class="actions-cell">
                                <a href="{{ path('competence_edit', {'id': competence.id}) }}" class="btn-icon edit" title="Modifier">
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                </a>
                                <form method="post" action="{{ path('competence_delete', {'id': competence.id}) }}" style="margin:0;" onsubmit="return confirm('Supprimer « {{ competence.nom }} » ? Cette action est irréversible.')">
                                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ competence.id) }}">
                                    <button type="submit" class="btn-icon delete" title="Supprimer">
                                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4">
                            <div class="empty-state">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
                                <div>Aucune compétence enregistrée.</div>
                                <div style="margin-top: 6px; opacity: .6;">Cliquez sur « Nouvelle compétence » pour commencer.</div>
                            </div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    {# ── Right : form ── #}
    <div>
        <div class="form-panel">
            <div class="form-panel-header">
                <div class="form-panel-title">
                    <span class="dot"></span>
                    Nouvelle compétence
                </div>
                <span class="ia-badge">
                    <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                    IA
                </span>
            </div>
            <div class="form-panel-body">
                <form method="post" action="{{ path('competence_index') }}">
                    {{ form_errors(form) }}

                    <div class="form-group">
                        {{ form_label(form.nom, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.nom, {'attr': {'class': 'form-control', 'placeholder': 'Ex : Symfony, Docker, React…'}}) }}
                        {{ form_errors(form.nom) }}
                    </div>

                    <div class="form-group">
                        {{ form_label(form.description, null, {'label_attr': {'class': 'form-label'}}) }}
                        {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Laisser vide pour génération automatique…', 'rows': 4}}) }}
                        {{ form_errors(form.description) }}
                        <div class="ia-hint">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                            Si vide, la description sera générée automatiquement par l'IA à partir du nom de la compétence.
                        </div>
                    </div>

                    {{ form_rest(form) }}
                    <div class="form-actions">
                        <button type="submit" class="btn-primary">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                            Ajouter
                        </button>
                        <button type="reset" class="btn-reset">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3.51"/></svg>
                            Vider
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

</div>

<script>
function filterTable(query) {
    const q = query.toLowerCase();
    document.querySelectorAll('#competenceTable tbody tr[data-search]').forEach(row => {
        row.style.display = row.dataset.search.includes(q) ? '' : 'none';
    });
}
</script>
{% endblock %}
