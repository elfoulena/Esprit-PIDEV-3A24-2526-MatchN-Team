{# templates/admin/users/index.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Utilisateurs — MatchNTeam{% endblock %}
{% block page_title %}Gestion des Utilisateurs{% endblock %}

{% block extra_styles %}
.page-banner {
    background: linear-gradient(135deg, #1e3a5f 0%, #2563eb 60%, #7c3aed 100%);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    color: #fff;
    position: relative;
    overflow: hidden;
    margin-bottom: 28px;
}
.page-banner::before {
    content: ''; position: absolute; top: -50px; right: -50px;
    width: 220px; height: 220px; border-radius: 50%;
    background: rgba(255,255,255,0.06); pointer-events: none;
}
.page-banner::after {
    content: ''; position: absolute; bottom: -30px; right: 180px;
    width: 130px; height: 130px; border-radius: 50%;
    background: rgba(255,255,255,0.05); pointer-events: none;
}
.banner-title { font-size: 22px; font-weight: 800; margin-bottom: 4px; }
.banner-sub   { font-size: 13px; opacity: 0.72; }

/* Stats */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
}
.stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px 22px;
    position: relative; overflow: hidden;
    transition: transform 0.18s, box-shadow 0.18s;
    box-shadow: var(--shadow-sm);
}
.stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.stat-card::before {
    content: ''; position: absolute; top: 0; right: 0;
    width: 70px; height: 70px; border-radius: 0 var(--radius-lg) 0 70px; opacity: 0.07;
}
.stat-card.blue::before   { background: var(--accent-blue); }
.stat-card.purple::before { background: var(--accent-purple); }
.stat-card.green::before  { background: var(--accent-green); }
.stat-card.orange::before { background: var(--accent-orange); }
.stat-icon {
    width: 38px; height: 38px; border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center; margin-bottom: 12px;
}
.stat-card.blue   .stat-icon { background: rgba(59,130,246,0.12); color: var(--accent-blue); }
.stat-card.purple .stat-icon { background: rgba(139,92,246,0.12); color: var(--accent-purple); }
.stat-card.green  .stat-icon { background: rgba(16,185,129,0.12); color: var(--accent-green); }
.stat-card.orange .stat-icon { background: rgba(245,158,11,0.12); color: var(--accent-orange); }
.stat-value { font-size: 30px; font-weight: 800; color: var(--text-primary); line-height: 1; margin-bottom: 3px; }
.stat-label { font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; }

/* Toolbar */
.toolbar {
    display: flex; align-items: center; gap: 10px; flex-wrap: wrap;
    padding: 14px 20px;
    border-bottom: 1px solid var(--border-color);
    background: var(--card-bg);
}
.search-wrap { position: relative; }
.search-wrap svg { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); color: var(--text-secondary); pointer-events: none; }
.search-input {
    padding: 8px 12px 8px 32px;
    border: 1px solid var(--border-color); border-radius: var(--radius-sm);
    background: var(--bg-surface); color: var(--text-primary);
    font-size: 13px; width: 220px; outline: none;
    transition: border-color 0.15s;
}
.search-input:focus { border-color: var(--accent-blue); }

.filter-tabs { display: flex; gap: 6px; }
.filter-tab {
    padding: 6px 14px; border-radius: 20px;
    font-size: 12px; font-weight: 700;
    border: 1px solid var(--border-color);
    background: var(--bg-surface); color: var(--text-secondary);
    text-decoration: none; cursor: pointer;
    transition: all 0.15s;
}
.filter-tab:hover, .filter-tab.active {
    background: var(--accent-blue); color: #fff; border-color: var(--accent-blue);
}
.filter-tab.employe.active  { background: var(--accent-green); border-color: var(--accent-green); }
.filter-tab.freelancer.active { background: var(--accent-purple); border-color: var(--accent-purple); }
.filter-tab.admin.active    { background: var(--accent-orange); border-color: var(--accent-orange); }

.total-label {
    margin-left: auto; font-size: 12px; font-weight: 600; color: var(--text-secondary);
}

/* Table */
.data-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
}
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 11px 18px; text-align: left;
    font-size: 11px; font-weight: 700; color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc; border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 13px 18px; font-size: 13.5px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-primary); vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }

/* Avatar */
.user-avatar {
    width: 34px; height: 34px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 800; color: #fff; flex-shrink: 0;
}
.user-info { display: flex; align-items: center; gap: 10px; }
.user-name  { font-weight: 700; font-size: 13.5px; color: var(--text-primary); }
.user-email { font-size: 11.5px; color: var(--text-secondary); }

/* Role badge */
.role-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 3px 10px; border-radius: 20px;
    font-size: 11px; font-weight: 700;
}
.role-badge.ADMIN_RH   { background: rgba(245,158,11,0.12); color: #b45309; }
.role-badge.EMPLOYE    { background: rgba(16,185,129,0.12); color: #059669; }
.role-badge.FREELANCER { background: rgba(139,92,246,0.12); color: #7c3aed; }

/* Status */
.status-dot {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;
}
.status-dot.active   { background: rgba(16,185,129,0.12); color: #059669; }
.status-dot.inactive { background: rgba(239,68,68,0.10);  color: #dc2626; }

/* Actions */
.actions-cell { display: flex; align-items: center; gap: 5px; }
.btn-icon {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px; border-radius: var(--radius-sm);
    border: none; cursor: pointer; transition: all 0.15s; text-decoration: none;
}
.btn-icon.view   { background: rgba(59,130,246,0.10);  color: var(--accent-blue); }
.btn-icon.toggle-on  { background: rgba(239,68,68,0.10);  color: #dc2626; }
.btn-icon.toggle-off { background: rgba(16,185,129,0.12); color: #059669; }
.btn-icon.delete { background: rgba(239,68,68,0.10);  color: #dc2626; }
.btn-icon:hover  { filter: brightness(0.88); transform: scale(1.08); }

/* Role select inline */
.role-select {
    padding: 4px 8px; border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    background: var(--bg-surface); color: var(--text-primary);
    font-size: 12px; font-weight: 600; cursor: pointer; outline: none;
}

/* Flash */
.flash-success {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 18px; margin-bottom: 20px;
    background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.28);
    border-radius: var(--radius-md); font-size: 13px; font-weight: 600; color: #059669;
}
.flash-error {
    display: flex; align-items: center; gap: 10px;
    padding: 12px 18px; margin-bottom: 20px;
    background: rgba(239,68,68,0.08); border: 1px solid rgba(239,68,68,0.24);
    border-radius: var(--radius-md); font-size: 13px; font-weight: 600; color: #dc2626;
}
.empty-state { text-align: center; padding: 48px 24px; color: var(--text-secondary); font-size: 13px; }
.empty-state svg { opacity: 0.3; margin-bottom: 12px; }

@media (max-width: 1100px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
}
{% endblock %}

{% block content %}

{# Flash #}
{% for msg in app.flashes('success') %}
    <div class="flash-success">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
        {{ msg }}
    </div>
{% endfor %}
{% for msg in app.flashes('error') %}
    <div class="flash-error">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
        {{ msg }}
    </div>
{% endfor %}

{# Banner #}
{# Dans le .page-banner, ajouter ce bouton #}
<div class="page-banner">
    <div>
        <div class="banner-title">Gestion des Utilisateurs</div>
        <div class="banner-sub">{{ stats.total }} utilisateurs enregistrés — {{ stats.actifs }} actifs</div>
    </div>
    {# ← Ajouter ce bouton #}
    <a href="{{ path('admin_user_create_employe') }}" style="
        display: inline-flex; align-items: center; gap: 7px; padding: 10px 20px;
        background: rgba(255,255,255,0.15); border: 1px solid rgba(255,255,255,0.30);
        border-radius: var(--radius-md); color: #fff; font-size: 13px; font-weight: 700;
        text-decoration: none; backdrop-filter: blur(4px); transition: background 0.18s;
        position: relative; z-index: 1; white-space: nowrap;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/></svg>
        Créer un employé
    </a>
</div>

{# Stats #}
<div class="stats-grid">
    <div class="stat-card blue">
        <div class="stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <div class="stat-value">{{ stats.total }}</div>
        <div class="stat-label">Total utilisateurs</div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
        </div>
        <div class="stat-value">{{ stats.employes }}</div>
        <div class="stat-label">Employés</div>
    </div>
    <div class="stat-card purple">
        <div class="stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
        </div>
        <div class="stat-value">{{ stats.freelancers }}</div>
        <div class="stat-label">Freelancers</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <div class="stat-value">{{ stats.admins }}</div>
        <div class="stat-label">Admins RH</div>
    </div>
</div>

{# Table #}
<div class="data-card">

    {# Toolbar #}
    <div class="toolbar">
        <div class="search-wrap">
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <form method="get" action="{{ path('admin_user_index') }}" style="display:inline">
                {% if currentRole %}<input type="hidden" name="role" value="{{ currentRole }}">{% endif %}
                <input type="text" class="search-input" name="q" value="{{ search }}" placeholder="Rechercher un utilisateur…" oninput="this.form.submit()">
            </form>
        </div>

        <div class="filter-tabs">
            <a href="{{ path('admin_user_index', {q: search}) }}"
               class="filter-tab {{ not currentRole ? 'active' : '' }}">Tous</a>
            <a href="{{ path('admin_user_index', {role: 'EMPLOYE', q: search}) }}"
               class="filter-tab employe {{ currentRole == 'EMPLOYE' ? 'active' : '' }}">Employés</a>
            <a href="{{ path('admin_user_index', {role: 'FREELANCER', q: search}) }}"
               class="filter-tab freelancer {{ currentRole == 'FREELANCER' ? 'active' : '' }}">Freelancers</a>
            <a href="{{ path('admin_user_index', {role: 'ADMIN_RH', q: search}) }}"
               class="filter-tab admin {{ currentRole == 'ADMIN_RH' ? 'active' : '' }}">Admins</a>
        </div>

        <span class="total-label">{{ utilisateurs|length }} résultat(s)</span>
    </div>

    {# Data table #}
    <table class="data-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Utilisateur</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Compétences</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for u in utilisateurs %}
            {% set initiales = u.nom|first ~ u.prenom|first %}
            {% set colors = ['#2563eb','#7c3aed','#059669','#b45309','#dc2626','#0891b2'] %}
            {% set color = colors[loop.index0 % colors|length] %}
            <tr>
                <td style="color:var(--text-secondary); font-size:12px; width:36px;">{{ loop.index }}</td>

                {# Utilisateur #}
                <td>
                    <div class="user-info">
                        <div class="user-avatar" style="background: {{ color }};">
                            {{ initiales|upper }}
                        </div>
                        <div>
                            <div class="user-name">{{ u.nom }} {{ u.prenom }}</div>
                            <div class="user-email">{{ u.email }}</div>
                        </div>
                    </div>
                </td>

                {# Rôle avec changement rapide #}
                <td>
                    <form method="post" action="{{ path('admin_user_role', {id: u.id}) }}" style="margin:0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('role_' ~ u.id) }}">
                        <select name="role" class="role-select" onchange="this.form.submit()">
                            <option value="EMPLOYE"    {{ u.role.value == 'EMPLOYE'    ? 'selected' : '' }}>Employé</option>
                            <option value="FREELANCER" {{ u.role.value == 'FREELANCER' ? 'selected' : '' }}>Freelancer</option>
                            <option value="ADMIN_RH"   {{ u.role.value == 'ADMIN_RH'   ? 'selected' : '' }}>Admin RH</option>
                        </select>
                    </form>
                </td>

                {# Statut #}
                <td>
                    <span class="status-dot {{ u.actif ? 'active' : 'inactive' }}">
                        ● {{ u.actif ? 'Actif' : 'Inactif' }}
                    </span>
                </td>

                {# Compétences (freelancers seulement) #}
                <td>
                    {% if u.role.value == 'FREELANCER' and u.competences is defined %}
                        {% if u.competences|length > 0 %}
                            <span style="font-size:12px; font-weight:600; color:var(--accent-purple);">
                                {{ u.competences|length }} compétence(s)
                            </span>
                        {% else %}
                            <span style="font-size:12px; color:var(--text-secondary);">Aucune</span>
                        {% endif %}
                    {% else %}
                        <span style="font-size:12px; color:var(--text-secondary);">—</span>
                    {% endif %}
                </td>

                {# Actions #}
                <td>
                    <div class="actions-cell">
                        {# Voir le profil #}
                        <a href="{{ path('admin_user_show', {id: u.id}) }}" class="btn-icon view" title="Voir le profil">
                            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>

                        {# Activer / Désactiver #}
                        <form method="post" action="{{ path('admin_user_toggle', {id: u.id}) }}" style="margin:0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_' ~ u.id) }}">
                            <button type="submit" class="btn-icon {{ u.actif ? 'toggle-on' : 'toggle-off' }}"
                                    title="{{ u.actif ? 'Désactiver' : 'Activer' }}">
                                {% if u.actif %}
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="16" cy="12" r="3" fill="currentColor"/></svg>
                                {% else %}
                                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="8" cy="12" r="3" fill="currentColor"/></svg>
                                {% endif %}
                            </button>
                        </form>

                        {# Supprimer #}
                        {% if u != app.user %}
                        <form method="post" action="{{ path('admin_user_delete', {id: u.id}) }}" style="margin:0;"
                              onsubmit="return confirm('Supprimer {{ u.nom }} {{ u.prenom }} ? Cette action est irréversible.')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_' ~ u.id) }}">
                            <button type="submit" class="btn-icon delete" title="Supprimer">
                                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">
                    <div class="empty-state">
                        <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
                        <div>Aucun utilisateur trouvé.</div>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
