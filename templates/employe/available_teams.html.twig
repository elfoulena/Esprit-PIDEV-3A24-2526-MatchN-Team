{% extends 'back/base_employe.html.twig' %}

{% block title %}Équipes disponibles — MatchNTeam{% endblock %}
{% block page_title %}Rejoindre une équipe{% endblock %}

{% block extra_styles %}
.filter-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 18px 22px;
    margin-bottom: 20px;
    box-shadow: var(--shadow-sm);
}
.filter-form {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: flex-end;
}
.filter-group {
    display: flex;
    flex-direction: column;
    gap: 5px;
}
.filter-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 1px;
}
.filter-input, .filter-select {
    padding: 9px 13px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm);
    font-size: 13px;
    color: var(--text-primary);
    background: #fff;
    font-family: inherit;
    min-width: 140px;
}
.filter-input:focus, .filter-select:focus {
    outline: none;
    border-color: var(--accent-blue);
}
.btn-filter {
    padding: 9px 18px;
    background: var(--accent-blue);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
}
.btn-reset {
    padding: 9px 14px;
    background: var(--bg-surface);
    color: var(--text-primary);
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
}
.team-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px;
    transition: all var(--transition);
    position: relative;
}
.team-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}
.team-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
}
.team-avatar {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
}
.team-name {
    font-size: 16px;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 4px;
}
.team-department {
    font-size: 11px;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
}
.team-description {
    font-size: 13px;
    color: var(--text-secondary);
    margin: 12px 0;
    line-height: 1.5;
}
.team-stats {
    display: flex;
    gap: 16px;
    margin: 12px 0;
    padding: 12px 0;
    border-top: 1px solid var(--border-color);
    border-bottom: 1px solid var(--border-color);
}
.stat-item {
    flex: 1;
    text-align: center;
}
.stat-value {
    font-size: 18px;
    font-weight: 800;
    color: var(--accent-blue);
}
.stat-label {
    font-size: 10px;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
}
.progress-bar {
    background: #e2e8f0;
    border-radius: 4px;
    height: 4px;
    width: 100%;
    margin-top: 6px;
}
.progress-fill {
    height: 4px;
    border-radius: 4px;
    background: var(--accent-blue);
}
.btn-request {
    width: 100%;
    padding: 10px;
    background: var(--accent-blue);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
}
.btn-request:hover {
    background: #2563eb;
    transform: translateY(-1px);
}
.btn-pending {
    width: 100%;
    padding: 10px;
    background: #fef3c7;
    color: #d97706;
    border: 1px solid #fde68a;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: not-allowed;
}
.teams-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 20px;
}
.empty-state {
    text-align: center;
    padding: 60px;
    color: var(--text-secondary);
}
{% endblock %}

{% block content %}

<div class="filter-card">
    <form method="get" action="{{ path('employe_available_teams') }}" class="filter-form">
        <div class="filter-group">
            <label class="filter-label">Rechercher</label>
            <input type="text" name="search" class="filter-input" value="{{ search }}" placeholder="Nom de l'équipe...">
        </div>
        <div class="filter-group">
            <label class="filter-label">Département</label>
            <select name="departement" class="filter-select">
                <option value="">Tous</option>
                {% for dept in departements %}
                    <option value="{{ dept }}" {{ departement == dept ? 'selected' }}>{{ dept }}</option>
                {% endfor %}
            </select>
        </div>
        <div style="display: flex; gap: 8px;">
            <button type="submit" class="btn-filter">Filtrer</button>
            <a href="{{ path('employe_available_teams') }}" class="btn-reset">Reset</a>
        </div>
    </form>
</div>

{% if teams is empty %}
    <div class="empty-state">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="opacity: 0.3;">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <p style="margin-top: 16px; font-size: 14px;">Aucune équipe disponible pour le moment.</p>
    </div>
{% else %}
    <div class="teams-grid">
        {% for team in teams %}
            <div class="team-card">
                <div class="team-header">
                    <div class="team-avatar" style="background: {{ team.couleurEquipe }}22;">
                        <span style="font-size: 20px; font-weight: 800; color: {{ team.couleurEquipe }};">
                            {{ team.nomEquipe|slice(0,1)|upper }}
                        </span>
                    </div>
                    <div>
                        <div class="team-name">{{ team.nomEquipe }}</div>
                        <div class="team-department">{{ team.departement ?? 'Département non défini' }}</div>
                    </div>
                </div>
                
                {% if team.description %}
                    <div class="team-description">{{ team.description|slice(0,100) }}{% if team.description|length > 100 %}...{% endif %}</div>
                {% endif %}
                
                <div class="team-stats">
                    <div class="stat-item">
                        <div class="stat-value">{{ team.nbMembresActuel }}/{{ team.nbMembresMax }}</div>
                        <div class="stat-label">Membres</div>
                        <div class="progress-bar">
                            {% set pct = team.nbMembresMax > 0 ? ((team.nbMembresActuel / team.nbMembresMax) * 100)|round : 0 %}
                            <div class="progress-fill" style="width: {{ pct > 100 ? 100 : pct }}%;"></div>
                        </div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-value">{{ team.budget ? team.budget ~ ' DT' : '—' }}</div>
                        <div class="stat-label">Budget</div>
                    </div>
                </div>
                
                {% if team.idEquipe in pendingTeamIds %}
                    <button class="btn-pending" disabled>
                        ⏳ Demande en attente
                    </button>
                {% else %}
                    <a href="{{ path('employe_request_team', {'id_equipe': team.idEquipe}) }}" class="btn-request" style="display: block; text-align: center; text-decoration: none;">
                        📝 Demander à rejoindre
                    </a>
                {% endif %}
            </div>
        {% endfor %}
    </div>
{% endif %}

<div style="margin-top: 24px; text-align: center;">
    <a href="{{ path('employe_dashboard') }}" class="btn-cancel" style="display: inline-flex; align-items: center; gap: 6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Retour au tableau de bord
    </a>
</div>

{% endblock %}