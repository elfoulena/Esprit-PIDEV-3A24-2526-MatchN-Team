{# templates/ai_statistics/team_stats.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}AI Analytics - {{ equipe.nomEquipe }}{% endblock %}
{% block page_title %}🤖 Analyse IA: {{ equipe.nomEquipe }}{% endblock %}

{% block content %}
<div style="margin-bottom: 24px;">
    <div style="display: flex; justify-content: space-between; align-items: center;">
        <div>
            <a href="{{ path('app_equipe_show', {'id_equipe': equipe.idEquipe}) }}" 
               style="color: var(--text-secondary); text-decoration: none; font-size: 14px;">
                ← Retour à l'équipe
            </a>
        </div>
        <div>
            <button onclick="window.location.reload()" 
                    style="padding: 8px 16px; background: var(--bg-surface); border: none; border-radius: 8px; cursor: pointer;">
                🔄 Actualiser
            </button>
        </div>
    </div>
</div>

<div id="statsContent">
    <!-- Loading indicator -->
    <div style="text-align: center; padding: 60px;">
        <div class="loading">🤖 Chargement des analyses en temps réel...</div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', async function() {
    const container = document.getElementById('statsContent');
    
    try {
        const response = await fetch('{{ path('api_ai_team_stats', {'id_equipe': equipe.idEquipe}) }}');
        const stats = await response.json();
        
        // Render the stats with all the AI insights
        container.innerHTML = renderStats(stats);
        
        // Initialize charts if needed
        initializeCharts(stats);
    } catch (error) {
        container.innerHTML = '<div style="text-align: center; padding: 60px; color: #ef4444;">❌ Erreur lors du chargement des analyses</div>';
        console.error('Error:', error);
    }
});

function renderStats(stats) {
    return `
        <!-- Team Metrics -->
        <div class="ai-insight-card">
            <div class="insight-header">
                <div class="insight-icon">📊</div>
                <div>
                    <h3 style="margin: 0;">Métriques de performance</h3>
                    <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-secondary);">Indicateurs clés de l'équipe</p>
                </div>
            </div>
            <div class="metrics-grid">
                ${Object.entries(stats.team_metrics).map(([key, value]) => `
                    <div class="metric-item">
                        <div class="metric-label">${formatMetricLabel(key)}</div>
                        <div class="metric-value ${getMetricColor(value)}">${value}${isPercentage(key) ? '%' : ''}</div>
                    </div>
                `).join('')}
            </div>
        </div>
        
        <!-- AI Predictions -->
        <div class="ai-insight-card">
            <div class="insight-header">
                <div class="insight-icon">🔮</div>
                <div>
                    <h3 style="margin: 0;">Prédictions et tendances</h3>
                    <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-secondary);">Analyse prédictive basée sur l'IA</p>
                </div>
            </div>
            <div class="predictions-grid">
                <div class="prediction-card">
                    <div class="prediction-title">Performance prédite</div>
                    <div class="prediction-value">${stats.ai_predictions.performance_prediction.predicted_score}%</div>
                    <div class="prediction-detail">Niveau de confiance: ${stats.ai_predictions.performance_prediction.confidence_level}%</div>
                    <div class="trend-indicator ${stats.ai_predictions.performance_prediction.trend}">
                        ${getTrendIcon(stats.ai_predictions.performance_prediction.trend)} Tendance ${getTrendText(stats.ai_predictions.performance_prediction.trend)}
                    </div>
                </div>
                <div class="prediction-card">
                    <div class="prediction-title">Probabilité de succès</div>
                    <div class="prediction-value">${stats.ai_predictions.success_probability}%</div>
                    <div class="prediction-detail">Basé sur ${stats.team_metrics.total_members} membres actifs</div>
                </div>
                <div class="prediction-card">
                    <div class="prediction-title">Potentiel de croissance</div>
                    <div class="prediction-value">${stats.ai_predictions.growth_potential}%</div>
                    <div class="prediction-detail">Opportunités d'amélioration identifiées</div>
                </div>
            </div>
        </div>
        
        <!-- Skill Gap Analysis -->
        <div class="ai-insight-card">
            <div class="insight-header">
                <div class="insight-icon">🎯</div>
                <div>
                    <h3 style="margin: 0;">Analyse des compétences</h3>
                    <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-secondary);">Lacunes et opportunités de développement</p>
                </div>
            </div>
            <div class="skill-analysis">
                <div class="overall-coverage">
                    <div>Couverture globale: ${stats.ai_predictions.skill_gap_analysis.overall_coverage}%</div>
                    <div>Lacunes critiques: ${stats.ai_predictions.skill_gap_analysis.critical_gaps}</div>
                </div>
                ${stats.ai_predictions.skill_gap_analysis.gaps.map(gap => `
                    <div class="skill-gap-item">
                        <div class="skill-gap-header">
                            <span class="skill-name">${gap.skill}</span>
                            <span class="skill-coverage ${gap.severity}">${gap.coverage}%</span>
                        </div>
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: ${gap.coverage}%; background: ${getSeverityColor(gap.severity)};"></div>
                        </div>
                        <div class="recommendation">💡 ${gap.recommendation}</div>
                    </div>
                `).join('')}
            </div>
        </div>
        
        <!-- Turnover Risk -->
        ${stats.ai_predictions.turnover_risk.at_risk_members.length > 0 ? `
            <div class="ai-insight-card">
                <div class="insight-header">
                    <div class="insight-icon">⚠️</div>
                    <div>
                        <h3 style="margin: 0;">Risques de départ</h3>
                        <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-secondary);">Membres nécessitant une attention particulière</p>
                    </div>
                </div>
                ${stats.ai_predictions.turnover_risk.at_risk_members.map(member => `
                    <div class="risk-card risk-${member.risk_level}">
                        <div class="risk-header">
                            <strong>${member.member}</strong>
                            <span class="risk-score">Risque: ${member.risk_score}%</span>
                        </div>
                        <div class="risk-factors">
                            ${member.factors.map(factor => `<div class="risk-factor">• ${factor}</div>`).join('')}
                        </div>
                    </div>
                `).join('')}
                <div class="risk-summary">
                    <strong>Risque moyen: ${stats.ai_predictions.turnover_risk.average_risk}%</strong>
                    <span>${stats.ai_predictions.turnover_risk.critical_count} membre(s) à risque critique</span>
                </div>
            </div>
        ` : ''}
        
        <!-- Recommendations -->
        <div class="ai-insight-card">
            <div class="insight-header">
                <div class="insight-icon">💡</div>
                <div>
                    <h3 style="margin: 0;">Recommandations stratégiques</h3>
                    <p style="margin: 4px 0 0; font-size: 12px; color: var(--text-secondary);">Actions recommandées par l'IA</p>
                </div>
            </div>
            ${stats.insights.recommendations.map(rec => `
                <div class="recommendation-card priority-${rec.priority}">
                    <div class="recommendation-header">
                        <span class="recommendation-title">${rec.title}</span>
                        <span class="priority-badge">Priorité ${rec.priority}</span>
                    </div>
                    <div class="recommendation-action">${rec.action}</div>
                    <div class="recommendation-impact">📈 Impact: ${rec.impact}</div>
                </div>
            `).join('')}
        </div>
        
        <!-- Team Strengths & Weaknesses -->
        <div class="strengths-weaknesses">
            <div class="strengths-card">
                <h4>✅ Forces de l'équipe</h4>
                ${stats.insights.strengths.map(strength => `<div class="strength-item">${strength}</div>`).join('')}
                ${stats.insights.strengths.length === 0 ? '<div>Aucune force identifiée</div>' : ''}
            </div>
            <div class="weaknesses-card">
                <h4>⚠️ Points d'amélioration</h4>
                ${stats.insights.weaknesses.map(weakness => `<div class="weakness-item">${weakness}</div>`).join('')}
                ${stats.insights.weaknesses.length === 0 ? '<div>Aucune faiblesse majeure détectée</div>' : ''}
            </div>
            <div class="opportunities-card">
                <h4>🚀 Opportunités</h4>
                ${stats.insights.opportunities.map(opp => `<div class="opportunity-item">${opp}</div>`).join('')}
                ${stats.insights.opportunities.length === 0 ? '<div>Opportunités à explorer</div>' : ''}
            </div>
        </div>
    `;
}

function formatMetricLabel(key) {
    const labels = {
        'total_members': 'Membres totaux',
        'member_turnover_rate': 'Taux de rotation',
        'average_participation_rate': 'Participation moyenne',
        'engagement_score': 'Score d\'engagement',
        'team_health_score': 'Santé de l\'équipe',
        'budget_efficiency': 'Efficacité budgétaire',
        'diversity_score': 'Score de diversité',
        'productivity_index': 'Indice productivité'
    };
    return labels[key] || key.replace(/_/g, ' ');
}

function getMetricColor(value) {
    if (value >= 80) return 'metric-excellent';
    if (value >= 60) return 'metric-good';
    if (value >= 40) return 'metric-average';
    return 'metric-poor';
}

function isPercentage(key) {
    const percentageKeys = ['engagement_score', 'team_health_score', 'budget_efficiency', 'diversity_score', 'productivity_index', 'average_participation_rate'];
    return percentageKeys.includes(key);
}

function getTrendIcon(trend) {
    if (trend === 'upward') return '📈';
    if (trend === 'downward') return '📉';
    return '➡️';
}

function getTrendText(trend) {
    if (trend === 'upward') return 'Hausse';
    if (trend === 'downward') return 'Baisse';
    return 'Stable';
}

function getSeverityColor(severity) {
    if (severity === 'high') return '#ef4444';
    if (severity === 'medium') return '#f59e0b';
    return '#10b981';
}

function initializeCharts(stats) {
    // You can add Chart.js or other charting libraries here
    console.log('Initializing charts with data:', stats);
}
</script>

<style>
.metrics-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
}

.metric-item {
    padding: 12px;
    background: #f8fafc;
    border-radius: 12px;
    text-align: center;
}

.metric-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.metric-value {
    font-size: 24px;
    font-weight: 800;
}

.metric-excellent { color: #10b981; }
.metric-good { color: #3b82f6; }
.metric-average { color: #f59e0b; }
.metric-poor { color: #ef4444; }

.predictions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 20px;
}

.prediction-card {
    background: linear-gradient(135deg, #f8fafc, #f1f5f9);
    padding: 16px;
    border-radius: 12px;
    text-align: center;
}

.prediction-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text-secondary);
    margin-bottom: 8px;
}

.prediction-value {
    font-size: 32px;
    font-weight: 800;
    color: var(--accent-blue);
    margin-bottom: 8px;
}

.trend-indicator {
    font-size: 12px;
    margin-top: 8px;
}

.trend-indicator.upward { color: #10b981; }
.trend-indicator.downward { color: #ef4444; }

.skill-gap-item {
    margin-bottom: 16px;
}

.skill-gap-header {
    display: flex;
    justify-content: space-between;
    margin-bottom: 8px;
}

.skill-name { font-weight: 600; }
.skill-coverage.high { color: #ef4444; }
.skill-coverage.medium { color: #f59e0b; }
.skill-coverage.low { color: #10b981; }

.recommendation {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 8px;
}

.risk-card {
    padding: 16px;
    border-radius: 12px;
    margin-bottom: 16px;
}

.risk-high { background: linear-gradient(135deg, #fee2e2, #fecaca); }
.risk-medium { background: linear-gradient(135deg, #fef3c7, #fed7aa); }

.risk-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.risk-score {
    font-weight: 800;
    color: #dc2626;
}

.risk-factors {
    font-size: 13px;
}

.recommendation-card {
    padding: 16px;
    border-radius: 12px;
    margin-bottom: 16px;
    background: #f8fafc;
}

.priority-high { border-left: 4px solid #ef4444; }
.priority-medium { border-left: 4px solid #f59e0b; }
.priority-low { border-left: 4px solid #10b981; }

.recommendation-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
}

.recommendation-title {
    font-weight: 700;
    font-size: 16px;
}

.priority-badge {
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 12px;
    background: #e2e8f0;
}

.recommendation-action {
    font-size: 14px;
    margin-bottom: 8px;
}

.recommendation-impact {
    font-size: 12px;
    color: var(--text-secondary);
}

.strengths-weaknesses {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 20px;
    margin-top: 24px;
}

.strengths-card, .weaknesses-card, .opportunities-card {
    padding: 20px;
    border-radius: 16px;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
}

.strength-item, .weakness-item, .opportunity-item {
    padding: 8px 0;
    border-bottom: 1px solid var(--border-color);
}

.strength-item:last-child, .weakness-item:last-child, .opportunity-item:last-child {
    border-bottom: none;
}
</style>
{% endblock %}