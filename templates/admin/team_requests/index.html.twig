{% extends 'back/base_admin.html.twig' %}

{% block title %}Gestion des demandes d'équipe — MatchNTeam{% endblock %}
{% block page_title %}Demandes d'adhésion{% endblock %}

{% block extra_styles %}
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 28px;
}
.stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 20px;
    text-align: center;
    transition: all var(--transition);
}
.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}
.stat-number {
    font-size: 32px;
    font-weight: 800;
    color: var(--accent-blue);
}
.stat-label {
    font-size: 12px;
    color: var(--text-secondary);
    text-transform: uppercase;
    font-weight: 600;
    margin-top: 4px;
}
.requests-section {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    margin-bottom: 24px;
    overflow: hidden;
}
.section-header {
    padding: 16px 20px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border-color);
    font-weight: 800;
    font-size: 14px;
    color: var(--text-primary);
}
.request-item {
    padding: 20px;
    border-bottom: 1px solid var(--border-color);
    transition: background var(--transition);
}
.request-item:last-child {
    border-bottom: none;
}
.request-item:hover {
    background: #f8fafc;
}
.request-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: 12px;
    margin-bottom: 12px;
}
.employee-info {
    display: flex;
    align-items: center;
    gap: 12px;
}
.employee-avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-weight: 800;
    font-size: 16px;
}
.employee-name {
    font-weight: 700;
    color: var(--text-primary);
    font-size: 15px;
}
.employee-email {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 2px;
}
.team-badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(59,130,246,0.10);
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    color: var(--accent-blue);
}
.request-message {
    background: #f8fafc;
    border-radius: var(--radius-sm);
    padding: 12px 16px;
    margin: 12px 0;
    font-size: 13px;
    color: var(--text-secondary);
    border-left: 3px solid var(--accent-blue);
}
.request-message strong {
    color: var(--text-primary);
    display: block;
    margin-bottom: 6px;
}
.request-details {
    display: flex;
    gap: 20px;
    font-size: 12px;
    color: var(--text-secondary);
    margin-bottom: 16px;
    flex-wrap: wrap;
}
.request-actions {
    display: flex;
    gap: 10px;
    justify-content: flex-end;
}
.btn-approve, .btn-reject {
    padding: 8px 24px;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
    text-decoration: none;
    display: inline-block;
}
.btn-approve {
    background: rgba(16,185,129,0.12);
    color: #059669;
}
.btn-approve:hover {
    background: rgba(16,185,129,0.20);
    transform: translateY(-1px);
}
.btn-reject {
    background: rgba(239,68,68,0.10);
    color: #dc2626;
}
.btn-reject:hover {
    background: rgba(239,68,68,0.20);
    transform: translateY(-1px);
}
.empty-state {
    text-align: center;
    padding: 60px;
    color: var(--text-secondary);
}
/* Modal Styles */
.modal {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0,0,0,0.5);
    z-index: 1000;
    align-items: center;
    justify-content: center;
}
.modal.show {
    display: flex;
}
.modal-content {
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    max-width: 400px;
    width: 90%;
    box-shadow: var(--shadow-md);
}
.modal-header {
    padding: 20px 24px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: center;
}
.modal-header h3 {
    font-size: 18px;
    font-weight: 800;
    margin: 0;
}
.modal-close {
    background: none;
    border: none;
    font-size: 24px;
    cursor: pointer;
    color: var(--text-secondary);
}
.modal-body {
    padding: 24px;
}
.modal-footer {
    padding: 16px 24px;
    border-top: 1px solid var(--border-color);
    display: flex;
    justify-content: flex-end;
    gap: 12px;
}
.btn-secondary {
    padding: 8px 20px;
    background: var(--bg-surface);
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
}
.btn-primary {
    padding: 8px 20px;
    background: var(--accent-blue);
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
}
.btn-danger {
    padding: 8px 20px;
    background: #dc2626;
    color: #fff;
    border: none;
    border-radius: var(--radius-sm);
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
}
.tab-buttons {
    display: flex;
    gap: 10px;
    margin-bottom: 24px;
}
.tab-btn {
    padding: 10px 24px;
    background: var(--bg-surface);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
}
.tab-btn.active {
    background: var(--accent-blue);
    color: #fff;
    border-color: var(--accent-blue);
}
.tab-btn:hover:not(.active) {
    background: var(--card-bg);
    transform: translateY(-1px);
}
{% endblock %}

{% block content %}

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-number">{{ pendingRequests|length }}</div>
        <div class="stat-label">⏳ En attente</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">{{ approvedRequests|length }}</div>
        <div class="stat-label">✓ Approuvées</div>
    </div>
    <div class="stat-card">
        <div class="stat-number">{{ rejectedRequests|length }}</div>
        <div class="stat-label">✗ Rejetées</div>
    </div>
</div>

<div class="tab-buttons">
    <button class="tab-btn active" onclick="showTab('pending')">📋 En attente</button>
    <button class="tab-btn" onclick="showTab('approved')">✓ Approuvées</button>
    <button class="tab-btn" onclick="showTab('rejected')">✗ Rejetées</button>
</div>

<!-- Pending Requests -->
<div id="pending-tab" class="requests-section">
    <div class="section-header">
        Demandes en attente ({{ pendingRequests|length }})
    </div>
    {% if pendingRequests is empty %}
        <div class="empty-state">
            <p>Aucune demande en attente.</p>
        </div>
    {% else %}
        {% for request in pendingRequests %}
            <div class="request-item" id="request-{{ request.id }}">
                <div class="request-info">
                    <div class="employee-info">
                        <div class="employee-avatar">
                            {{ request.employee.prenom|slice(0,1) }}{{ request.employee.nom|slice(0,1) }}
                        </div>
                        <div>
                            <div class="employee-name">{{ request.employee.prenom }} {{ request.employee.nom }}</div>
                            <div class="employee-email">{{ request.employee.email }}</div>
                        </div>
                    </div>
                    <div class="team-badge">
                        🏢 {{ request.team.nomEquipe }}
                    </div>
                </div>
                
                <div class="request-details">
                    <span>📅 {{ request.createdAt|date('d/m/Y H:i') }}</span>
                    <span>🎯 Rôle: <strong>{{ request.requestedRole ?? 'Membre' }}</strong></span>
                </div>
                
                {% if request.message %}
                    <div class="request-message">
                        <strong>💬 Message:</strong>
                        {{ request.message }}
                    </div>
                {% endif %}
                
                <div class="request-actions">
                    <form method="post" action="{{ path('admin_team_request_reject', {'id': request.id}) }}" style="display: inline-block;" onsubmit="return confirm('Voulez-vous vraiment rejeter cette demande ?')">
                        <input type="hidden" name="_token" value="{{ csrf_token('reject_request_' ~ request.id) }}">
                        <input type="hidden" name="rejection_reason" value="Demande rejetée par l'administrateur">
                        <button type="submit" class="btn-reject">✗ Rejeter</button>
                    </form>
                    <form method="post" action="{{ path('admin_team_request_approve', {'id': request.id}) }}" style="display: inline-block;" onsubmit="return confirm('Voulez-vous vraiment approuver cette demande ? L\'employé sera ajouté à l\'équipe.')">
                        <input type="hidden" name="_token" value="{{ csrf_token('approve_request_' ~ request.id) }}">
                        <button type="submit" class="btn-approve">✓ Approuver</button>
                    </form>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>

<!-- Approved Requests -->
<div id="approved-tab" class="requests-section" style="display: none;">
    <div class="section-header">
        Demandes approuvées ({{ approvedRequests|length }})
    </div>
    {% if approvedRequests is empty %}
        <div class="empty-state">
            <p>Aucune demande approuvée.</p>
        </div>
    {% else %}
        {% for request in approvedRequests %}
            <div class="request-item">
                <div class="request-info">
                    <div class="employee-info">
                        <div class="employee-avatar">
                            {{ request.employee.prenom|slice(0,1) }}{{ request.employee.nom|slice(0,1) }}
                        </div>
                        <div>
                            <div class="employee-name">{{ request.employee.prenom }} {{ request.employee.nom }}</div>
                            <div class="employee-email">{{ request.employee.email }}</div>
                        </div>
                    </div>
                    <div class="team-badge">
                        🏢 {{ request.team.nomEquipe }}
                    </div>
                </div>
                <div class="request-details">
                    <span>📅 Demandé: {{ request.createdAt|date('d/m/Y H:i') }}</span>
                    <span>✓ Approuvé: {{ request.processedAt|date('d/m/Y H:i') }}</span>
                </div>
            </div>
        {% endfor %}
    {% endif %}
</div>

<!-- Rejected Requests -->
<div id="rejected-tab" class="requests-section" style="display: none;">
    <div class="section-header">
        Demandes rejetées ({{ rejectedRequests|length }})
    </div>
    {% if rejectedRequests is empty %}
        <div class="empty-state">
            <p>Aucune demande rejetée.</p>
        </div>
    {% else %}
        {% for request in rejectedRequests %}
            <div class="request-item">
                <div class="request-info">
                    <div class="employee-info">
                        <div class="employee-avatar">
                            {{ request.employee.prenom|slice(0,1) }}{{ request.employee.nom|slice(0,1) }}
                        </div>
                        <div>
                            <div class="employee-name">{{ request.employee.prenom }} {{ request.employee.nom }}</div>
                            <div class="employee-email">{{ request.employee.email }}</div>
                        </div>
                    </div>
                    <div class="team-badge">
                        🏢 {{ request.team.nomEquipe }}
                    </div>
                </div>
                <div class="request-details">
                    <span>📅 Demandé: {{ request.createdAt|date('d/m/Y H:i') }}</span>
                    <span>✗ Rejeté: {{ request.processedAt|date('d/m/Y H:i') }}</span>
                </div>
                {% if request.adminNotes %}
                    <div class="request-message" style="border-left-color: #dc2626;">
                        <strong>📌 Motif:</strong>
                        {{ request.adminNotes }}
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    {% endif %}
</div>

<script>
function showTab(tab) {
    // Hide all tabs
    document.getElementById('pending-tab').style.display = 'none';
    document.getElementById('approved-tab').style.display = 'none';
    document.getElementById('rejected-tab').style.display = 'none';
    
    // Show selected tab
    document.getElementById(tab + '-tab').style.display = 'block';
    
    // Update active button
    document.querySelectorAll('.tab-btn').forEach(btn => {
        btn.classList.remove('active');
    });
    event.target.classList.add('active');
}
</script>

{% endblock %}