{# templates/admin/projets/show.html.twig #}
{% extends 'back/base_admin.html.twig' %}
{% block title %}{{ projet.titre }}{% endblock %}
{% block page_title %}Détail du projet{% endblock %}
{% block extra_styles %}
.detail-card { background:var(--card-bg); border:1px solid var(--border-color); border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); padding:32px 36px; max-width:860px; }
.detail-header { display:flex; align-items:flex-start; justify-content:space-between; gap:16px; margin-bottom:28px; padding-bottom:20px; border-bottom:1px solid var(--border-color); }
.detail-title { font-size:20px; font-weight:800; margin-bottom:6px; }
.detail-meta { display:flex; gap:10px; align-items:center; flex-wrap:wrap; }
.detail-actions { display:flex; gap:8px; flex-shrink:0; }
.section-label { font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.8px; margin-bottom:12px; padding-bottom:8px; border-bottom:1px solid var(--border-color); }
.detail-grid { display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px; }
.detail-grid-3 { display:grid; grid-template-columns:1fr 1fr 1fr; gap:20px; margin-bottom:24px; }
.detail-field label { display:block; font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.5px; margin-bottom:5px; }
.detail-field .val { font-size:14px; font-weight:600; color:var(--text-primary); }
.detail-field .val.empty { color:var(--text-secondary); font-weight:400; font-style:italic; }
.badge { display:inline-flex; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
.badge-en_cours   { background:rgba(59,130,246,0.12); color:#1d4ed8; }
.badge-termine    { background:rgba(16,185,129,0.12); color:#059669; }
.badge-en_pause   { background:rgba(245,158,11,0.12); color:#d97706; }
.badge-planifie   { background:rgba(139,92,246,0.12); color:#7c3aed; }
.badge-annule     { background:rgba(239,68,68,0.10); color:#dc2626; }
.prio-haute   { color:#dc2626; font-weight:700; }
.prio-moyenne { color:#d97706; font-weight:700; }
.prio-basse   { color:#059669; font-weight:700; }
.vis-badge { display:inline-flex; align-items:center; gap:4px; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; }
.vis-employe    { background:rgba(14,165,233,0.1); color:#0369a1; }
.vis-freelancer { background:rgba(139,92,246,0.1); color:#7c3aed; }
.comp-chip { display:inline-block; background:rgba(139,92,246,0.08); color:#7c3aed; padding:4px 12px; border-radius:20px; font-size:12px; font-weight:700; margin:3px; }
.btn-edit { display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:rgba(245,158,11,0.1); color:#d97706; border:1px solid rgba(245,158,11,0.3); border-radius:var(--radius-md); font-size:13px; font-weight:700; text-decoration:none; transition:all var(--transition); }
.btn-edit:hover { background:rgba(245,158,11,0.2); }
.btn-danger { display:inline-flex; align-items:center; gap:6px; padding:9px 20px; background:rgba(239,68,68,0.1); color:#dc2626; border:1px solid rgba(239,68,68,0.3); border-radius:var(--radius-md); font-size:13px; font-weight:700; cursor:pointer; font-family:inherit; transition:all var(--transition); }
.btn-danger:hover { background:rgba(239,68,68,0.2); }
.desc-box { background:var(--bg-surface); border:1px solid var(--border-color); border-radius:var(--radius-md); padding:14px 16px; font-size:13.5px; line-height:1.6; color:var(--text-primary); white-space:pre-wrap; }
.affectations-list { display:flex; flex-direction:column; gap:8px; }
.affectation-row { display:flex; align-items:center; justify-content:space-between; padding:10px 14px; background:var(--bg-surface); border-radius:var(--radius-sm); border:1px solid var(--border-color); font-size:13px; }
{% endblock %}
{% block content %}
<div style="margin-bottom:20px;">
    <a href="{{ path('admin_projets_index') }}" style="color:var(--text-secondary); text-decoration:none; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux projets
    </a>
</div>

<div class="detail-card">
    <div class="detail-header">
        <div>
            <div class="detail-title">{{ projet.titre }}</div>
            <div class="detail-meta">
                {% if projet.statut %}
                    <span class="badge badge-{{ projet.statut|lower|replace({' ':'_'}) }}">{{ projet.statut|replace({'_':' '})|upper }}</span>
                {% endif %}
                {% if projet.priorite == 'HAUTE' %}<span class="prio-haute">▲ Haute</span>
                {% elseif projet.priorite == 'MOYENNE' %}<span class="prio-moyenne">● Moyenne</span>
                {% elseif projet.priorite == 'BASSE' %}<span class="prio-basse">▼ Basse</span>{% endif %}
                {% if projet.visibleEmploye %}<span class="vis-badge vis-employe">👔 Employés</span>{% endif %}
                {% if projet.visibleFreelancer %}<span class="vis-badge vis-freelancer">💼 Freelancers</span>{% endif %}
            </div>
        </div>
        <div class="detail-actions">
            <a href="{{ path('admin_projets_edit', {'id': projet.idProjet}) }}" class="btn-edit">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                Modifier
            </a>
            <form method="post" action="{{ path('admin_projets_delete', {'id': projet.idProjet}) }}" onsubmit="return confirm('Supprimer ce projet ?')">
                <input type="hidden" name="_token" value="{{ csrf_token('delete_projet_'~projet.idProjet) }}">
                <button type="submit" class="btn-danger">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                    Supprimer
                </button>
            </form>
        </div>
    </div>

    <div class="section-label">Informations générales</div>
    <div class="detail-grid" style="margin-bottom:20px;">
        <div class="detail-field">
            <label>Statut</label>
            <div class="val">{{ projet.statut ? projet.statut|replace({'_':' '})|title : '—' }}</div>
        </div>
        <div class="detail-field">
            <label>Priorité</label>
            <div class="val">{{ projet.priorite ? projet.priorite|title : '—' }}</div>
        </div>
    </div>

    {% if projet.description %}
    <div style="margin-bottom:24px;">
        <div class="section-label">Description</div>
        <div class="desc-box">{{ projet.description }}</div>
    </div>
    {% endif %}

    <div class="section-label">Dates</div>
    <div class="detail-grid-3" style="margin-bottom:24px;">
        <div class="detail-field">
            <label>Date de début</label>
            <div class="val {{ not projet.dateDebut ? 'empty' : '' }}">{{ projet.dateDebut ? projet.dateDebut|date('d/m/Y') : 'Non définie' }}</div>
        </div>
        <div class="detail-field">
            <label>Date de fin</label>
            <div class="val {{ not projet.dateFin ? 'empty' : '' }}">{{ projet.dateFin ? projet.dateFin|date('d/m/Y') : 'Non définie' }}</div>
        </div>
        <div class="detail-field">
            <label>Date de livraison</label>
            <div class="val {{ not projet.dateLivraison ? 'empty' : '' }}">{{ projet.dateLivraison ? projet.dateLivraison|date('d/m/Y') : 'Non définie' }}</div>
        </div>
    </div>

    <div class="section-label">Budget</div>
    <div class="detail-grid-3" style="margin-bottom:24px;">
        <div class="detail-field">
            <label>Budget total</label>
            <div class="val">{{ projet.budgetTotal ? projet.budgetTotal|number_format(2,'.',',')|raw ~ ' TND' : '—' }}</div>
        </div>
        <div class="detail-field">
            <label>Budget interne</label>
            <div class="val">{{ projet.budgetInterne ? projet.budgetInterne|number_format(2,'.',',')|raw ~ ' TND' : '—' }}</div>
        </div>
        <div class="detail-field">
            <label>Budget freelance</label>
            <div class="val">{{ projet.budgetFreelance ? projet.budgetFreelance|number_format(2,'.',',')|raw ~ ' TND' : '—' }}</div>
        </div>
    </div>

    <div class="section-label">Compétences requises</div>
    <div style="margin-bottom:24px;">
        {% if projet.competences|length > 0 %}
            {% for c in projet.competences %}
                <span class="comp-chip">{{ c.nomCompetence }}</span>
            {% endfor %}
        {% else %}
            <span style="color:var(--text-secondary); font-size:13px; font-style:italic;">Aucune compétence requise</span>
        {% endif %}
    </div>

    {% if affectations is defined and affectations|length > 0 %}
    <div class="section-label">Affectations employés ({{ affectations|length }})</div>
    <div class="affectations-list" style="margin-bottom:24px;">
        {% for aff in affectations %}
        <div class="affectation-row">
            <div>
                <strong>{{ aff.user.prenom }} {{ aff.user.nom }}</strong>
                <span style="color:var(--text-secondary); font-size:12px; margin-left:8px;">{{ aff.user.email }}</span>
            </div>
            <div style="display:flex; gap:10px; align-items:center; font-size:12px; color:var(--text-secondary);">
                <span>Depuis {{ aff.dateDebut ? aff.dateDebut|date('d/m/Y') : '—' }}</span>
                <span class="badge badge-{{ aff.statut|lower|replace({' ':'_'}) }}">{{ aff.statut }}</span>
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}

    {% if demandes is defined and demandes|length > 0 %}
    <div class="section-label">Demandes freelancers ({{ demandes|length }})</div>
    <div class="affectations-list">
        {% for d in demandes %}
        <div class="affectation-row">
            <div>
                <strong>{{ d.nomFreelancer }}</strong>
                <span style="color:var(--text-secondary); font-size:12px; margin-left:8px;">{{ d.emailFreelancer }}</span>
            </div>
            <div style="display:flex; gap:10px; align-items:center; font-size:12px; color:var(--text-secondary);">
                <span>{{ d.dateDemande ? d.dateDemande|date('d/m/Y') : '—' }}</span>
                {% if d.statut == 'ACCEPTE' %}<span class="badge badge-termine">Accepté</span>
                {% elseif d.statut == 'REFUSE' %}<span class="badge badge-annule">Refusé</span>
                {% else %}<span class="badge badge-planifie">En attente</span>{% endif %}
            </div>
        </div>
        {% endfor %}
    </div>
    {% endif %}
</div>
{% endblock %}
