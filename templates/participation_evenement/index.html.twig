{% extends 'back/base_employee.html.twig' %}

{% block page_title %}
    <h1>Gestion des Participations</h1>
{% endblock %}

{% block employee_content %}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div class="section-header" style="display: flex; align-items: center; gap: 8px; color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                <circle cx="9" cy="7" r="4"/>
            </svg>
            <h3 style="font-size: 13px; font-weight: 700; margin: 0; text-transform: uppercase;">LISTE DES PARTICIPATIONS</h3>
        </div>
        <a href="{{ path('app_participation_evenement_new') }}" class="btn-primary-custom" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--accent-blue); color: #fff; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nouvelle Participation
        </a>
    </div>

    <div class="data-card" style="background: var(--card-bg); border-radius: var(--radius-lg); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); overflow: hidden;">
        <div class="table-responsive" style="overflow-x: auto;">
            <table class="data-table" style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead style="background: #f8fafc; border-bottom: 1px solid var(--border-color);">
            <tr>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">ID</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Présence</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Date Inscription</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Jeton</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for participation_evenement in participation_evenements %}
            <tr style="border-bottom: 1px solid var(--border-color); font-size: 13px; font-weight: 500;">
                <td style="padding: 16px 20px; font-weight: 700; color: var(--text-secondary);">#{{ participation_evenement.idParticipation }}</td>
                <td style="padding: 16px 20px;">
                    {% if participation_evenement.presence %}
                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.1); color: var(--accent-green);">Présent</span>
                    {% else %}
                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(100,116,139,0.1); color: var(--text-secondary);">Absent</span>
                    {% endif %}
                </td>
                <td style="padding: 16px 20px; opacity: 0.8;">{{ participation_evenement.dateInscription ? participation_evenement.dateInscription|date('d/m/Y H:i') : '-' }}</td>
                <td style="padding: 16px 20px; font-weight: 600; color: var(--accent-blue);">{{ participation_evenement.jeton }}</td>
                <td style="padding: 16px 20px;">
                    <div style="display: flex; gap: 8px;">
                        <a href="{{ path('app_participation_evenement_show', {'id_participation': participation_evenement.id_participation}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #ebd0f5; color: #8b5cf6;" title="Voir">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                        <a href="{{ path('app_participation_evenement_edit', {'id_participation': participation_evenement.id_participation}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #e0f2fe; color: #0284c7;" title="Modifier">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        </a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5" style="text-align: center; padding: 40px; color: var(--text-secondary); font-size: 14px;">Aucune participation trouvée</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
        </div>
    </div>
{% endblock %}
