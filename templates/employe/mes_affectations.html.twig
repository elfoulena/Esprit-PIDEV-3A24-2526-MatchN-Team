{# templates/employe/mes_affectations.html.twig #}
{% extends 'back/base_employe.html.twig' %}
{% block title %}Mes affectations{% endblock %}
{% block page_title %}Mes affectations{% endblock %}

{% block extra_styles %}
.data-card { background:var(--card-bg); border:1px solid var(--border-color); border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); overflow:hidden; }
.data-table { width:100%; border-collapse:collapse; }
.data-table thead th { padding:12px 16px; text-align:left; font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.8px; background:#f8fafc; border-bottom:1px solid var(--border-color); }
.data-table tbody td { padding:13px 16px; font-size:13.5px; border-bottom:1px solid var(--border-color); color:var(--text-primary); vertical-align:middle; }
.data-table tbody tr:last-child td { border-bottom:none; }
.data-table tbody tr:hover { background:#f8fafc; }
.badge { display:inline-flex; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; white-space:nowrap; }
.badge-en_cours   { background:rgba(59,130,246,0.12); color:#1d4ed8; }
.badge-termine    { background:rgba(16,185,129,0.12); color:#059669; }
.badge-planifie   { background:rgba(139,92,246,0.12); color:#7c3aed; }
.badge-en_pause   { background:rgba(245,158,11,0.12); color:#d97706; }
.badge-annule     { background:rgba(239,68,68,0.10); color:#dc2626; }
.comp-chip { display:inline-block; background:rgba(139,92,246,0.08); color:#7c3aed; padding:2px 9px; border-radius:20px; font-size:10px; font-weight:700; margin:2px; }
.empty-state { text-align:center; padding:48px; color:var(--text-secondary); }
.project-cell { display:flex; align-items:center; gap:8px; min-width:0; }
.repo-link-table { display:inline-flex; align-items:center; justify-content:center; width:24px; height:24px; border-radius:7px; background:rgba(59,130,246,0.12); color:#1d4ed8; border:1px solid rgba(59,130,246,0.25); text-decoration:none; flex-shrink:0; }
.repo-link-table svg { width:12px; height:12px; }
{% endblock %}

{% block content %}
<div style="display:flex; align-items:center; justify-content:space-between; margin-bottom:20px;">
    <a href="{{ path('employe_projets_index') }}" style="color:var(--text-secondary); text-decoration:none; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Voir les projets disponibles
    </a>
    <div style="font-size:13px; color:var(--text-secondary);">
        {{ affectations|length }} affectation{{ affectations|length != 1 ? 's' : '' }} au total
    </div>
</div>

<div class="data-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>Projet</th>
                <th>Statut projet</th>
                <th>Compétences</th>
                <th>Date début</th>
                <th>Date fin</th>
                <th>Statut affectation</th>
            </tr>
        </thead>
        <tbody>
        {% for aff in affectations %}
            <tr>
                <td style="font-weight:700; max-width:260px;">
                    <div class="project-cell">
                        <span style="white-space:nowrap; overflow:hidden; text-overflow:ellipsis;">{{ aff.projet.titre }}</span>
                        {% if aff.projet.repository and aff.projet.repository.urlRepo %}
                            <a href="{{ aff.projet.repository.urlRepo }}" target="_blank" rel="noopener noreferrer" class="repo-link-table" title="Voir le repo GitHub">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                                    <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                                    <polyline points="15 3 21 3 21 9"/>
                                    <line x1="10" y1="14" x2="21" y2="3"/>
                                </svg>
                            </a>
                        {% endif %}
                    </div>
                </td>
                <td>
                    {% if aff.projet.statut %}
                        <span class="badge badge-{{ aff.projet.statut|lower|replace({' ':'_'}) }}">{{ aff.projet.statut|replace({'_':' '})|upper }}</span>
                    {% else %}<span style="color:var(--text-secondary);">—</span>{% endif %}
                </td>
                <td style="font-size:12px;">
                    {% if aff.projet.competences|length > 0 %}
                        {% for c in aff.projet.competences|slice(0,3) %}
                            <span class="comp-chip">{{ c.nomCompetence }}</span>
                        {% endfor %}
                        {% if aff.projet.competences|length > 3 %}
                            <span style="font-size:11px; color:var(--text-secondary);">+{{ aff.projet.competences|length - 3 }}</span>
                        {% endif %}
                    {% else %}<span style="color:var(--text-secondary);">—</span>{% endif %}
                </td>
                <td style="font-size:12px; color:var(--text-secondary);">{{ aff.dateDebut ? aff.dateDebut|date('d/m/Y') : '—' }}</td>
                <td style="font-size:12px; color:var(--text-secondary);">{{ aff.dateFin ? aff.dateFin|date('d/m/Y') : '—' }}</td>
                <td>
                    <span class="badge badge-{{ aff.statut|lower|replace({' ':'_'}) }}">{{ aff.statut|replace({'_':' '})|upper }}</span>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="6" class="empty-state">Vous n'avez encore aucune affectation.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>
{% endblock %}
