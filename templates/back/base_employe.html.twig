{# templates/back/base_employe.html.twig #}
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}MatchNTeam Employé{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg-main:        #f0f2f5;
            --bg-surface:     #e8eaf0;
            --card-bg:        #ffffff;
            --border-color:   rgba(0,0,0,0.08);
            --text-primary:   #1e293b;
            --text-secondary: #64748b;
            --accent-blue:    #0ea5e9;
            --accent-teal:    #14b8a6;
            --accent-green:   #10b981;
            --accent-orange:  #f59e0b;
            --accent-red:     #ef4444;
            --accent-purple:  #8b5cf6;
            --sidebar-w:      260px;
            --radius-sm:      8px;
            --radius-md:      12px;
            --radius-lg:      16px;
            --shadow-sm:      0 1px 4px rgba(0,0,0,0.07);
            --shadow-md:      0 4px 20px rgba(0,0,0,0.09);
            --transition:     0.18s ease;
        }

        body {
            font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
            background: var(--bg-main);
            color: var(--text-primary);
            display: flex;
            min-height: 100vh;
        }

        /* ══════════════════ SIDEBAR ══════════════════ */
        .sidebar {
            width: var(--sidebar-w);
            background: var(--card-bg);
            border-right: 1px solid var(--border-color);
            position: fixed;
            top: 0; left: 0; bottom: 0;
            z-index: 100;
            display: flex;
            flex-direction: column;
            box-shadow: var(--shadow-sm);
        }

        .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 11px;
            text-decoration: none;
        }
        .brand-logo {
            width: 36px; height: 36px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            border-radius: var(--radius-sm);
            display: flex; align-items: center; justify-content: center;
            font-size: 13px; font-weight: 800; color: #fff;
            flex-shrink: 0;
        }
        .brand-name {
            font-size: 16px; font-weight: 800;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            -webkit-background-clip: text; background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-section-label {
            padding: 20px 20px 6px;
            font-size: 10px; font-weight: 700;
            letter-spacing: 1.4px;
            color: #94a3b8;
            text-transform: uppercase;
        }

        .sidebar-nav {
            flex: 1;
            padding: 8px 12px 16px;
            display: flex;
            flex-direction: column;
            gap: 2px;
            overflow-y: auto;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 11px;
            padding: 10px 14px;
            border-radius: var(--radius-md);
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text-secondary);
            text-decoration: none;
            transition: all var(--transition);
            position: relative;
        }
        .nav-item svg { width: 18px; height: 18px; flex-shrink: 0; stroke-width: 1.8; }
        .nav-item:hover {
            background: rgba(14,165,233,0.07);
            color: var(--accent-blue);
        }
        .nav-item.active {
            background: linear-gradient(135deg, rgba(14,165,233,0.13), rgba(20,184,166,0.07));
            color: var(--accent-blue);
            font-weight: 700;
        }
        .nav-item.active::before {
            content: '';
            position: absolute;
            left: 0; top: 6px; bottom: 6px;
            width: 3px;
            background: linear-gradient(var(--accent-blue), var(--accent-teal));
            border-radius: 0 3px 3px 0;
        }

        .nav-divider {
            height: 1px;
            background: var(--border-color);
            margin: 10px 12px;
        }

        .sidebar-footer {
            padding: 16px 20px;
            border-top: 1px solid var(--border-color);
        }
        .user-pill {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 12px;
        }
        .user-avatar {
            width: 34px; height: 34px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-teal));
            border-radius: 50%;
            display: flex; align-items: center; justify-content: center;
            font-size: 12px; font-weight: 800; color: #fff;
            flex-shrink: 0;
        }
        .user-info { flex: 1; min-width: 0; }
        .user-name { font-size: 13px; font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .user-role { font-size: 11px; color: var(--text-secondary); }

        .logout-btn {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--accent-red);
            text-decoration: none;
            font-size: 13px;
            font-weight: 600;
            padding: 8px 10px;
            border-radius: var(--radius-sm);
            transition: background var(--transition);
        }
        .logout-btn:hover { background: rgba(239,68,68,0.08); }
        .logout-btn svg { width: 16px; height: 16px; }

        /* ══════════════════ MAIN ══════════════════ */
        .main-content {
            flex: 1;
            margin-left: var(--sidebar-w);
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .topbar {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 0 32px;
            height: 60px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky; top: 0; z-index: 50;
            box-shadow: var(--shadow-sm);
        }
        .topbar-title { font-size: 15px; font-weight: 700; color: var(--text-primary); }
        .topbar-right { display: flex; align-items: center; gap: 12px; }
        .topbar-badge {
            font-size: 11px; font-weight: 700;
            padding: 4px 12px;
            border-radius: 20px;
            background: linear-gradient(135deg, rgba(14,165,233,0.12), rgba(20,184,166,0.08));
            color: var(--accent-blue);
        }

        .page-body { padding: 28px 32px; flex: 1; }

        .flash-wrap { padding: 0 32px; margin-top: 16px; }
        .flash-success {
            background: rgba(16,185,129,0.09);
            border: 1px solid rgba(16,185,129,0.25);
            color: #065f46;
            border-radius: var(--radius-sm);
            padding: 11px 16px;
            font-size: 13px; font-weight: 600;
        }
        .flash-error {
            background: rgba(239,68,68,0.08);
            border: 1px solid rgba(239,68,68,0.2);
            color: #991b1b;
            border-radius: var(--radius-sm);
            padding: 11px 16px;
            font-size: 13px; font-weight: 600;
        }

        {% block extra_styles %}{% endblock %}
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{# ══════════════ SIDEBAR ══════════════ #}
<aside class="sidebar">
    <a class="sidebar-brand" href="{{ path('employe_dashboard') }}">
        <div class="brand-logo">MT</div>
        <span class="brand-name">MatchNTeam</span>
    </a>

    <nav class="sidebar-nav">
        <div class="sidebar-section-label">Principal</div>

        <a href="{{ path('employe_dashboard') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'employe_dashboard' %}active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
            Tableau de bord
        </a>

        <div class="sidebar-section-label" style="margin-top: 6px;">Équipes</div>

        <a href="{{ path('app_equipe_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'app_equipe' or app.request.attributes.get('_route') starts with 'app_membre' %}active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Gestion Équipes
        </a>

        <div class="sidebar-section-label" style="margin-top: 6px;">Projets</div>

        <a href="{{ path('employe_projets_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'employe_projets_index' %}active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            Projets disponibles
        </a>

        <a href="{{ path('employe_mes_affectations') }}"
           class="nav-item {% if app.request.attributes.get('_route') == 'employe_mes_affectations' %}active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M9 11l3 3L22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
            Mes affectations
        </a>

        <div class="sidebar-section-label" style="margin-top: 6px;">Communication</div>

        <a href="{{ path('app_front_evenement_index') }}"
           class="nav-item {% if app.request.attributes.get('_route') starts with 'app_front_evenement' %}active{% endif %}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            Événements
        </a>

        <div class="nav-divider"></div>

        <a href="#" class="nav-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor"><circle cx="12" cy="12" r="3"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14"/></svg>
            Paramètres
        </a>
    </nav>

    <div class="sidebar-footer">
        <div class="user-pill">
            <div class="user-avatar">
                {{ app.user ? (app.user.nom|slice(0,1) ~ app.user.prenom|slice(0,1))|upper : 'EM' }}
            </div>
            <div class="user-info">
                <div class="user-name">{{ app.user ? app.user.nom ~ ' ' ~ app.user.prenom : 'Employé' }}</div>
                <div class="user-role">{{ app.user and app.user.poste ? app.user.poste : 'Employé' }}</div>
            </div>
        </div>
        <a href="{{ path('app_logout') }}" class="logout-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            Déconnexion
        </a>
    </div>
</aside>

{# ══════════════ MAIN ══════════════ #}
<div class="main-content">
    <header class="topbar">
        <span class="topbar-title">{% block page_title %}MatchNTeam{% endblock %}</span>
        <div class="topbar-right">
            <span class="topbar-badge">Espace Employé</span>
        </div>
    </header>

    {% for msg in app.flashes('success') %}
        <div class="flash-wrap"><div class="flash-success">✓ {{ msg }}</div></div>
    {% endfor %}
    {% for msg in app.flashes('error') %}
        <div class="flash-wrap"><div class="flash-error">{{ msg }}</div></div>
    {% endfor %}

    <div class="page-body">
        {% block content %}{% endblock %}
    </div>
</div>

{% block javascripts %}{% endblock %}
</body>
</html>
