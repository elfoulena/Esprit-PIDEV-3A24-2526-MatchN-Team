{% extends 'back/base_employe.html.twig' %}

{% block title %}Mon Équipe — MatchNTeam{% endblock %}
{% block page_title %}Mon Équipe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block extra_styles %}
.detail-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    margin-bottom: 24px;
}
.detail-banner {
    padding: 28px 32px;
    border-bottom: 1px solid var(--border-color);
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
}
.detail-stats {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border-color);
}
.detail-stat-cell {
    padding: 18px 24px;
    border-right: 1px solid var(--border-color);
}
.detail-stat-cell:last-child { border-right: none; }
.stat-cell-label {
    font-size: 10px;
    font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 6px;
}
.stat-cell-value {
    font-size: 15px;
    font-weight: 700;
    color: var(--text-primary);
}
.badge-status {
    padding: 6px 14px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    display: inline-block;
}
.badge-status.active { background: rgba(16,185,129,0.12); color: #059669; }
.badge-status.paused { background: rgba(245,158,11,0.12); color: #b45309; }
.badge-status.inactive { background: rgba(239,68,68,0.10); color: #dc2626; }
.member-card {
    background: #f8fafc;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-md);
    padding: 16px;
    transition: all var(--transition);
}
.member-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}
.team-info-section {
    margin-top: 24px;
}
.section-title {
    font-size: 14px;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Calendar specific styles */
.calendar-section {
    margin-top: 32px;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 24px;
}

.calendar-section-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
}

.calendar-section-title i {
    color: #3498db;
    font-size: 20px;
}

#calendar {
    min-height: 500px;
}

.event-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 15px;
    margin-bottom: 24px;
}

.event-stat-card {
    background: #f8fafc;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s;
    cursor: pointer;
}

.event-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.event-stat-card .stat-icon {
    font-size: 24px;
    margin-bottom: 8px;
}

.event-stat-card .stat-label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 4px;
}

.event-stat-card .stat-number {
    font-size: 24px;
    font-weight: 700;
    color: #1e293b;
}

.event-stat-card.total .stat-icon { color: #3498db; }
.event-stat-card.upcoming .stat-icon { color: #f39c12; }
.event-stat-card.ongoing .stat-icon { color: #2ecc71; }
.event-stat-card.completed .stat-icon { color: #95a5a6; }

.filter-bar {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.filter-bar .filter-group {
    flex: 1;
    min-width: 150px;
}

.filter-bar select, .filter-bar button {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: white;
    font-size: 14px;
}

.filter-bar button {
    background: #64748b;
    color: white;
    border: none;
    cursor: pointer;
}

.filter-bar button:hover {
    background: #475569;
}

.fc-event {
    cursor: pointer;
}

.fc-event:hover {
    filter: brightness(1.05);
}

@media (max-width: 768px) {
    .event-stats {
        grid-template-columns: repeat(2, 1fr);
    }
    .filter-bar {
        flex-direction: column;
    }
}
{% endblock %}

{% block content %}

<div class="detail-card">
    <div class="detail-banner">
        <div style="display: flex; align-items: center; gap: 18px;">
            <div style="width: 58px; height: 58px; border-radius: 14px; background: {{ equipe.couleurEquipe }}22; display: flex; align-items: center; justify-content: center; border: 2px solid {{ equipe.couleurEquipe }}55;">
                <span style="font-size: 24px; font-weight: 900; color: {{ equipe.couleurEquipe }};">{{ equipe.nomEquipe|slice(0,1)|upper }}</span>
            </div>
            <div>
                <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">
                    {{ equipe.departement ?? 'Département non défini' }}
                </div>
                <h2 style="font-size: 22px; font-weight: 800; color: var(--text-primary); margin: 0 0 5px;">{{ equipe.nomEquipe }}</h2>
                {% if equipe.description %}
                    <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">{{ equipe.description }}</p>
                {% endif %}
            </div>
        </div>
        <div>
            {% if equipe.statut == 'Active' %}
                <span class="badge-status active">● Active</span>
            {% elseif equipe.statut == 'En pause' %}
                <span class="badge-status paused">● En pause</span>
            {% else %}
                <span class="badge-status inactive">● Inactive</span>
            {% endif %}
        </div>
    </div>

    <div class="detail-stats">
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Mon Rôle</div>
            <div class="stat-cell-value" style="color: var(--accent-blue);">{{ membre.roleEquipe }}</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Date d'affectation</div>
            <div class="stat-cell-value">{{ membre.dateAffectation|date('d/m/Y') }}</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Taux participation</div>
            <div class="stat-cell-value">{{ membre.tauxParticipation }}%</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Statut</div>
            <div class="stat-cell-value">
                <span class="badge-status active">● {{ membre.statutMembre }}</span>
            </div>
        </div>
    </div>
</div>

<div class="team-info-section">
    <div class="section-title">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
            <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        Membres de l'équipe ({{ equipe.membres|length }})
    </div>
    
    <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px;">
        {% for member in equipe.membres %}
            <div class="member-card">
                <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 12px;">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: {{ equipe.couleurEquipe }}33; display: flex; align-items: center; justify-content: center;">
                        <span style="font-size: 16px; font-weight: 800; color: {{ equipe.couleurEquipe }};">
                            {{ member.user.prenom|slice(0,1) }}{{ member.user.nom|slice(0,1) }}
                        </span>
                    </div>
                    <div>
                        <div style="font-weight: 700; color: var(--text-primary);">
                            {{ member.user.prenom }} {{ member.user.nom }}
                        </div>
                        <div style="font-size: 12px; color: var(--text-secondary);">
                            {{ member.roleEquipe }}
                        </div>
                    </div>
                </div>
                {% if member.idMembre == membre.idMembre %}
                    <div style="font-size: 11px; color: var(--accent-blue); font-weight: 600; margin-top: 8px;">
                        ← Vous
                    </div>
                {% endif %}
            </div>
        {% endfor %}
    </div>
</div>

{# Calendar Section #}
<div class="calendar-section">
    <div class="calendar-section-title">
        <i class="fas fa-calendar-alt"></i>
        <span>Calendrier des événements de l'équipe</span>
    </div>

    <div class="event-stats">
        <div class="event-stat-card total" data-filter="all">
            <div class="stat-icon">
                <i class="fas fa-calendar-week"></i>
            </div>
            <div class="stat-label">Total</div>
            <div class="stat-number" id="totalEvents">0</div>
        </div>
        <div class="event-stat-card upcoming" data-filter="upcoming">
            <div class="stat-icon">
                <i class="fas fa-clock"></i>
            </div>
            <div class="stat-label">À venir</div>
            <div class="stat-number" id="upcomingEvents">0</div>
        </div>
        <div class="event-stat-card ongoing" data-filter="ongoing">
            <div class="stat-icon">
                <i class="fas fa-play-circle"></i>
            </div>
            <div class="stat-label">En cours</div>
            <div class="stat-number" id="ongoingEvents">0</div>
        </div>
        <div class="event-stat-card completed" data-filter="completed">
            <div class="stat-icon">
                <i class="fas fa-check-circle"></i>
            </div>
            <div class="stat-label">Terminés</div>
            <div class="stat-number" id="completedEvents">0</div>
        </div>
    </div>

    <div class="filter-bar">
        <div class="filter-group">
            <select id="eventTypeFilter">
                <option value="">Tous les types</option>
                <option value="CONFERENCE">Conférences</option>
                <option value="WORKSHOP">Workshops</option>
                <option value="COMPETITION">Compétitions</option>
                <option value="FORMATION">Formations</option>
                <option value="MEETUP">Meetups</option>
                <option value="TEAM_BUILDING">Team Building</option>
                <option value="EVENT_INTERNE">Événements internes</option>
                <option value="PORTE_OUVERTE">Portes ouvertes</option>
            </select>
        </div>
        <div class="filter-group">
            <select id="eventStatusFilter">
                <option value="">Tous les statuts</option>
                <option value="prevu">Prévus</option>
                <option value="en_cours">En cours</option>
                <option value="termine">Terminés</option>
            </select>
        </div>
        <div class="filter-group">
            <button id="resetFilters">
                <i class="fas fa-undo-alt"></i> Réinitialiser
            </button>
        </div>
    </div>

    <div id="calendar"></div>
</div>

<div style="margin-top: 24px; text-align: center;">
    <a href="{{ path('employe_dashboard') }}" class="btn-cancel" style="display: inline-flex; align-items: center; gap: 6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="15 18 9 12 15 6"/>
        </svg>
        Retour au tableau de bord
    </a>
</div>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.js'></script>
    <script src='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/locales/fr.js'></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            let calendar = null;
            let allEvents = [];
            
            function getEventColor(type) {
                const colors = {
                    'CONFERENCE': '#3498db',
                    'WORKSHOP': '#2ecc71',
                    'COMPETITION': '#e74c3c',
                    'FORMATION': '#9b59b6',
                    'MEETUP': '#f39c12',
                    'TEAM_BUILDING': '#1abc9c',
                    'EVENT_INTERNE': '#34495e',
                    'PORTE_OUVERTE': '#e67e22'
                };
                return colors[type] || '#95a5a6';
            }
            
            function getStatusClass(status) {
                const classes = {
                    'prevu': 'bg-info',
                    'en_cours': 'bg-warning',
                    'termine': 'bg-success'
                };
                return classes[status] || 'bg-secondary';
            }
            
            function getStatusText(status) {
                const texts = {
                    'prevu': 'Prévu',
                    'en_cours': 'En cours',
                    'termine': 'Terminé'
                };
                return texts[status] || status;
            }
            
            function escapeHtml(text) {
                if (!text) return '';
                const div = document.createElement('div');
                div.textContent = text;
                return div.innerHTML;
            }
            
            async function loadStats() {
                try {
                    const response = await fetch('/api/events/stats');
                    const stats = await response.json();
                    
                    document.getElementById('totalEvents').textContent = stats.total || 0;
                    document.getElementById('upcomingEvents').textContent = stats.upcoming || 0;
                    document.getElementById('ongoingEvents').textContent = stats.ongoing || 0;
                    document.getElementById('completedEvents').textContent = stats.completed || 0;
                } catch (error) {
                    console.error('Error loading stats:', error);
                }
            }
            
            async function loadEvents() {
                try {
                    const typeFilter = document.getElementById('eventTypeFilter').value;
                    const statusFilter = document.getElementById('eventStatusFilter').value;
                    
                    let url = '/api/events';
                    const params = new URLSearchParams();
                    
                    if (typeFilter) params.append('type', typeFilter);
                    if (statusFilter) params.append('status', statusFilter);
                    
                    if (params.toString()) {
                        url += '?' + params.toString();
                    }
                    
                    const response = await fetch(url);
                    const events = await response.json();
                    allEvents = events;
                    
                    if (calendar) {
                        calendar.removeAllEvents();
                        calendar.addEventSource(events);
                    }
                    
                    return events;
                } catch (error) {
                    console.error('Error loading events:', error);
                    return [];
                }
            }
            
            async function showEventDetails(eventId) {
                try {
                    const response = await fetch(`/api/events/${eventId}`);
                    const event = await response.json();
                    
                    const statusClass = getStatusClass(event.statut);
                    const statusText = getStatusText(event.statut);
                    const eventColor = getEventColor(event.type);
                    
                    const modalHtml = `
                        <div class="modal fade event-detail-modal" id="eventDetailModal" tabindex="-1">
                            <div class="modal-dialog modal-lg modal-dialog-centered">
                                <div class="modal-content">
                                    <div class="modal-header" style="background: ${eventColor}; color: white; padding: 20px 24px;">
                                        <h5 class="modal-title">
                                            <i class="fas fa-calendar-alt me-2"></i>
                                            ${escapeHtml(event.title)}
                                        </h5>
                                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body" style="padding: 24px;">
                                        <div class="row">
                                            <div class="col-md-6">
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-tag"></i> Type</label>
                                                    <p class="mb-0 fw-semibold">${escapeHtml(event.type)}</p>
                                                </div>
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-map-marker-alt"></i> Lieu</label>
                                                    <p class="mb-0 fw-semibold">${escapeHtml(event.lieu)}</p>
                                                </div>
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-clock"></i> Date début</label>
                                                    <p class="mb-0 fw-semibold">${new Date(event.start).toLocaleString('fr-FR')}</p>
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-flag-checkered"></i> Statut</label>
                                                    <p><span class="badge ${statusClass}" style="padding: 6px 12px; border-radius: 20px;">${statusText}</span></p>
                                                </div>
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-users"></i> Capacité</label>
                                                    <p class="mb-0 fw-semibold">${event.capacite_max} places (${event.nombre_actuel || 0} inscrits)</p>
                                                </div>
                                                <div class="info-group mb-3">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-hourglass-end"></i> Date fin</label>
                                                    <p class="mb-0 fw-semibold">${new Date(event.end).toLocaleString('fr-FR')}</p>
                                                </div>
                                            </div>
                                        </div>
                                        ${event.description ? `
                                        <div class="row mt-2">
                                            <div class="col-12">
                                                <div class="info-group">
                                                    <label class="text-muted small text-uppercase fw-bold"><i class="fas fa-align-left"></i> Description</label>
                                                    <p class="mb-0">${escapeHtml(event.description)}</p>
                                                </div>
                                            </div>
                                        </div>
                                        ` : ''}
                                    </div>
                                    <div class="modal-footer" style="border-top: 1px solid #e2e8f0; padding: 16px 24px;">
                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                            <i class="fas fa-times"></i> Fermer
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    `;
                    
                    const existingModal = document.getElementById('eventDetailModal');
                    if (existingModal) {
                        existingModal.remove();
                    }
                    
                    document.body.insertAdjacentHTML('beforeend', modalHtml);
                    
                    const modal = new bootstrap.Modal(document.getElementById('eventDetailModal'));
                    modal.show();
                    
                    document.getElementById('eventDetailModal').addEventListener('hidden.bs.modal', function() {
                        this.remove();
                    });
                    
                } catch (error) {
                    console.error('Error fetching event details:', error);
                }
            }
            
            function initCalendar() {
                const calendarEl = document.getElementById('calendar');
                
                calendar = new FullCalendar.Calendar(calendarEl, {
                    locale: 'fr',
                    initialView: 'dayGridMonth',
                    headerToolbar: {
                        left: 'prev,next today',
                        center: 'title',
                        right: 'dayGridMonth,timeGridWeek,timeGridDay'
                    },
                    buttonText: {
                        today: 'Aujourd\'hui',
                        month: 'Mois',
                        week: 'Semaine',
                        day: 'Jour'
                    },
                    events: allEvents,
                    editable: false,
                    selectable: true,
                    dayMaxEvents: true,
                    eventTimeFormat: {
                        hour: '2-digit',
                        minute: '2-digit',
                        hour12: false
                    },
                    eventClick: function(info) {
                        showEventDetails(info.event.id);
                    },
                    loading: function(isLoading) {
                        let loader = document.getElementById('calendar-loader');
                        if (isLoading) {
                            if (!loader) {
                                loader = document.createElement('div');
                                loader.id = 'calendar-loader';
                                loader.style.cssText = `
                                    position: absolute;
                                    top: 0;
                                    left: 0;
                                    right: 0;
                                    bottom: 0;
                                    background: rgba(255,255,255,0.8);
                                    display: flex;
                                    align-items: center;
                                    justify-content: center;
                                    z-index: 1000;
                                    border-radius: 12px;
                                `;
                                loader.innerHTML = '<div class="spinner-border text-primary" style="width: 3rem; height: 3rem;" role="status"><span class="visually-hidden">Chargement...</span></div>';
                                calendarEl.parentNode.style.position = 'relative';
                                calendarEl.parentNode.appendChild(loader);
                            }
                            loader.style.display = 'flex';
                        } else if (loader) {
                            loader.style.display = 'none';
                        }
                    }
                });
                
                calendar.render();
            }
            
            async function init() {
                await loadStats();
                await loadEvents();
                initCalendar();
                
                document.getElementById('eventTypeFilter').addEventListener('change', async () => {
                    await loadEvents();
                });
                
                document.getElementById('eventStatusFilter').addEventListener('change', async () => {
                    await loadEvents();
                });
                
                document.getElementById('resetFilters').addEventListener('click', () => {
                    document.getElementById('eventTypeFilter').value = '';
                    document.getElementById('eventStatusFilter').value = '';
                    loadEvents();
                });
                
                document.querySelectorAll('.event-stat-card').forEach(card => {
                    card.addEventListener('click', () => {
                        const filter = card.getAttribute('data-filter');
                        if (filter === 'all') {
                            document.getElementById('eventStatusFilter').value = '';
                        } else if (filter === 'upcoming') {
                            document.getElementById('eventStatusFilter').value = 'prevu';
                        } else if (filter === 'ongoing') {
                            document.getElementById('eventStatusFilter').value = 'en_cours';
                        } else if (filter === 'completed') {
                            document.getElementById('eventStatusFilter').value = 'termine';
                        }
                        loadEvents();
                    });
                });
            }
            
            init();
        });
    </script>
{% endblock %}