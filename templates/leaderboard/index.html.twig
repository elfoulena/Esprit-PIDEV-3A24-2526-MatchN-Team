{# templates/leaderboard/index.html.twig #}
{% extends layout == 'freelancer' ? 'back/base_freelancer.html.twig' : 'back/base_admin.html.twig' %}

{% block title %}Leaderboard Freelancers — MatchNTeam{% endblock %}
{% block page_title %}Leaderboard Freelancers{% endblock %}

{% block extra_styles %}
.lb-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 28px; }
.lb-header h2 { font-size: 20px; font-weight: 800; color: var(--text-primary); }
.lb-header p { font-size: 13px; color: var(--text-secondary); margin-top: 2px; }

/* ── Podium ── */
.podium { display: flex; justify-content: center; align-items: flex-end; gap: 20px; margin-bottom: 36px; }
.podium-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-sm);
    text-align: center; padding: 28px 24px 22px; position: relative;
    transition: transform var(--transition), box-shadow var(--transition);
    width: 220px;
}
.podium-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
.podium-card.gold   { border-top: 3px solid #f59e0b; order: 2; }
.podium-card.silver { border-top: 3px solid #94a3b8; order: 1; }
.podium-card.bronze { border-top: 3px solid #d97706; order: 3; }

.podium-rank {
    position: absolute; top: -14px; left: 50%; transform: translateX(-50%);
    width: 28px; height: 28px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 900; color: #fff;
}
.podium-card.gold   .podium-rank { background: linear-gradient(135deg, #f59e0b, #d97706); }
.podium-card.silver .podium-rank { background: linear-gradient(135deg, #94a3b8, #64748b); }
.podium-card.bronze .podium-rank { background: linear-gradient(135deg, #d97706, #92400e); }

.podium-avatar {
    width: 64px; height: 64px; border-radius: 50%; margin: 0 auto 12px;
    border: 3px solid var(--border-color); object-fit: cover;
}
.podium-card.gold   .podium-avatar { border-color: #f59e0b; }
.podium-card.silver .podium-avatar { border-color: #94a3b8; }
.podium-card.bronze .podium-avatar { border-color: #d97706; }

.podium-name { font-size: 15px; font-weight: 800; color: var(--text-primary); margin-bottom: 4px; }
.podium-score { font-size: 22px; font-weight: 900; margin: 8px 0 4px; }
.podium-card.gold   .podium-score { color: #d97706; }
.podium-card.silver .podium-score { color: #64748b; }
.podium-card.bronze .podium-score { color: #92400e; }
.podium-meta { font-size: 11px; color: var(--text-secondary); display: flex; justify-content: center; gap: 14px; }

/* ── Table ── */
.data-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 12px 18px; text-align: left; font-size: 10.5px; font-weight: 700;
    color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc; border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 18px; font-size: 13px; border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }
.data-table tbody tr.highlight { background: rgba(139,92,246,0.06); }

.rank-num {
    width: 30px; height: 30px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 800;
    background: var(--bg-surface); color: var(--text-secondary);
}
.rank-num.r1 { background: linear-gradient(135deg, rgba(245,158,11,0.15), rgba(217,119,6,0.1)); color: #d97706; }
.rank-num.r2 { background: linear-gradient(135deg, rgba(148,163,184,0.15), rgba(100,116,139,0.1)); color: #64748b; }
.rank-num.r3 { background: linear-gradient(135deg, rgba(217,119,6,0.12), rgba(146,64,14,0.08)); color: #92400e; }

.user-cell { display: flex; align-items: center; gap: 12px; }
.user-avatar-img { width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0; }

.note-bar { height: 6px; border-radius: 3px; background: #e2e8f0; width: 80px; display: inline-block; vertical-align: middle; margin-left: 8px; }
.note-bar-fill { height: 6px; border-radius: 3px; display: block; }

.score-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 12px; border-radius: 20px; font-size: 13px; font-weight: 800;
    background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(139,92,246,0.08));
    color: #3b82f6;
}

.empty-state { padding: 60px; text-align: center; color: var(--text-secondary); }
.empty-state p { font-size: 14px; }

@media (max-width: 800px) {
    .podium { flex-direction: column; align-items: center; }
    .podium-card { order: unset !important; }
}
{% endblock %}

{% block content %}

{# ── Header ── #}
<div class="lb-header">
    <div>
        <h2>Leaderboard</h2>
        <p>Classement des freelancers par score (évaluations + projets terminés)</p>
    </div>
</div>

{% if leaderboard|length > 0 %}

{# ── Podium (Top 3) ── #}
{% if leaderboard|length >= 1 %}
<div class="podium">
    {% if leaderboard|length >= 2 %}
        {% set fl = leaderboard[1] %}
        <div class="podium-card silver">
            <div class="podium-rank">2</div>
            <img src="{{ gravatar(fl.email, 128) }}" alt="" class="podium-avatar">
            <div class="podium-name">{{ fl.prenom }} {{ fl.nom }}</div>
            <div class="podium-score">{{ fl.score|round(1) }}</div>
            <div class="podium-meta">
                <span>Note {{ fl.avgNote|round(1) }}/10</span>
                <span>{{ fl.finishedProjects }} projet(s)</span>
            </div>
        </div>
    {% endif %}

    {% set fl = leaderboard[0] %}
    <div class="podium-card gold">
        <div class="podium-rank">1</div>
        <img src="{{ gravatar(fl.email, 128) }}" alt="" class="podium-avatar">
        <div class="podium-name">{{ fl.prenom }} {{ fl.nom }}</div>
        <div class="podium-score">{{ fl.score|round(1) }}</div>
        <div class="podium-meta">
            <span>Note {{ fl.avgNote|round(1) }}/10</span>
            <span>{{ fl.finishedProjects }} projet(s)</span>
        </div>
    </div>

    {% if leaderboard|length >= 3 %}
        {% set fl = leaderboard[2] %}
        <div class="podium-card bronze">
            <div class="podium-rank">3</div>
            <img src="{{ gravatar(fl.email, 128) }}" alt="" class="podium-avatar">
            <div class="podium-name">{{ fl.prenom }} {{ fl.nom }}</div>
            <div class="podium-score">{{ fl.score|round(1) }}</div>
            <div class="podium-meta">
                <span>Note {{ fl.avgNote|round(1) }}/10</span>
                <span>{{ fl.finishedProjects }} projet(s)</span>
            </div>
        </div>
    {% endif %}
</div>
{% endif %}

{# ── Full Ranking Table ── #}
<div class="data-card">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width: 60px;">Rang</th>
                    <th>Freelancer</th>
                    <th>Note moyenne</th>
                    <th>Projets terminés</th>
                    <th style="text-align: right; padding-right: 22px;">Score</th>
                </tr>
            </thead>
            <tbody>
            {% for fl in leaderboard %}
                <tr{% if currentUserId is defined and currentUserId == fl.id %} class="highlight"{% endif %}>
                    <td>
                        {% if loop.index == 1 %}
                            <span class="rank-num r1">1</span>
                        {% elseif loop.index == 2 %}
                            <span class="rank-num r2">2</span>
                        {% elseif loop.index == 3 %}
                            <span class="rank-num r3">3</span>
                        {% else %}
                            <span class="rank-num">{{ loop.index }}</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="user-cell">
                            <img src="{{ gravatar(fl.email, 72) }}" alt="" class="user-avatar-img">
                            <div>
                                <div style="font-weight: 700; color: var(--text-primary);">{{ fl.prenom }} {{ fl.nom }}</div>
                                <div style="font-size: 11px; color: var(--text-secondary);">{{ fl.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td>
                        {% set noteColor = fl.avgNote >= 7 ? '#059669' : (fl.avgNote >= 5 ? '#b45309' : '#dc2626') %}
                        <span style="font-weight: 700; color: {{ noteColor }};">{{ fl.avgNote|round(1) }}</span>/10
                        <div class="note-bar">
                            <span class="note-bar-fill" style="width: {{ (fl.avgNote / 10 * 100)|round }}%; background: {{ noteColor }};"></span>
                        </div>
                    </td>
                    <td>
                        <span style="font-weight: 700; color: var(--text-primary);">{{ fl.finishedProjects }}</span>
                        <span style="color: var(--text-secondary);"> projet(s)</span>
                    </td>
                    <td style="text-align: right; padding-right: 22px;">
                        <span class="score-badge">{{ fl.score|round(1) }} pts</span>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% else %}
    <div class="data-card">
        <div class="empty-state">
            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" style="opacity: 0.3; margin-bottom: 14px;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <p>Aucun freelancer avec des affectations pour le moment.</p>
        </div>
    </div>
{% endif %}

{% endblock %}
