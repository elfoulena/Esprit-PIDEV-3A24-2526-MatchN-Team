    // Mettre en évidence l'élément de navigation actif en fonction de l'URL
    function highlightCurrentNav() {
        const currentPath = window.location.pathname;
        const navItems = document.querySelectorAll('.nav-item');
        navItems.forEach(item => {
            const href = item.getAttribute('href');
            if (href && href !== '#' && currentPath === href) {
                item.classList.add('active');
            } else if (currentPath.includes('/admin/equipe') && item.getAttribute('href') === '/admin/equipe/') {
                item.classList.add('active');
            } else if (currentPath === '/' || currentPath === '/admin/dashboard') {
                // Pour la page d'accueil ou dashboard
                if (item.getAttribute('data-view') === 'dashboard') {
                    item.classList.add('active');
                }
            }
        });
    }
    
    highlightCurrentNav();
    
