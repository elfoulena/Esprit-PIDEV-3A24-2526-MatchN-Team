{# templates/admin/projets/index.html.twig #}
{% extends 'back/base_admin.html.twig' %}
{% block title %}Gestion des projets{% endblock %}
{% block page_title %}Gestion des projets{% endblock %}

{% block extra_styles %}
.toolbar { display:flex; align-items:center; justify-content:space-between; gap:12px; margin-bottom:20px; flex-wrap:wrap; }
.search-box { position:relative; flex:1; min-width:220px; max-width:340px; }
.search-box svg { position:absolute; left:12px; top:50%; transform:translateY(-50%); width:16px; height:16px; color:var(--text-secondary); pointer-events:none; }
.search-input { width:100%; padding:9px 12px 9px 38px; border:1px solid var(--border-color); border-radius:var(--radius-md); font-size:13.5px; font-family:inherit; background:var(--card-bg); color:var(--text-primary); outline:none; transition:border-color var(--transition), box-shadow var(--transition); }
.search-input:focus { border-color:var(--accent-blue); box-shadow:0 0 0 3px rgba(59,130,246,0.1); }
.filters { display:flex; gap:8px; align-items:center; }
.filter-select { padding:8px 12px; border:1px solid var(--border-color); border-radius:var(--radius-sm); font-size:13px; font-family:inherit; background:var(--card-bg); color:var(--text-primary); outline:none; cursor:pointer; }
.btn-primary { display:inline-flex; align-items:center; gap:7px; padding:9px 20px; background:linear-gradient(135deg,var(--accent-blue),var(--accent-purple)); color:#fff; border-radius:var(--radius-md); font-size:13px; font-weight:700; text-decoration:none; transition:opacity var(--transition); white-space:nowrap; }
.btn-primary:hover { opacity:0.88; }
.btn-primary svg { width:15px; height:15px; }
.btn-stats { display:inline-flex; align-items:center; gap:7px; padding:9px 16px; background:rgba(14,165,233,0.1); border:1px solid rgba(14,165,233,0.28); color:#0369a1; border-radius:var(--radius-md); font-size:13px; font-weight:700; cursor:pointer; font-family:inherit; }
.btn-stats:hover { filter:brightness(0.95); }
.data-card { background:var(--card-bg); border:1px solid var(--border-color); border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); overflow:hidden; }
.data-table { width:100%; border-collapse:collapse; }
.data-table thead th { padding:12px 16px; text-align:left; font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.8px; background:#f8fafc; border-bottom:1px solid var(--border-color); }
.data-table tbody td { padding:13px 16px; font-size:13.5px; border-bottom:1px solid var(--border-color); color:var(--text-primary); vertical-align:middle; }
.data-table tbody tr:last-child td { border-bottom:none; }
.data-table tbody tr:hover { background:#f8fafc; }
.badge { display:inline-flex; padding:3px 10px; border-radius:20px; font-size:11px; font-weight:700; white-space:nowrap; }
.badge-en_cours   { background:rgba(59,130,246,0.12); color:#1d4ed8; }
.badge-termine    { background:rgba(16,185,129,0.12); color:#059669; }
.badge-en_pause   { background:rgba(245,158,11,0.12); color:#d97706; }
.badge-planifie   { background:rgba(139,92,246,0.12); color:#7c3aed; }
.badge-annule     { background:rgba(239,68,68,0.10); color:#dc2626; }
.badge-default    { background:var(--bg-surface); color:var(--text-secondary); }
.prio-haute   { color:#dc2626; font-weight:700; }
.prio-moyenne { color:#d97706; font-weight:700; }
.prio-basse   { color:#059669; font-weight:700; }
.vis-badge { display:inline-flex; align-items:center; gap:4px; padding:2px 8px; border-radius:20px; font-size:10px; font-weight:700; }
.vis-employe    { background:rgba(14,165,233,0.1); color:#0369a1; }
.vis-freelancer { background:rgba(139,92,246,0.1); color:#7c3aed; }
.actions { display:flex; gap:5px; }
.action-btn { display:inline-flex; align-items:center; justify-content:center; width:30px; height:30px; border-radius:var(--radius-sm); border:none; cursor:pointer; text-decoration:none; transition:all var(--transition); }
.action-btn.view   { background:rgba(59,130,246,0.10); color:var(--accent-blue); }
.action-btn.edit   { background:rgba(245,158,11,0.10); color:#d97706; }
.action-btn.repo-setup { background:rgba(34,197,94,0.10); color:#15803d; }
.action-btn.repo-visit { background:rgba(6,182,212,0.12); color:#0e7490; }
.action-btn.delete { background:rgba(239,68,68,0.10); color:#dc2626; }
.action-btn.disabled { background:rgba(148,163,184,0.15); color:#94a3b8; cursor:not-allowed; }
.action-btn:hover  { filter:brightness(0.88); }
.action-btn svg    { width:14px; height:14px; }
.empty-state { text-align:center; padding:48px; color:var(--text-secondary); }
.stats-legend { display:grid; grid-template-columns:repeat(2,minmax(0,1fr)); gap:8px; margin-top:16px; }
.stats-item { display:flex; align-items:center; justify-content:space-between; gap:8px; font-size:12px; background:#fff; border:1px solid var(--border-color); border-radius:10px; padding:8px 10px; }
.dot { width:10px; height:10px; border-radius:50%; display:inline-block; }
{% endblock %}

{% block content %}
<div class="toolbar">
    <div style="display:flex; gap:10px; flex:1; flex-wrap:wrap; align-items:center;">
        <div class="search-box">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input type="text" id="searchInput" class="search-input" placeholder="Rechercher un projet…" value="{{ q }}" autocomplete="off">
        </div>
        <select id="statutFilter" class="filter-select">
            <option value="">Tous les statuts</option>
            {% for s in ['EN_COURS','PLANIFIE','TERMINE','EN_PAUSE','ANNULE'] %}
                <option value="{{ s }}" {{ statut == s ? 'selected' : '' }}>{{ s|replace({'_':' '})|title }}</option>
            {% endfor %}
        </select>
        <select id="visiblFilter" class="filter-select">
            <option value="">Toute visibilité</option>
            <option value="employe"    {{ visib == 'employe'    ? 'selected' : '' }}>Employés</option>
            <option value="freelancer" {{ visib == 'freelancer' ? 'selected' : '' }}>Freelancers</option>
        </select>
    </div>
    <div style="display:flex; gap:10px;">
        <button type="button" class="btn-stats" id="openStatsBtn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 21H3"/><path d="M7 14v4"/><path d="M12 10v8"/><path d="M17 6v12"/></svg>
            Statistiques
        </button>
        <a href="{{ path('admin_projets_demandes') }}" style="display:inline-flex; align-items:center; gap:7px; padding:9px 16px; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-secondary); border-radius:var(--radius-md); font-size:13px; font-weight:600; text-decoration:none;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            Demandes
        </a>
        <a href="{{ path('admin_competences_index') }}" style="display:inline-flex; align-items:center; gap:7px; padding:9px 16px; background:var(--bg-surface); border:1px solid var(--border-color); color:var(--text-secondary); border-radius:var(--radius-md); font-size:13px; font-weight:600; text-decoration:none;">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/></svg>
            Compétences
        </a>
        <a href="{{ path('admin_projets_new') }}" class="btn-primary">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Nouveau projet
        </a>
    </div>
</div>

<div class="data-card" id="tableWrap">
    {% include 'admin/projets/_table.html.twig' %}
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>

<div class="modal fade" id="projectStatsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered" style="max-width:500px;">
        <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden;box-shadow:0 30px 60px rgba(0,0,0,.15);">
            <div style="background:linear-gradient(135deg,#1e293b,#334155);padding:18px 22px;display:flex;align-items:center;justify-content:space-between;">
                <div style="color:#fff;font-weight:700;">Statistiques des projets</div>
                <button type="button" data-bs-dismiss="modal" style="background:rgba(255,255,255,.1);border:none;color:#fff;width:30px;height:30px;border-radius:50%;font-size:18px;cursor:pointer;">×</button>
            </div>
            <div style="padding:20px;background:#f8fafc;">
                <div style="position:relative;width:280px;max-width:100%;margin:0 auto;">
                    <canvas id="projectPieChart"></canvas>
                    <div style="position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);text-align:center;pointer-events:none;">
                        <div id="statsTotal" style="font-size:28px;font-weight:800;color:var(--text-primary);line-height:1;">0</div>
                        <div style="font-size:11px;color:var(--text-secondary);">projets</div>
                    </div>
                </div>
                <div class="stats-legend">
                    <div class="stats-item"><span><span class="dot" style="background:#2563eb;"></span> En cours</span><strong id="sEnCours">0</strong></div>
                    <div class="stats-item"><span><span class="dot" style="background:#7c3aed;"></span> Planifié</span><strong id="sPlanifie">0</strong></div>
                    <div class="stats-item"><span><span class="dot" style="background:#10b981;"></span> Terminé</span><strong id="sTermine">0</strong></div>
                    <div class="stats-item"><span><span class="dot" style="background:#f59e0b;"></span> En pause</span><strong id="sPause">0</strong></div>
                    <div class="stats-item"><span><span class="dot" style="background:#ef4444;"></span> Annulé</span><strong id="sAnnule">0</strong></div>
                    <div class="stats-item"><span><span class="dot" style="background:#94a3b8;"></span> Autre</span><strong id="sAutre">0</strong></div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
(function() {
    const inp = document.getElementById('searchInput');
    const stat = document.getElementById('statutFilter');
    const visb = document.getElementById('visiblFilter');
    const wrap = document.getElementById('tableWrap');
    const openStatsBtn = document.getElementById('openStatsBtn');
    const statsModalEl = document.getElementById('projectStatsModal');
    const statsModal = new bootstrap.Modal(statsModalEl);

    let currentStats = {{ stats|json_encode|raw }};
    let chart = null;

    function renderStatsLegend() {
        document.getElementById('statsTotal').textContent = currentStats.total || 0;
        document.getElementById('sEnCours').textContent = currentStats.EN_COURS || 0;
        document.getElementById('sPlanifie').textContent = currentStats.PLANIFIE || 0;
        document.getElementById('sTermine').textContent = currentStats.TERMINE || 0;
        document.getElementById('sPause').textContent = currentStats.EN_PAUSE || 0;
        document.getElementById('sAnnule').textContent = currentStats.ANNULE || 0;
        document.getElementById('sAutre').textContent = currentStats.AUTRE || 0;
    }

    function openStats() {
        statsModal.show();
    }

    statsModalEl.addEventListener('shown.bs.modal', function () {
        renderStatsLegend();

        if (chart) {
            chart.destroy();
            chart = null;
        }

        const ctx = document.getElementById('projectPieChart').getContext('2d');
        const labels = ['En cours', 'Planifié', 'Terminé', 'En pause', 'Annulé', 'Autre'];
        const values = [
            currentStats.EN_COURS || 0,
            currentStats.PLANIFIE || 0,
            currentStats.TERMINE || 0,
            currentStats.EN_PAUSE || 0,
            currentStats.ANNULE || 0,
            currentStats.AUTRE || 0
        ];

        chart = new Chart(ctx, {
            type: 'doughnut',
            data: {
                labels: labels,
                datasets: [{
                    data: values,
                    backgroundColor: ['#2563eb', '#7c3aed', '#10b981', '#f59e0b', '#ef4444', '#94a3b8'],
                    borderColor: '#ffffff',
                    borderWidth: 3
                }]
            },
            options: {
                cutout: '60%',
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        callbacks: {
                            label: function(context) {
                                const total = currentStats.total || 0;
                                const value = context.raw || 0;
                                const pct = total > 0 ? Math.round((value / total) * 100) : 0;
                                return ' ' + context.label + ': ' + value + ' (' + pct + '%)';
                            }
                        }
                    }
                }
            }
        });
    });

    openStatsBtn.addEventListener('click', openStats);

    function fetchTable() {
        const params = new URLSearchParams({ q: inp.value, statut: stat.value, visib: visb.value });
        fetch('{{ path('admin_projets_index') }}?' + params, {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(r => r.json())
        .then(data => {
            wrap.innerHTML = data.html;
            if (data.stats) {
                currentStats = data.stats;
            }
        });
    }

    let timer;
    inp.addEventListener('input', () => { clearTimeout(timer); timer = setTimeout(fetchTable, 280); });
    stat.addEventListener('change', fetchTable);
    visb.addEventListener('change', fetchTable);
})();
</script>
{% endblock %}
