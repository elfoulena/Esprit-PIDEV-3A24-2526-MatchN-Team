{# templates/security/login.html.twig #}
{% extends 'base.html.twig' %}

{% block body_class %}no-nav{% endblock %}

{% block title %}Connexion — MatchNTeam{% endblock %}

{% block stylesheets %}
<style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    /* ── Design tokens (thème clair) ── */
    :root {
        --bg-main:        #f0f2f5;
        --bg-surface:     #e8eaf0;
        --card-bg:        #ffffff;
        --border-color:   rgba(0,0,0,0.08);
        --text-primary:   #1e293b;
        --text-secondary: #64748b;
        --accent-blue:    #3b82f6;
        --accent-purple:  #8b5cf6;
        --accent-green:   #10b981;
        --accent-orange:  #f59e0b;
        --radius-sm:      8px;
        --radius-md:      12px;
        --radius-lg:      16px;
        --shadow-sm:      0 1px 4px rgba(0,0,0,0.08);
        --shadow-md:      0 4px 20px rgba(0,0,0,0.10);
        --transition:     0.18s ease;
    }

    body {
        background: var(--bg-main);
        font-family: 'Segoe UI', system-ui, sans-serif;
        color: var(--text-primary);
    }

    /* ── Layout deux colonnes ── */
    .login-page {
        min-height: 100vh;
        display: grid;
        grid-template-columns: 1fr 1fr;
    }

    /* ══════════════════════════════
       PANNEAU GAUCHE — branding
    ══════════════════════════════ */
    .login-left {
        background: var(--bg-surface);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 3rem;
        position: relative;
        overflow: hidden;
    }

    /* Orbe décoratif (style welcome-banner du dashboard) */
    .login-left::before {
        content: '';
        position: absolute;
        top: -120px; left: -120px;
        width: 420px; height: 420px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(59,130,246,0.09) 0%, transparent 70%);
        pointer-events: none;
    }
    .login-left::after {
        content: '';
        position: absolute;
        bottom: -80px; right: -80px;
        width: 300px; height: 300px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(139,92,246,0.1) 0%, transparent 70%);
        pointer-events: none;
    }

    /* Brand */
    .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        position: relative;
        z-index: 1;
    }
    .brand-logo {
        width: 38px; height: 38px;
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        font-size: 15px; font-weight: 800; color: #fff;
        letter-spacing: -0.5px;
    }
    .brand-name {
        font-size: 16px;
        font-weight: 600;
        color: var(--text-primary);
        letter-spacing: 0.2px;
    }

    /* Titre principal */
    .left-content { position: relative; z-index: 1; }

    .left-title {
        font-size: 34px;
        font-weight: 800;
        color: var(--text-primary);
        line-height: 1.25;
        margin-bottom: 14px;
    }
    .left-title .gradient-word {
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }
    .left-sub {
        font-size: 14px;
        color: var(--text-secondary);
        line-height: 1.7;
        margin-bottom: 2.5rem;
    }

    /* Feature cards (style stat-card du dashboard) */
    .feature-list { display: flex; flex-direction: column; gap: 10px; }

    .feature-item {
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-md);
        padding: 14px 16px;
        display: flex;
        align-items: center;
        gap: 12px;
        position: relative;
        overflow: hidden;
        transition: transform var(--transition), box-shadow var(--transition);
    }
    .feature-item:hover {
        transform: translateX(4px);
        box-shadow: var(--shadow-sm);
    }
    .feature-item::before {
        content: '';
        position: absolute;
        left: 0; top: 0; bottom: 0;
        width: 3px;
    }
    .feature-item:nth-child(1)::before { background: var(--accent-blue); }
    .feature-item:nth-child(2)::before { background: var(--accent-purple); }
    .feature-item:nth-child(3)::before { background: var(--accent-green); }
    .feature-item:nth-child(4)::before { background: var(--accent-orange); }

    .feature-icon {
        width: 34px; height: 34px;
        border-radius: var(--radius-sm);
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .feature-item:nth-child(1) .feature-icon { background: rgba(59,130,246,0.12); color: var(--accent-blue); }
    .feature-item:nth-child(2) .feature-icon { background: rgba(139,92,246,0.12); color: var(--accent-purple); }
    .feature-item:nth-child(3) .feature-icon { background: rgba(16,185,129,0.12); color: var(--accent-green); }
    .feature-item:nth-child(4) .feature-icon { background: rgba(245,158,11,0.12); color: var(--accent-orange); }

    .feature-text {
        font-size: 13px;
        font-weight: 500;
        color: var(--text-secondary);
    }

    /* Footer */
    .left-footer {
        position: relative;
        z-index: 1;
        font-size: 12px;
        color: #94a3b8;
    }

    /* ══════════════════════════════
       PANNEAU DROIT — formulaire
    ══════════════════════════════ */
    .login-right {
        background: var(--bg-main);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 2rem;
        position: relative;
    }
    /* Orbe subtil derrière le form */
    .login-right::before {
        content: '';
        position: absolute;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%);
        width: 500px; height: 500px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(59,130,246,0.06) 0%, transparent 70%);
        pointer-events: none;
    }

    .login-form-wrap {
        width: 100%;
        max-width: 380px;
        position: relative;
        z-index: 1;
    }

    /* En-tête formulaire */
    .form-header { margin-bottom: 2rem; }
    .form-title {
        font-size: 26px;
        font-weight: 800;
        color: var(--text-primary);
        margin-bottom: 6px;
    }
    .form-sub {
        font-size: 13px;
        color: var(--text-secondary);
    }

    /* Section header (identique au dashboard) */
    .section-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 18px;
        color: var(--text-secondary);
    }
    .section-header h3 {
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1.2px;
        color: var(--text-secondary);
        text-transform: uppercase;
    }

    /* Champs */
    .form-group { margin-bottom: 14px; }
    .form-group label {
        display: block;
        font-size: 12px;
        font-weight: 600;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 6px;
    }
    .form-group input {
        width: 100%;
        padding: 11px 14px;
        background: var(--card-bg);
        border: 1px solid var(--border-color);
        border-radius: var(--radius-sm);
        font-size: 14px;
        color: var(--text-primary);
        transition: border-color var(--transition), box-shadow var(--transition);
        font-family: inherit;
    }
    .form-group input::placeholder { color: #94a3b8; }
    .form-group input:focus {
        outline: none;
        border-color: var(--accent-blue);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.12);
    }

    /* Options */
    .form-options {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
        font-size: 13px;
    }
    .remember-label {
        display: flex;
        align-items: center;
        gap: 7px;
        color: var(--text-secondary);
        cursor: pointer;
        font-size: 13px;
    }
    .remember-label input[type="checkbox"] {
        width: 15px; height: 15px;
        accent-color: var(--accent-blue);
        cursor: pointer;
    }
    .forgot-link {
        color: var(--accent-blue);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: color var(--transition);
    }
    .forgot-link:hover { color: #60a5fa; }

    /* Bouton connexion (style welcome-banner gradient) */
    .btn-login {
        width: 100%;
        padding: 13px;
        background: linear-gradient(135deg, var(--accent-blue) 0%, var(--accent-purple) 100%);
        color: #fff;
        border: none;
        border-radius: var(--radius-sm);
        font-size: 14px;
        font-weight: 700;
        cursor: pointer;
        transition: opacity var(--transition), transform var(--transition), box-shadow var(--transition);
        font-family: inherit;
        letter-spacing: 0.3px;
        box-shadow: 0 4px 15px rgba(59,130,246,0.25);
    }
    .btn-login:hover {
        opacity: 0.92;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(59,130,246,0.4);
    }
    .btn-login:active { transform: scale(0.99); }

    /* Divider */
    .divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 1.4rem 0;
        font-size: 12px;
        color: var(--text-secondary);
    }
    .divider::before,
    .divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border-color);
    }

    /* Bouton register (style action-btn du dashboard) */
    .btn-register {
        width: 100%;
        padding: 12px;
        background: rgba(139,92,246,0.08);
        color: var(--accent-purple);
        border: 1px solid rgba(139,92,246,0.2);
        border-radius: var(--radius-sm);
        font-size: 13px;
        font-weight: 600;
        cursor: pointer;
        text-align: center;
        text-decoration: none;
        display: block;
        transition: background var(--transition), transform var(--transition);
        font-family: inherit;
    }
    .btn-register:hover {
        background: rgba(139,92,246,0.15);
        transform: translateY(-1px);
    }

    /* Alertes */
    .alert-error {
        background: rgba(239,68,68,0.08);
        border: 1px solid rgba(239,68,68,0.2);
        color: #fca5a5;
        border-radius: var(--radius-sm);
        padding: 11px 14px;
        font-size: 13px;
        margin-bottom: 1.4rem;
        display: flex;
        align-items: flex-start;
        gap: 9px;
    }
    .alert-icon {
        width: 16px; height: 16px;
        border-radius: 50%;
        background: rgba(239,68,68,0.3);
        color: #fca5a5;
        font-size: 10px; font-weight: 700;
        display: inline-flex; align-items: center; justify-content: center;
        flex-shrink: 0; margin-top: 1px;
    }
    .alert-success {
        background: rgba(16,185,129,0.08);
        border: 1px solid rgba(16,185,129,0.2);
        color: #6ee7b7;
        border-radius: var(--radius-sm);
        padding: 11px 14px;
        font-size: 13px;
        margin-bottom: 1.4rem;
    }

    /* Role badges (style team-badge du dashboard) */
    .role-badges {
        display: flex;
        gap: 6px;
        margin-top: 1.5rem;
        flex-wrap: wrap;
    }
    .role-badge {
        font-size: 11px;
        font-weight: 600;
        padding: 4px 12px;
        border-radius: 20px;
        border: 1px solid var(--border-color);
        color: var(--text-secondary);
        background: var(--card-bg);
    }

    /* ── Responsive ── */
    @media (max-width: 900px) {
        .login-page { grid-template-columns: 1fr; }
        .login-left { display: none; }
    }
    @media (max-width: 480px) {
        .login-right { padding: 2rem 1.25rem; }
        .form-title { font-size: 22px; }
    }
</style>
{% endblock %}

{% block body %}
<div class="login-page">

    {# ════ Panneau gauche : branding ════ #}
    <div class="login-left">
        <div class="brand">
            <div class="brand-logo">RH</div>
            <span class="brand-name">MatchNTeam</span>
        </div>

        <div class="left-content">
            <h1 class="left-title">
                Gérez vos équipes<br>
                avec <span class="gradient-word">efficacité</span>
            </h1>
            <p class="left-sub">
                Plateforme complète de gestion des ressources humaines.<br>
                Employés, freelancers et administrateurs réunis.
            </p>

            <div class="feature-list">
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
                            <circle cx="9" cy="7" r="4"/>
                        </svg>
                    </div>
                    <span class="feature-text">Gestion des employés et contrats</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <rect x="2" y="3" width="20" height="14" rx="2"/>
                            <line x1="8" y1="21" x2="16" y2="21"/>
                            <line x1="12" y1="17" x2="12" y2="21"/>
                        </svg>
                    </div>
                    <span class="feature-text">Espace freelancer avec profil de compétences</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <line x1="18" y1="20" x2="18" y2="10"/>
                            <line x1="12" y1="20" x2="12" y2="4"/>
                            <line x1="6" y1="20" x2="6" y2="14"/>
                        </svg>
                    </div>
                    <span class="feature-text">Tableau de bord administrateur complet</span>
                </div>
                <div class="feature-item">
                    <div class="feature-icon">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none"
                             stroke="currentColor" stroke-width="2">
                            <rect x="3" y="11" width="18" height="11" rx="2"/>
                            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                        </svg>
                    </div>
                    <span class="feature-text">Sécurité et vérification par email</span>
                </div>
            </div>
        </div>

        <div class="left-footer">
            &copy; {{ "now"|date("Y") }} MatchNTeam — Esprit PIDEV
        </div>
    </div>

    {# ════ Panneau droit : formulaire ════ #}
    <div class="login-right">
        <div class="login-form-wrap">

            <div class="form-header">
                <h2 class="form-title">bienvenue 👋</h2>
                <p class="form-sub">Connectez-vous à votre espace de travail</p>
            </div>

            {# ── Section header style dashboard ── #}
            <div class="section-header">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="3" y="11" width="18" height="11" rx="2"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                <h3>IDENTIFIANTS</h3>
            </div>

            {# Erreur #}
            {% if error %}
                <div class="alert-error">
                    <span class="alert-icon">!</span>
                    <span>{{ error.messageKey | trans(error.messageData, 'security') }}</span>
                </div>
            {% endif %}

            {# Flash success #}
            {% for msg in app.flashes('success') %}
                <div class="alert-success">{{ msg }}</div>
            {% endfor %}

            <form method="post" action="{{ path('app_login') }}">

                <div class="form-group">
                    <label for="email">Adresse email</label>
                    <input
                        type="email"
                        id="email"
                        name="_username"
                        value="{{ last_username }}"
                        placeholder="votre@email.com"
                        autocomplete="email"
                        required
                        autofocus
                    >
                </div>

                <div class="form-group">
                    <label for="password">Mot de passe</label>
                    <input
                        type="password"
                        id="password"
                        name="_password"
                        placeholder="••••••••"
                        autocomplete="current-password"
                        required
                    >
                </div>

                <div class="form-options">
                    <label class="remember-label">
                        <input type="checkbox" name="_remember_me">
                        Se souvenir de moi
                    </label>
                    <a href="{{ path('app_forgot_password_request') }}" class="forgot-link">Mot de passe oublié ?</a>
                </div>

                <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

                <button type="submit" class="btn-login">
                    Se connecter →
                </button>

            </form>

            <a href="{{ path('connect_google') }}" class="btn-google">
    <img src="https://developers.google.com/identity/images/g-logo.png" width="20">
    Continuer avec Google
</a>

            <div class="divider">ou</div>

            <a href="{{ path('app_register') }}" class="btn-register">
                Créer un compte freelancer
            </a>

            <div class="role-badges">
                <span class="role-badge">Admin RH</span>
                <span class="role-badge">Employé</span>
                <span class="role-badge">Freelancer</span>
            </div>

        </div>
    </div>

</div>
{% endblock %}
