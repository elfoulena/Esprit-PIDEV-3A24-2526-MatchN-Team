{# templates/evaluation/index.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Évaluations Part-Time — MatchNTeam{% endblock %}
{% block page_title %}Évaluations Part-Time{% endblock %}

{% block extra_styles %}
.page-actions { display: flex; align-items: center; justify-content: space-between; margin-bottom: 24px; }
.btn-primary {
    display: inline-flex; align-items: center; gap: 7px;
    padding: 10px 20px; background: var(--accent-blue); color: #fff;
    border-radius: var(--radius-md); text-decoration: none;
    font-size: 13px; font-weight: 700;
    transition: all var(--transition); box-shadow: 0 2px 8px rgba(59,130,246,0.3);
}
.btn-primary:hover { background: #2563eb; transform: translateY(-1px); }

.data-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; }
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 12px 18px; text-align: left; font-size: 10.5px; font-weight: 700;
    color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc; border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 18px; font-size: 13px; border-bottom: 1px solid var(--border-color);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }

.note-circle {
    width: 40px; height: 40px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 800;
}
.note-bar {
    height: 6px; border-radius: 3px; background: #e2e8f0; width: 80px; display: inline-block; vertical-align: middle; margin-left: 8px;
}
.note-bar-fill { height: 6px; border-radius: 3px; display: block; }

.label-badge {
    padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; display: inline-block;
}

.action-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 32px; height: 32px; border-radius: 8px;
    text-decoration: none; border: none; cursor: pointer;
    transition: all var(--transition);
}
.action-btn:hover { filter: brightness(0.9); transform: scale(1.05); }
.action-btn.edit { background: rgba(59,130,246,0.12); color: var(--accent-blue); }
.action-btn.del  { background: rgba(239,68,68,0.10); color: var(--accent-red); }

.empty-state { padding: 60px; text-align: center; color: var(--text-secondary); }
.empty-state svg { opacity: 0.3; margin-bottom: 14px; }
.empty-state p { font-size: 14px; }
{% endblock %}

{% block content %}

{# ── Header ── #}
<div class="page-actions">
    <div>
        <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Évaluations</h2>
        <p style="font-size: 13px; color: var(--text-secondary); margin-top: 2px;">{{ evaluations|length }} évaluation(s)</p>
    </div>
    <a href="{{ path('app_evaluation_new') }}" class="btn-primary">
        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Nouvelle évaluation
    </a>
</div>

{# ── Table ── #}
<div class="data-card">
    <div style="overflow-x: auto;">
        <table class="data-table">
            <thead>
                <tr>
                    <th>Freelancer</th>
                    <th>Projet</th>
                    <th>Note</th>
                    <th>Appréciation</th>
                    <th>Commentaire</th>
                    <th>Date</th>
                    <th style="text-align:right; padding-right: 22px;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for eval in evaluations %}
                {% set a = eval.affectationProjet %}
                {% set noteColor = eval.note >= 7 ? '#059669' : (eval.note >= 5 ? '#b45309' : '#dc2626') %}
                {% set noteBg = eval.note >= 7 ? 'rgba(16,185,129,0.12)' : (eval.note >= 5 ? 'rgba(245,158,11,0.12)' : 'rgba(239,68,68,0.10)') %}
                <tr>
                    <td style="font-weight: 600;">{{ a and a.user ? a.user.nom ~ ' ' ~ a.user.prenom : '—' }}</td>
                    <td style="color: var(--text-secondary);">{{ a and a.projet ? a.projet.titre : '—' }}</td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 10px;">
                            <div class="note-circle" style="background: {{ noteBg }}; color: {{ noteColor }};">{{ eval.note }}</div>
                            <div class="note-bar">
                                <span class="note-bar-fill" style="width: {{ (eval.note / 10 * 100)|round }}%; background: {{ noteColor }};"></span>
                            </div>
                        </div>
                    </td>
                    <td>
                        <span class="label-badge" style="background: {{ noteBg }}; color: {{ noteColor }};">{{ eval.labelNote }}</span>
                    </td>
                    <td style="color: var(--text-secondary); max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">{{ eval.commentaire|default('—') }}</td>
                    <td style="color: var(--text-secondary);">{{ eval.dateEvaluation ? eval.dateEvaluation|date('d/m/Y') : '—' }}</td>
                    <td>
                        <div style="display: flex; gap: 6px; justify-content: flex-end;">
                            <a href="{{ path('app_evaluation_edit', {'id': eval.id}) }}" class="action-btn edit" title="Modifier">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                            <form method="post" action="{{ path('app_evaluation_delete', {'id': eval.id}) }}" onsubmit="return confirm('Supprimer cette évaluation ?');" style="margin:0;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ eval.id) }}">
                                <button type="submit" class="action-btn del" title="Supprimer">
                                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7">
                        <div class="empty-state">
                            <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                            <p>Aucune évaluation trouvée</p>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
