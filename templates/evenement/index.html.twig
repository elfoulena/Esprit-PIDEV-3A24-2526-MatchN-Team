{% extends 'back/base_employee.html.twig' %}

{% block page_title %}
    <h1>Gestion des Événements</h1>
{% endblock %}

{% block employee_content %}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div class="section-header" style="display: flex; align-items: center; gap: 8px; color: var(--text-secondary);">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
            </svg>
            <h3 style="font-size: 13px; font-weight: 700; margin: 0; text-transform: uppercase;">LISTE DES ÉVÉNEMENTS</h3>
        </div>
        <a href="{{ path('app_evenement_new') }}" class="btn-primary-custom" style="display: inline-flex; align-items: center; gap: 8px; padding: 10px 20px; background: var(--accent-blue); color: #fff; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
            </svg>
            Nouvel Événement
        </a>
    </div>

    <div class="data-card" style="background: var(--card-bg); border-radius: var(--radius-lg); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); overflow: hidden;">
        <div class="table-responsive" style="overflow-x: auto;">
            <table class="data-table" style="width: 100%; border-collapse: collapse; text-align: left;">
        <thead style="background: #f8fafc; border-bottom: 1px solid var(--border-color);">
            <tr>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Titre</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Type</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Date Début</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Lieu</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Actuel/Capacité</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Statut</th>
                <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for evenement in evenements %}
            <tr style="border-bottom: 1px solid var(--border-color); font-size: 13px; font-weight: 500;">
                <td style="padding: 16px 20px;">{{ evenement.titre }}</td>
                <td style="padding: 16px 20px; opacity: 0.8;">{{ evenement.typeEvenement }}</td>
                <td style="padding: 16px 20px;">{{ evenement.dateDebut ? evenement.dateDebut|date('d/m/Y H:i') : '-' }}</td>
                <td style="padding: 16px 20px;">{{ evenement.lieu }}</td>
                <td style="padding: 16px 20px; font-weight: 600; color: var(--accent-blue);">{{ evenement.nombreActuel }} / {{ evenement.capaciteMax }}</td>
                <td style="padding: 16px 20px;">
                    {% if evenement.statut == 'en_cours' %}
                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(59,130,246,0.12); color: #3b82f6;">en cours</span>
                    {% elseif evenement.statut == 'termine' %}
                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(239,68,68,0.12); color: #ef4444;">terminé</span>
                    {% else %}
                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.12); color: #10b981;">prévu</span>
                    {% endif %}
                </td>
                <td style="padding: 16px 20px;">
                    <div style="display: flex; gap: 8px;">
                        <a href="{{ path('app_evenement_show', {'id_evenement': evenement.id_evenement}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #ebd0f5; color: #8b5cf6;" title="Voir">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </a>
                        <a href="{{ path('app_evenement_edit', {'id_evenement': evenement.id_evenement}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #e0f2fe; color: #0284c7;" title="Modifier">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path></svg>
                        </a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="8" style="text-align: center; padding: 40px; color: var(--text-secondary); font-size: 14px;">Aucun événement trouvé</td>
            </tr>
        {% endfor %}

        </tbody>
    </table>
        </div>
    </div>
{% endblock %}
