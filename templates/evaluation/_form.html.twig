{# templates/evaluation/_form.html.twig #}
<style>
.form-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    max-width: 700px;
}
.form-card-header {
    padding: 20px 28px;
    border-bottom: 1px solid var(--border-color);
    background: #f8fafc;
    display: flex; align-items: center; gap: 10px;
}
.form-card-header h3 {
    font-size: 12px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 1px; margin: 0;
}
.form-card-body { padding: 28px; }
.form-group { margin-bottom: 20px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
.form-label {
    display: block; font-size: 12px; font-weight: 700;
    color: var(--text-primary); margin-bottom: 7px; letter-spacing: 0.3px;
}
.form-control {
    width: 100%; padding: 10px 14px;
    border: 1px solid var(--border-color);
    border-radius: var(--radius-sm); font-size: 13.5px;
    color: var(--text-primary); background: #fff;
    font-family: inherit; transition: all var(--transition);
    box-sizing: border-box;
}
.form-control:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(59,130,246,0.10); }
textarea.form-control { min-height: 96px; resize: vertical; }
.form-control.is-invalid { border-color: var(--accent-red); box-shadow: 0 0 0 3px rgba(239,68,68,0.10); }
.field-error { color: var(--accent-red); font-size: 11.5px; font-weight: 600; margin-top: 4px; display: block; }
.form-actions {
    display: flex; justify-content: flex-end; gap: 10px;
    margin-top: 28px; padding-top: 20px;
    border-top: 1px solid var(--border-color);
}
.btn-cancel {
    padding: 10px 22px; background: var(--bg-surface); color: var(--text-primary);
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: none;
    display: inline-flex; align-items: center;
}
.btn-save {
    padding: 10px 24px; background: var(--accent-blue); color: #fff;
    border: none; border-radius: var(--radius-sm); font-size: 13px;
    font-weight: 700; cursor: pointer; font-family: inherit;
    transition: background var(--transition);
}
.btn-save:hover { background: #2563eb; }

.note-display {
    display: flex; align-items: center; gap: 14px; margin-top: 8px;
}
.note-value {
    font-size: 28px; font-weight: 900; min-width: 44px; text-align: center;
}
.note-label-text {
    font-size: 14px; font-weight: 700;
}
.note-slider {
    width: 100%; cursor: pointer; accent-color: var(--accent-blue);
}
</style>

<div class="form-card">
    <div class="form-card-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
        <h3>Évaluation du freelancer</h3>
    </div>
    <div class="form-card-body">

        {{ form_start(form, {'attr': {'id': 'evaluation_form', 'novalidate': 'novalidate'}}) }}

            <div class="form-group">
                {{ form_label(form.affectationProjet, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.affectationProjet, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.affectationProjet) }}
            </div>

            <div class="form-group">
                {{ form_label(form.note, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.note, {'attr': {'class': 'note-slider', 'id': 'note_slider'}}) }}
                {{ form_errors(form.note) }}
                <div class="note-display">
                    <span class="note-value" id="note_value">5</span>
                    <span class="note-label-text" id="note_label">Moyen</span>
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.commentaire, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.commentaire, {'attr': {'class': 'form-control', 'placeholder': 'Votre commentaire sur la performance du freelancer...'}}) }}
                {{ form_errors(form.commentaire) }}
            </div>

            <div class="form-group">
                {{ form_label(form.dateEvaluation, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.dateEvaluation, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.dateEvaluation) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_evaluation_index') }}" class="btn-cancel">Annuler</a>
                <button type="submit" class="btn-save">{{ button_label|default('Enregistrer') }}</button>
            </div>

        {{ form_end(form) }}

    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const slider = document.getElementById('note_slider');
    const valueEl = document.getElementById('note_value');
    const labelEl = document.getElementById('note_label');

    if (!slider) return;

    function getLabel(n) {
        if (n >= 9) return 'Excellent';
        if (n >= 7) return 'Bien';
        if (n >= 5) return 'Moyen';
        if (n >= 3) return 'Insuffisant';
        return 'Très insuffisant';
    }

    function getColor(n) {
        if (n >= 7) return '#059669';
        if (n >= 5) return '#b45309';
        return '#dc2626';
    }

    function update() {
        const n = parseInt(slider.value) || 0;
        valueEl.textContent = n;
        valueEl.style.color = getColor(n);
        labelEl.textContent = getLabel(n);
        labelEl.style.color = getColor(n);
    }

    slider.addEventListener('input', update);
    update();
});
</script>
