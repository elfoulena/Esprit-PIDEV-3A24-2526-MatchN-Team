{# templates/affectation/show.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}{{ affectation }} — MatchNTeam{% endblock %}
{% block page_title %}Détail Affectation{% endblock %}

{% block extra_styles %}
.detail-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
    margin-bottom: 24px;
}
.detail-banner {
    padding: 28px 32px; border-bottom: 1px solid var(--border-color);
    display: flex; justify-content: space-between; align-items: flex-start;
}
.detail-stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border-color);
}
.detail-stat-cell {
    padding: 18px 24px; border-right: 1px solid var(--border-color);
}
.detail-stat-cell:last-child { border-right: none; }
.stat-cell-label { font-size: 10px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.stat-cell-value { font-size: 15px; font-weight: 700; color: var(--text-primary); }

.badge-status {
    padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; display: inline-block;
}
.badge-status.en_attente { background: rgba(245,158,11,0.12); color: #b45309; }
.badge-status.acceptee   { background: rgba(16,185,129,0.12); color: #059669; }
.badge-status.refusee    { background: rgba(239,68,68,0.10); color: #dc2626; }
.badge-status.terminee   { background: rgba(139,92,246,0.12); color: #7c3aed; }

.status-btn {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 6px 14px; border: none; border-radius: var(--radius-sm);
    font-size: 12px; font-weight: 700; cursor: pointer; font-family: inherit;
    transition: all var(--transition);
}
.status-btn:hover { filter: brightness(0.9); transform: translateY(-1px); }
.status-btn.accept  { background: rgba(16,185,129,0.12); color: #059669; }
.status-btn.refuse  { background: rgba(239,68,68,0.10); color: #dc2626; }
.status-btn.termine { background: rgba(139,92,246,0.12); color: #7c3aed; }
.status-btn.attente { background: rgba(245,158,11,0.12); color: #b45309; }

.eval-card {
    display: flex; align-items: center; gap: 16px;
    padding: 14px 18px; background: #f8fafc;
    border: 1px solid var(--border-color); border-radius: var(--radius-md);
    margin-bottom: 10px;
}
.note-circle {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 16px; font-weight: 800; flex-shrink: 0;
}
{% endblock %}

{% block content %}

{# Breadcrumb + actions #}
<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 12px;">
    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-secondary);">
        <a href="{{ path('app_affectation_index') }}" style="color: var(--text-secondary); text-decoration: none;">Affectations</a>
        <span>/</span>
        <span style="color: var(--text-primary); font-weight: 600;">{{ affectation }}</span>
    </div>
    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="{{ path('app_affectation_edit', {'id': affectation.id}) }}"
           style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: rgba(59,130,246,0.10); color: var(--accent-blue); border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
            Modifier
        </a>
        <form method="post" action="{{ path('app_affectation_delete', {'id': affectation.id}) }}"
              onsubmit="return confirm('Supprimer cette affectation ?');" style="margin:0;">
            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ affectation.id) }}">
            <button type="submit" style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: rgba(239,68,68,0.10); color: var(--accent-red); border: none; border-radius: var(--radius-sm); font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit;">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/></svg>
                Supprimer
            </button>
        </form>
        <a href="{{ path('app_affectation_index') }}"
           style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: var(--bg-surface); color: var(--text-primary); border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Retour
        </a>
    </div>
</div>

{# Main detail card #}
<div class="detail-card">

    {# Banner #}
    <div class="detail-banner">
        <div style="display: flex; align-items: center; gap: 18px;">
            <div style="width: 58px; height: 58px; border-radius: 14px; background: linear-gradient(135deg, rgba(59,130,246,0.15), rgba(139,92,246,0.10)); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--accent-blue)" stroke-width="1.8"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v2"/></svg>
            </div>
            <div>
                <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;">Affectation Part-Time</div>
                <h2 style="font-size: 22px; font-weight: 800; color: var(--text-primary); margin: 0 0 5px;">{{ affectation.user ? affectation.user.nom ~ ' ' ~ affectation.user.prenom : '—' }}</h2>
                <p style="font-size: 13px; color: var(--text-secondary); margin: 0;">Projet : {{ affectation.projet ? affectation.projet.titre : '—' }}</p>
            </div>
        </div>
        <div>
            {% if affectation.statut == 'EN_ATTENTE' %}
                <span class="badge-status en_attente">● En attente</span>
            {% elseif affectation.statut == 'ACCEPTEE' %}
                <span class="badge-status acceptee">● Acceptée</span>
            {% elseif affectation.statut == 'REFUSEE' %}
                <span class="badge-status refusee">● Refusée</span>
            {% elseif affectation.statut == 'TERMINEE' %}
                <span class="badge-status terminee">● Terminée</span>
            {% endif %}
        </div>
    </div>

    {# Stats row #}
    <div class="detail-stats">
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Date début</div>
            <div class="stat-cell-value">{{ affectation.dateDebut ? affectation.dateDebut|date('d/m/Y') : '—' }}</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Date fin</div>
            <div class="stat-cell-value">{{ affectation.dateFin ? affectation.dateFin|date('d/m/Y') : '—' }}</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Taux horaire</div>
            <div class="stat-cell-value" style="color: var(--accent-green);">{{ affectation.tauxHoraire ? affectation.tauxHoraire ~ ' DT/h' : '—' }}</div>
        </div>
        <div class="detail-stat-cell">
            <div class="stat-cell-label">Coût estimé</div>
            {% set cout = affectation.calculerCoutEstime() %}
            <div class="stat-cell-value" style="color: var(--accent-blue);">{{ cout is not null ? cout|number_format(2, '.', ' ') ~ ' DT' : '—' }}</div>
        </div>
    </div>

    {# Quick status change #}
    <div style="padding: 20px 32px; border-bottom: 1px solid var(--border-color);">
        <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 12px;">Changer le statut</div>
        <div style="display: flex; gap: 8px; flex-wrap: wrap;">
            {% for s in ['EN_ATTENTE', 'ACCEPTEE', 'REFUSEE', 'TERMINEE'] %}
                {% if s != affectation.statut %}
                    <form method="post" action="{{ path('app_affectation_change_statut', {'id': affectation.id, 'statut': s}) }}" style="margin:0;">
                        <input type="hidden" name="_token" value="{{ csrf_token('statut' ~ affectation.id) }}">
                        {% if s == 'ACCEPTEE' %}
                            <button type="submit" class="status-btn accept">Accepter</button>
                        {% elseif s == 'REFUSEE' %}
                            <button type="submit" class="status-btn refuse">Refuser</button>
                        {% elseif s == 'TERMINEE' %}
                            <button type="submit" class="status-btn termine">Terminer</button>
                        {% elseif s == 'EN_ATTENTE' %}
                            <button type="submit" class="status-btn attente">En attente</button>
                        {% endif %}
                    </form>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    {# Evaluations #}
    <div style="padding: 24px 32px;">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px;">
            <div style="font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px;">Évaluations ({{ affectation.evaluationPartTimes|length }})</div>
            {% if affectation.peutEtreEvaluee() and affectation.evaluationPartTimes|length == 0 %}
                <a href="{{ path('app_evaluation_new') }}" style="font-size: 12px; font-weight: 600; color: var(--accent-blue); text-decoration: none;">+ Ajouter une évaluation</a>
            {% endif %}
        </div>

        {% if affectation.evaluationPartTimes|length > 0 %}
            {% for eval in affectation.evaluationPartTimes %}
                <div class="eval-card">
                    {% set noteColor = eval.note >= 7 ? '#059669' : (eval.note >= 5 ? '#b45309' : '#dc2626') %}
                    {% set noteBg = eval.note >= 7 ? 'rgba(16,185,129,0.12)' : (eval.note >= 5 ? 'rgba(245,158,11,0.12)' : 'rgba(239,68,68,0.10)') %}
                    <div class="note-circle" style="background: {{ noteBg }}; color: {{ noteColor }};">
                        {{ eval.note }}/10
                    </div>
                    <div style="flex: 1;">
                        <div style="font-weight: 700; color: var(--text-primary); font-size: 14px;">{{ eval.labelNote }}</div>
                        {% if eval.commentaire %}
                            <div style="font-size: 12.5px; color: var(--text-secondary); margin-top: 4px;">{{ eval.commentaire }}</div>
                        {% endif %}
                    </div>
                    <div style="text-align: right; font-size: 12px; color: var(--text-secondary);">
                        {{ eval.dateEvaluation ? eval.dateEvaluation|date('d/m/Y') : '' }}
                    </div>
                    <a href="{{ path('app_evaluation_edit', {'id': eval.id}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 30px; height: 30px; border-radius: 6px; background: rgba(59,130,246,0.12); color: var(--accent-blue); text-decoration: none;">
                        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                    </a>
                </div>
            {% endfor %}
        {% else %}
            <div style="text-align: center; padding: 30px; color: var(--text-secondary);">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.3" style="opacity: 0.3; margin-bottom: 10px; display: block; margin-left: auto; margin-right: auto;"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                <p style="font-size: 13px;">Aucune évaluation pour cette affectation</p>
                {% if affectation.peutEtreEvaluee() %}
                    <a href="{{ path('app_evaluation_new') }}"
                       style="display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; background: var(--accent-blue); color: #fff; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600; margin-top: 12px;">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
                        Ajouter une évaluation
                    </a>
                {% else %}
                    <p style="font-size: 12px; color: var(--text-secondary); margin-top: 6px;">Le statut doit être Acceptée ou Terminée pour pouvoir évaluer.</p>
                {% endif %}
            </div>
        {% endif %}
    </div>

</div>

{% endblock %}
