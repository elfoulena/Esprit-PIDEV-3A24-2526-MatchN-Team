{% extends 'back/base_employe.html.twig' %}

{% block title %}Chat d'équipe - {{ equipe.nomEquipe }} — MatchNTeam{% endblock %}
{% block page_title %}Chat d'équipe{% endblock %}

{% block extra_styles %}
.chat-container {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 200px);
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    overflow: hidden;
}
.chat-header {
    padding: 16px 24px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    color: white;
    display: flex;
    align-items: center;
    gap: 12px;
}
.chat-header h3 {
    margin: 0;
    font-size: 18px;
    font-weight: 700;
}
.chat-header .team-info {
    font-size: 13px;
    opacity: 0.9;
}
.chat-messages {
    flex: 1;
    overflow-y: auto;
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    background: #f8fafc;
}
.message {
    display: flex;
    animation: fadeIn 0.3s ease;
}
.message-sent {
    justify-content: flex-end;
}
.message-received {
    justify-content: flex-start;
}
.message-bubble {
    max-width: 70%;
    padding: 10px 16px;
    border-radius: 18px;
    position: relative;
}
.message-sent .message-bubble {
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    color: white;
    border-bottom-right-radius: 4px;
}
.message-received .message-bubble {
    background: white;
    border: 1px solid var(--border-color);
    color: var(--text-primary);
    border-bottom-left-radius: 4px;
}
.message-sender {
    font-size: 11px;
    font-weight: 700;
    margin-bottom: 4px;
    display: block;
}
.message-sent .message-sender {
    color: rgba(255,255,255,0.9);
}
.message-received .message-sender {
    color: var(--accent-blue);
}
.message-content {
    font-size: 13px;
    line-height: 1.4;
    word-wrap: break-word;
}
.message-time {
    font-size: 10px;
    margin-top: 4px;
    opacity: 0.7;
    display: block;
    text-align: right;
}
.chat-input-area {
    padding: 16px 20px;
    background: white;
    border-top: 1px solid var(--border-color);
    display: flex;
    gap: 12px;
    align-items: flex-end;
}
.chat-input {
    flex: 1;
    padding: 10px 16px;
    border: 1px solid var(--border-color);
    border-radius: 24px;
    font-size: 13px;
    font-family: inherit;
    resize: none;
    max-height: 100px;
    transition: all var(--transition);
}
.chat-input:focus {
    outline: none;
    border-color: var(--accent-blue);
    box-shadow: 0 0 0 3px rgba(59,130,246,0.1);
}
.btn-send {
    padding: 10px 24px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    color: white;
    border: none;
    border-radius: 24px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    gap: 8px;
}
.btn-send:hover {
    transform: translateY(-1px);
    filter: brightness(1.05);
}
.btn-send:active {
    transform: translateY(0);
}
.message-date-divider {
    text-align: center;
    margin: 16px 0;
    position: relative;
}
.message-date-divider span {
    background: #e2e8f0;
    padding: 4px 12px;
    border-radius: 20px;
    font-size: 11px;
    color: var(--text-secondary);
    font-weight: 600;
}
.typing-indicator {
    padding: 8px 16px;
    font-size: 12px;
    color: var(--text-secondary);
    font-style: italic;
    display: flex;
    align-items: center;
    gap: 8px;
}
.typing-dots {
    display: flex;
    gap: 3px;
}
.typing-dots span {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-blue);
    animation: typing 1.4s infinite;
}
.typing-dots span:nth-child(2) { animation-delay: 0.2s; }
.typing-dots span:nth-child(3) { animation-delay: 0.4s; }
@keyframes typing {
    0%, 60%, 100% { transform: translateY(0); opacity: 0.4; }
    30% { transform: translateY(-6px); opacity: 1; }
}
@keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
}
.empty-chat {
    text-align: center;
    padding: 60px;
    color: var(--text-secondary);
}
.online-status {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #10b981;
    display: inline-block;
    margin-left: 8px;
    animation: pulse 2s infinite;
}
@keyframes pulse {
    0% { transform: scale(1); opacity: 1; }
    50% { transform: scale(1.2); opacity: 0.7; }
    100% { transform: scale(1); opacity: 1; }
}
.scroll-to-bottom {
    position: absolute;
    bottom: 80px;
    right: 30px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--accent-blue);
    color: white;
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-md);
    transition: all var(--transition);
}
.scroll-to-bottom:hover {
    transform: scale(1.1);
}
{% endblock %}

{% block content %}

<div class="chat-container">
    <div class="chat-header">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        <div>
            <h3>{{ equipe.nomEquipe }}</h3>
            <div class="team-info">
                {{ equipe.membres|length }} membre(s) <span class="online-status"></span> Actifs
            </div>
        </div>
    </div>

    <div class="chat-messages" id="chatMessages">
        <div class="empty-chat" id="emptyChat">
            <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
            <p style="margin-top: 16px;">Aucun message pour le moment</p>
            <p style="font-size: 12px;">Soyez le premier à envoyer un message !</p>
        </div>
    </div>

    <div class="chat-input-area">
        <textarea 
            id="messageInput" 
            class="chat-input" 
            placeholder="Écrivez votre message..." 
            rows="1"
            maxlength="500"
        ></textarea>
        <button id="sendButton" class="btn-send">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            Envoyer
        </button>
    </div>
</div>

<script>
    const equipeId = {{ equipe.idEquipe }};
    const currentUserId = {{ currentUser.id }};
    let lastMessageId = 0;
    let pollingInterval = null;
    let isTyping = false;
    let typingTimeout = null;

    const messagesContainer = document.getElementById('chatMessages');
    const messageInput = document.getElementById('messageInput');
    const sendButton = document.getElementById('sendButton');

    function escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
    }

    function formatMessageDate(dateStr) {
        const today = new Date().toDateString();
        const msgDate = new Date(dateStr).toDateString();
        
        if (today === msgDate) {
            return "Aujourd'hui";
        }
        
        const yesterday = new Date();
        yesterday.setDate(yesterday.getDate() - 1);
        if (yesterday.toDateString() === msgDate) {
            return "Hier";
        }
        
        return new Date(dateStr).toLocaleDateString('fr-FR');
    }

    function addMessageToUI(message, isNew = false) {
        const isSent = message.sender_id === currentUserId;
        const messageDiv = document.createElement('div');
        messageDiv.className = `message message-${isSent ? 'sent' : 'received'}`;
        if (isNew) {
            messageDiv.style.animation = 'fadeIn 0.3s ease';
        }
        
        messageDiv.innerHTML = `
            <div class="message-bubble">
                ${!isSent ? `<span class="message-sender">${escapeHtml(message.sender_name)}</span>` : ''}
                <div class="message-content">${escapeHtml(message.content)}</div>
                <span class="message-time">${message.time}</span>
            </div>
        `;
        
        return messageDiv;
    }

    function displayMessages(messages) {
        if (messages.length === 0 && lastMessageId === 0) {
            document.getElementById('emptyChat').style.display = 'block';
            return;
        }
        
        document.getElementById('emptyChat')?.remove();
        
        let currentDate = '';
        let lastMessageDate = '';
        
        messages.forEach(message => {
            const messageDate = formatMessageDate(message.full_date);
            
            if (messageDate !== lastMessageDate) {
                const dateDivider = document.createElement('div');
                dateDivider.className = 'message-date-divider';
                dateDivider.innerHTML = `<span>${messageDate}</span>`;
                messagesContainer.appendChild(dateDivider);
                lastMessageDate = messageDate;
            }
            
            const messageDiv = addMessageToUI(message, false);
            messagesContainer.appendChild(messageDiv);
        });
        
        scrollToBottom();
    }

    async function loadNewMessages() {
        try {
            const response = await fetch(`/team-chat/api/messages/${equipeId}?lastId=${lastMessageId}`);
            const messages = await response.json();
            
            if (messages.length > 0) {
                messages.forEach(message => {
                    const messageDiv = addMessageToUI(message, true);
                    messagesContainer.appendChild(messageDiv);
                    if (message.id > lastMessageId) {
                        lastMessageId = message.id;
                    }
                });
                scrollToBottom();
            }
        } catch (error) {
            console.error('Error loading messages:', error);
        }
    }

    async function sendMessage() {
        const content = messageInput.value.trim();
        if (!content) return;
        
        sendButton.disabled = true;
        sendButton.textContent = 'Envoi...';
        
        try {
            const response = await fetch(`/team-chat/api/messages/${equipeId}`, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ content: content })
            });
            
            const result = await response.json();
            
            if (result.success) {
                messageInput.value = '';
                messageInput.style.height = 'auto';
                
                const newMessage = result.message;
                const messageDiv = addMessageToUI(newMessage, true);
                messagesContainer.appendChild(messageDiv);
                lastMessageId = newMessage.id;
                scrollToBottom();
            } else {
                alert('Erreur: ' + (result.error || 'Impossible d\'envoyer le message'));
            }
        } catch (error) {
            console.error('Error sending message:', error);
            alert('Erreur lors de l\'envoi du message');
        } finally {
            sendButton.disabled = false;
            sendButton.innerHTML = `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="22" y1="2" x2="11" y2="13"/>
                <polygon points="22 2 15 22 11 13 2 9 22 2"/>
            </svg>
            Envoyer`;
        }
    }

    function scrollToBottom() {
        messagesContainer.scrollTop = messagesContainer.scrollHeight;
    }

    function autoResizeTextarea() {
        messageInput.style.height = 'auto';
        messageInput.style.height = Math.min(messageInput.scrollHeight, 100) + 'px';
    }

    // Event listeners
    sendButton.addEventListener('click', sendMessage);
    
    messageInput.addEventListener('keypress', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });
    
    messageInput.addEventListener('input', autoResizeTextarea);
    
    // Load initial messages
    async function init() {
        try {
            const response = await fetch(`/team-chat/api/messages/${equipeId}`);
            const messages = await response.json();
            
            if (messages.length > 0) {
                messages.forEach(msg => {
                    if (msg.id > lastMessageId) lastMessageId = msg.id;
                });
                displayMessages(messages);
            }
            
            // Start polling for new messages every 2 seconds
            pollingInterval = setInterval(loadNewMessages, 2000);
        } catch (error) {
            console.error('Error initializing chat:', error);
        }
    }
    
    init();
    
    // Cleanup on page unload
    window.addEventListener('beforeunload', () => {
        if (pollingInterval) {
            clearInterval(pollingInterval);
        }
    });
</script>

{% endblock %}