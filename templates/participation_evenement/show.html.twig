{% extends 'back/base_admin.html.twig' %}

{% block title %}Détails de la Participation — MatchNTeam{% endblock %}
{% block page_title %}Gestion des Participations{% endblock %}

{% block content %}
<div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
    <div>
        <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Détails de la Participation</h2>
        <p style="font-size: 13px; color: var(--text-secondary); margin-top: 2px;">Consultation des informations d'inscription</p>
    </div>

    <table class="table">
        <tbody>
            <tr>
                <th>Id_participation</th>
                <td>{{ participation_evenement.idParticipation }}</td>
            </tr>
            <tr>
                <th>Presence</th>
                <td>{{ participation_evenement.presence ? 'Yes' : 'No' }}</td>
            </tr>
            <tr>
                <th>Date_inscription</th>
                <td>{{ participation_evenement.dateInscription ? participation_evenement.dateInscription|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Token</th>
                <td>{{ participation_evenement.token }}</td>
            </tr>
            <tr>
                <th>Jeton</th>
                <td>{{ participation_evenement.jeton }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_participation_evenement_index') }}">back to list</a>

    <a href="{{ path('app_participation_evenement_edit', {'id_participation': participation_evenement.id_participation}) }}">edit</a>

    {{ include('participation_evenement/_delete_form.html.twig') }}
{% endblock %}
