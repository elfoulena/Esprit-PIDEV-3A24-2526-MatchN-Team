{# templates/equipe/show.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}{{ equipe.nomEquipe }} — MatchNTeam{% endblock %}
{% block page_title %}Détail Équipe{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link href='https://cdn.jsdelivr.net/npm/fullcalendar@5.11.3/main.min.css' rel='stylesheet' />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
{% endblock %}

{% block extra_styles %}
.detail-card {
    background: var(--card-bg); border: 1px solid var(--border-color);
    border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden;
    margin-bottom: 24px;
}
.detail-banner {
    padding: 28px 32px; border-bottom: 1px solid var(--border-color);
    display: flex; justify-content: space-between; align-items: flex-start;
}
.detail-stats {
    display: grid; grid-template-columns: repeat(4, 1fr);
    border-bottom: 1px solid var(--border-color);
}
.detail-stat-cell {
    padding: 18px 24px; border-right: 1px solid var(--border-color);
}
.detail-stat-cell:last-child { border-right: none; }
.stat-cell-label { font-size: 10px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 6px; }
.stat-cell-value { font-size: 15px; font-weight: 700; color: var(--text-primary); }

.badge-status {
    padding: 6px 14px; border-radius: 20px; font-size: 12px; font-weight: 700; display: inline-block;
}
.badge-status.active   { background: rgba(16,185,129,0.12); color: #059669; }
.badge-status.paused   { background: rgba(245,158,11,0.12); color: #b45309; }
.badge-status.inactive { background: rgba(239,68,68,0.10); color: #dc2626; }

.member-pill {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 14px; background: #f8fafc;
    border: 1px solid var(--border-color); border-radius: 20px; font-size: 13px;
}

/* Calendar specific styles */
.calendar-section {
    margin-top: 24px;
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 24px;
}

.calendar-section-title {
    font-size: 18px;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
    padding-bottom: 12px;
    border-bottom: 1px solid var(--border-color);
}

.calendar-section-title i {
    color: #3498db;
    font-size: 20px;
}

#calendar {
    min-height: 600px;
}

.event-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 15px;
    margin-bottom: 24px;
}

.event-stat-card {
    background: #f8fafc;
    border-radius: 12px;
    padding: 16px;
    border: 1px solid #e2e8f0;
    transition: all 0.3s;
    cursor: pointer;
}

.event-stat-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 6px rgba(0,0,0,0.1);
}

.event-stat-card .stat-icon {
    font-size: 28px;
    margin-bottom: 10px;
}

.event-stat-card .stat-label {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 5px;
}

.event-stat-card .stat-number {
    font-size: 28px;
    font-weight: 700;
    color: #1e293b;
}

.event-stat-card.total .stat-icon { color: #3498db; }
.event-stat-card.upcoming .stat-icon { color: #f39c12; }
.event-stat-card.ongoing .stat-icon { color: #2ecc71; }
.event-stat-card.completed .stat-icon { color: #95a5a6; }

/* Filter bar */
.filter-bar {
    display: flex;
    gap: 15px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}

.filter-bar .filter-group {
    flex: 1;
    min-width: 150px;
}

.filter-bar select, .filter-bar button {
    width: 100%;
    padding: 8px 12px;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: white;
    font-size: 14px;
}

.filter-bar button {
    background: #64748b;
    color: white;
    border: none;
    cursor: pointer;
}

.filter-bar button:hover {
    background: #475569;
}

/* Modal styles */
.event-detail-modal .modal-header {
    border-bottom: none;
}

.event-detail-modal .info-group {
    margin-bottom: 20px;
}

.event-detail-modal .info-group label {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    color: #64748b;
    letter-spacing: 0.5px;
    display: block;
    margin-bottom: 6px;
}

.event-detail-modal .info-group label i {
    margin-right: 6px;
}

.event-detail-modal .info-group p {
    margin: 0;
    font-size: 14px;
    color: #1e293b;
    font-weight: 500;
}

/* Responsive */
@media (max-width: 768px) {
    .event-stats {
        grid-template-columns: repeat(2, 1fr);
    }
    
    .filter-bar {
        flex-direction: column;
    }
    
    .filter-bar .filter-group {
        min-width: auto;
    }
}

.fc-event {
    cursor: pointer;
}

.fc-event:hover {
    filter: brightness(1.05);
}
{% endblock %}

{% block content %}

{# Breadcrumb + actions #}
<div style="display: flex; align-items: center; justify-content: space-between; margin-bottom: 22px; flex-wrap: wrap; gap: 12px;">
    <div style="display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-secondary);">
        <a href="{{ path('app_equipe_index') }}" style="color: var(--text-secondary); text-decoration: none;">Équipes</a>
        <span>/</span>
        <span style="color: var(--text-primary); font-weight: 600;">{{ equipe.nomEquipe }}</span>
    </div>
    <div style="display: flex; gap: 8px; flex-wrap: wrap;">
        <a href="{{ path('app_membre_equipe_index', {'id_equipe': equipe.idEquipe}) }}"
           style="display: inline-flex; align-items: center; gap: 6px; padding: 8px 16px; background: rgba(16,185,129,0.10); color: #059669; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Membres ({{ equipe.nbMembresActuel }})
