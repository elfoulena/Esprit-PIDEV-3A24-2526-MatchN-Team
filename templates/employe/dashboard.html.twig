{# templates/employe/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Bienvenue — Espace Employé{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; }

    .welcome-page {
        min-height: 100vh;
        background: #f5f4f0;
        display: flex;
        flex-direction: column;
    }

    /* ---- Navbar ---- */
    .navbar {
        background: #fff;
        border-bottom: 0.5px solid #ddd;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .navbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }
    .brand-logo {
        width: 32px;
        height: 32px;
        background: #1a1a1a;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        font-family: Georgia, serif;
    }
    .brand-name {
        font-size: 15px;
        font-weight: 500;
        color: #1a1a1a;
    }
    .navbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .nav-user {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .nav-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #e6f1fb;
        color: #185fa5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
    }
    .nav-name {
        font-size: 13px;
        font-weight: 500;
        color: #1a1a1a;
    }
    .nav-role {
        font-size: 11px;
        color: #888;
    }
    .btn-logout {
        padding: 7px 14px;
        border: 0.5px solid #f09595;
        border-radius: 7px;
        color: #a32d2d;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        background: #fff;
        transition: background 0.15s;
    }
    .btn-logout:hover { background: #fcebeb; }

    /* ---- Contenu principal ---- */
    .welcome-body {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
    }
    .welcome-card {
        background: #fff;
        border: 0.5px solid #ddd;
        border-radius: 20px;
        padding: 3rem;
        max-width: 560px;
        width: 100%;
        text-align: center;
    }
    .welcome-icon-wrap {
        width: 72px;
        height: 72px;
        background: #e6f1fb;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.75rem;
    }
    .welcome-icon {
        width: 36px;
        height: 36px;
        fill: none;
        stroke: #185fa5;
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .welcome-badge {
        display: inline-block;
        background: #e6f1fb;
        color: #185fa5;
        font-size: 11px;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 1rem;
    }
    .welcome-title {
        font-size: 28px;
        font-weight: 500;
        color: #1a1a1a;
        font-family: Georgia, serif;
        margin: 0 0 0.75rem;
        line-height: 1.3;
    }
    .welcome-title span { color: #185fa5; }
    .welcome-sub {
        font-size: 14px;
        color: #888;
        line-height: 1.7;
        margin: 0 0 2rem;
    }

    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 2rem;
        text-align: left;
    }
    .info-item {
        background: #f9f8f5;
        border-radius: 10px;
        padding: 12px 14px;
    }
    .info-label {
        font-size: 11px;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0 0 3px;
    }
    .info-value {
        font-size: 14px;
        font-weight: 500;
        color: #1a1a1a;
        margin: 0;
    }

    .divider {
        border: none;
        border-top: 0.5px solid #eee;
        margin: 0 0 1.5rem;
    }

    .welcome-note {
        font-size: 12px;
        color: #bbb;
        line-height: 1.6;
    }

    @media (max-width: 480px) {
        .welcome-card { padding: 2rem 1.25rem; }
        .info-grid { grid-template-columns: 1fr; }
        .navbar { padding: 0 1rem; }
        .nav-name, .nav-role { display: none; }
    }
</style>
{% endblock %}

{% block body %}
<div class="welcome-page">

    {# Navbar #}
    <nav class="navbar">
        <div class="navbar-brand">
            <div class="brand-logo">RH</div>
            <span class="brand-name">MatchNTeam</span>
        </div>
        <div class="navbar-right">
            <div class="nav-user">
                <div class="nav-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </div>
                <div>
                    <div class="nav-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                    <div class="nav-role">Employé</div>
                </div>
            </div>
            <a href="{{ path('app_logout') }}" class="btn-logout"
               onclick="return confirm('Voulez-vous vous déconnecter ?')">
                Déconnexion
            </a>
        </div>
    </nav>

    {# Contenu #}
    <div class="welcome-body">
        <div class="welcome-card">

            <div class="welcome-icon-wrap">
                <svg class="welcome-icon" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                    <circle cx="12" cy="7" r="4"/>
                </svg>
            </div>

            <span class="welcome-badge">Espace Employé</span>

            <h1 class="welcome-title">
                Bonjour,<br>
                <span>{{ app.user.prenom }} {{ app.user.nom }}</span>
            </h1>

            <p class="welcome-sub">
                Bienvenue sur votre espace personnel.<br>
                Votre compte est actif et opérationnel.
            </p>

            <div class="info-grid">
                <div class="info-item">
                    <p class="info-label">Email</p>
                    <p class="info-value" style="font-size:12px; word-break:break-all;">
                        {{ app.user.email }}
                    </p>
                </div>
                <div class="info-item">
                    <p class="info-label">Poste</p>
                    <p class="info-value">{{ app.user.poste ?? 'Non défini' }}</p>
                </div>
                <div class="info-item">
                    <p class="info-label">Département</p>
                    <p class="info-value">{{ app.user.departement ?? 'Non défini' }}</p>
                </div>
                <div class="info-item">
                    <p class="info-label">Contrat</p>
                    <p class="info-value">{{ app.user.typeContrat ?? 'Non défini' }}</p>
                </div>
            </div>

            <hr class="divider">

            <p class="welcome-note">
                Pour toute modification de vos informations, veuillez contacter votre administrateur RH.
            </p>

        </div>
    </div>

</div>
{% endblock %}
