{# templates/freelancer/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Bienvenue — Espace Freelancer{% endblock %}

{% block stylesheets %}
<style>
    * { box-sizing: border-box; }

    .welcome-page {
        min-height: 100vh;
        background: #f5f4f0;
        display: flex;
        flex-direction: column;
    }

    /* ---- Navbar ---- */
    .navbar {
        background: #fff;
        border-bottom: 0.5px solid #ddd;
        padding: 0 2rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        height: 56px;
        position: sticky;
        top: 0;
        z-index: 100;
    }
    .navbar-brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
    }
    .brand-logo {
        width: 32px;
        height: 32px;
        background: #1a1a1a;
        border-radius: 7px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: #fff;
        font-family: Georgia, serif;
    }
    .brand-name {
        font-size: 15px;
        font-weight: 500;
        color: #1a1a1a;
    }
    .navbar-right {
        display: flex;
        align-items: center;
        gap: 1rem;
    }
    .nav-user {
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .nav-avatar {
        width: 32px;
        height: 32px;
        border-radius: 50%;
        background: #e1f5ee;
        color: #0f6e56;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 500;
    }
    .nav-name { font-size: 13px; font-weight: 500; color: #1a1a1a; }
    .nav-role { font-size: 11px; color: #888; }
    .btn-logout {
        padding: 7px 14px;
        border: 0.5px solid #f09595;
        border-radius: 7px;
        color: #a32d2d;
        font-size: 13px;
        font-weight: 500;
        text-decoration: none;
        background: #fff;
        transition: background 0.15s;
    }
    .btn-logout:hover { background: #fcebeb; }

    /* ---- Contenu ---- */
    .welcome-body {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem 1.5rem;
    }
    .welcome-card {
        background: #fff;
        border: 0.5px solid #ddd;
        border-radius: 20px;
        padding: 3rem;
        max-width: 580px;
        width: 100%;
        text-align: center;
    }
    .welcome-icon-wrap {
        width: 72px;
        height: 72px;
        background: #e1f5ee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.75rem;
    }
    .welcome-icon {
        width: 36px;
        height: 36px;
        fill: none;
        stroke: #0f6e56;
        stroke-width: 1.5;
        stroke-linecap: round;
        stroke-linejoin: round;
    }
    .welcome-badge {
        display: inline-block;
        background: #e1f5ee;
        color: #0f6e56;
        font-size: 11px;
        font-weight: 500;
        padding: 4px 12px;
        border-radius: 20px;
        text-transform: uppercase;
        letter-spacing: 0.6px;
        margin-bottom: 1rem;
    }
    .welcome-title {
        font-size: 28px;
        font-weight: 500;
        color: #1a1a1a;
        font-family: Georgia, serif;
        margin: 0 0 0.75rem;
        line-height: 1.3;
    }
    .welcome-title span { color: #0f6e56; }
    .welcome-sub {
        font-size: 14px;
        color: #888;
        line-height: 1.7;
        margin: 0 0 2rem;
    }

    /* Infos compte */
    .info-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 10px;
        margin-bottom: 1.5rem;
        text-align: left;
    }
    .info-item {
        background: #f9f8f5;
        border-radius: 10px;
        padding: 12px 14px;
    }
    .info-item.full { grid-column: 1 / -1; }
    .info-label {
        font-size: 11px;
        color: #aaa;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin: 0 0 3px;
    }
    .info-value {
        font-size: 14px;
        font-weight: 500;
        color: #1a1a1a;
        margin: 0;
        line-height: 1.5;
    }

    /* Statut vérifié */
    .status-row {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        margin-bottom: 1.5rem;
        padding: 10px 16px;
        border-radius: 10px;
        font-size: 13px;
        font-weight: 500;
    }
    .status-verified {
        background: #eaf3de;
        color: #3b6d11;
        border: 0.5px solid #c0dd97;
    }
    .status-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #639922;
        flex-shrink: 0;
    }

    .divider {
        border: none;
        border-top: 0.5px solid #eee;
        margin: 0 0 1.5rem;
    }
    .welcome-note {
        font-size: 12px;
        color: #bbb;
        line-height: 1.6;
    }

    @media (max-width: 480px) {
        .welcome-card { padding: 2rem 1.25rem; }
        .info-grid { grid-template-columns: 1fr; }
        .info-item.full { grid-column: 1; }
        .navbar { padding: 0 1rem; }
        .nav-name, .nav-role { display: none; }
    }
</style>
{% endblock %}

{% block body %}
<div class="welcome-page">

    {# Navbar #}
    <nav class="navbar">
        <div class="navbar-brand">
            <div class="brand-logo">RH</div>
            <span class="brand-name">MatchNTeam</span>
        </div>
        <div class="navbar-right">
            <div class="nav-user">
                <div class="nav-avatar">
                    {{ app.user.prenom|first|upper }}{{ app.user.nom|first|upper }}
                </div>
                <div>
                    <div class="nav-name">{{ app.user.prenom }} {{ app.user.nom }}</div>
                    <div class="nav-role">Freelancer</div>
                </div>
            </div>
            <a href="{{ path('app_logout') }}" class="btn-logout"
               onclick="return confirm('Voulez-vous vous déconnecter ?')">
                Déconnexion
            </a>
        </div>
    </nav>

    {# Contenu #}
    <div class="welcome-body">
        <div class="welcome-card">

            <div class="welcome-icon-wrap">
                <svg class="welcome-icon" viewBox="0 0 24 24">
                    <rect x="2" y="7" width="20" height="14" rx="2" ry="2"/>
                    <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"/>
                </svg>
            </div>

            <span class="welcome-badge">Espace Freelancer</span>

            <h1 class="welcome-title">
                Bienvenue,<br>
                <span>{{ app.user.prenom }} {{ app.user.nom }}</span>
            </h1>

            <p class="welcome-sub">
                Votre profil freelancer est actif.<br>
                Vous êtes prêt à recevoir des missions.
            </p>

            {# Statut du compte #}
            <div class="status-row status-verified">
                <span class="status-dot"></span>
                Compte vérifié et actif
            </div>

            {# Infos profil #}
            <div class="info-grid">
                <div class="info-item">
                    <p class="info-label">Email</p>
                    <p class="info-value" style="font-size:12px; word-break:break-all;">
                        {{ app.user.email }}
                    </p>
                </div>
                <div class="info-item">
                    <p class="info-label">Téléphone</p>
                    <p class="info-value">{{ app.user.telephone ?? 'Non renseigné' }}</p>
                </div>
                {% if app.user.description %}
                <div class="info-item full">
                    <p class="info-label">Description</p>
                    <p class="info-value" style="font-weight:400; font-size:13px; color:#555;">
                        {{ app.user.description }}
                    </p>
                </div>
                {% endif %}
            </div>

            <hr class="divider">

            <p class="welcome-note">
                Votre profil est visible par les administrateurs RH.<br>
                Vos compétences ont été détectées automatiquement depuis votre description.
            </p>

        </div>
    </div>

</div>
{% endblock %}
