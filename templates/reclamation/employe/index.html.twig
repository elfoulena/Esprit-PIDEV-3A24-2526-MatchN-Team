{% extends 'back/base_employe.html.twig' %}

{% block title %}Mes Réclamations — MatchNTeam{% endblock %}
{% block page_title %}Mes Réclamations{% endblock %}

{% block extra_styles %}
.stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
    margin-bottom: 28px;
}
.stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    padding: 22px 24px;
    position: relative;
    overflow: hidden;
    transition: transform var(--transition), box-shadow var(--transition);
    box-shadow: var(--shadow-sm);
}
.stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }
.stat-card::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 80px; height: 80px;
    border-radius: 0 var(--radius-lg) 0 80px;
    opacity: 0.07;
}
.stat-card.teal::before   { background: var(--accent-teal); }
.stat-card.orange::before { background: var(--accent-orange); }
.stat-card.cyan::before   { background: #06b6d4; }
.stat-card.green::before  { background: var(--accent-green); }
.stat-icon {
    width: 40px; height: 40px;
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 14px; font-size: 20px;
}
.stat-card.teal   .stat-icon { background: rgba(20,184,166,0.12);  color: var(--accent-teal); }
.stat-card.orange .stat-icon { background: rgba(245,158,11,0.12);  color: var(--accent-orange); }
.stat-card.cyan   .stat-icon { background: rgba(6,182,212,0.12);   color: #06b6d4; }
.stat-card.green  .stat-icon { background: rgba(16,185,129,0.12);  color: var(--accent-green); }
.stat-value { font-size: 32px; font-weight: 800; color: var(--text-primary); line-height: 1; margin-bottom: 4px; }
.stat-label { font-size: 12px; font-weight: 600; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 0.5px; }

.data-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
    padding: 24px;
    margin-bottom: 24px;
}

.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: 11px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 16px;
    font-size: 13.5px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-primary);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }

.filter-bar {
    display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center;
}
.filter-bar input,
.filter-bar select {
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border-color);
    font-size: 13px;
    background: var(--card-bg);
    color: var(--text-primary);
    font-family: inherit;
}
.filter-bar input { flex: 1; min-width: 180px; }
.filter-bar select { width: 180px; }

.btn-filter {
    padding: 8px 20px;
    border-radius: var(--radius-sm);
    border: 2px solid var(--accent-teal);
    background: var(--card-bg);
    color: var(--accent-teal);
    font-weight: 700; font-size: 13px;
    cursor: pointer; transition: all var(--transition);
    font-family: inherit;
}
.btn-filter:hover { background: var(--accent-teal); color: #fff; }

.btn-nouvelle {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 8px 18px;
    border-radius: var(--radius-sm);
    background: var(--accent-teal);
    color: white;
    border: none;
    font-weight: 700; font-size: 13px;
    cursor: pointer; transition: all var(--transition);
    font-family: inherit;
}
.btn-nouvelle:hover { opacity: 0.9; transform: translateY(-1px); }

.modal-header-custom {
    background: linear-gradient(135deg, #1e293b, #334155);
    padding: 22px 26px;
    display: flex; align-items: center; justify-content: space-between;
}
.modal-icon-box {
    background: rgba(255,255,255,.1); border-radius: 10px;
    width: 42px; height: 42px;
    display: flex; align-items: center; justify-content: center; font-size: 20px;
}
.textarea-custom {
    width: 100%; resize: vertical;
    border: 2px solid var(--border-color);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    font-size: 14px; line-height: 1.6;
    color: var(--text-primary);
    outline: none; transition: border-color .2s;
    font-family: inherit; background: white;
}
.textarea-custom:focus { border-color: var(--accent-teal); }

.empty-state { text-align: center; padding: 48px 0; color: var(--text-secondary); }
.empty-state-icon { font-size: 48px; margin-bottom: 12px; }
{% endblock %}

{% block content %}

{# Flashs #}
{% for msg in app.flashes('success') %}
    <div style="background:rgba(16,185,129,0.1);border:1px solid rgba(16,185,129,0.3);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:#059669;font-weight:600;">
        ✅ {{ msg }}
    </div>
{% endfor %}
{% for msg in app.flashes('error') %}
    <div style="background:rgba(239,68,68,0.1);border:1px solid rgba(239,68,68,0.3);border-radius:var(--radius-sm);padding:12px 16px;margin-bottom:16px;color:#dc2626;font-weight:600;">
        ❌ {{ msg }}
    </div>
{% endfor %}

{# ── Stats ── #}
<div class="stats-grid">
    <div class="stat-card teal">
        <div class="stat-icon">📋</div>
        <div class="stat-value">{{ stats.total }}</div>
        <div class="stat-label">Total</div>
    </div>
    <div class="stat-card orange">
        <div class="stat-icon">🆕</div>
        <div class="stat-value">{{ stats.nouveau }}</div>
        <div class="stat-label">Nouveau</div>
    </div>
    <div class="stat-card cyan">
        <div class="stat-icon">⏳</div>
        <div class="stat-value">{{ stats.en_cours }}</div>
        <div class="stat-label">En cours</div>
    </div>
    <div class="stat-card green">
        <div class="stat-icon">✅</div>
        <div class="stat-value">{{ stats.ferme }}</div>
        <div class="stat-label">Fermées</div>
    </div>
</div>

{# ── Tableau ── #}
<div class="data-card">

    <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;">
        <div style="font-size:15px;font-weight:800;color:var(--text-primary);">
            Liste de mes réclamations
        </div>
        <button onclick="new bootstrap.Modal(document.getElementById('modalNouvelle')).show()"
                class="btn-nouvelle">
            ➕ Nouvelle réclamation
        </button>
    </div>

    {# Filtre #}
    <form method="GET" class="filter-bar">
    <input type="text" name="search"
           placeholder="🔍 Rechercher dans mes messages..."
           value="{{ search }}"
           style="flex:1;">
    <select name="reponse">
        <option value="">Toutes les réclamations</option>
        <option value="avec" {{ filtre == 'avec' ? 'selected' }}>💬 Avec réponse</option>
        <option value="sans" {{ filtre == 'sans' ? 'selected' }}>— Sans réponse</option>
    </select>
    <button type="submit" class="btn-filter">Filtrer</button>
</form>

    {# Table #}
    <table class="data-table">
        <thead>
            <tr>
                <th>#ID</th>
                <th>Message</th>
                <th>Reponse</th>
                <th>Date</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for r in reclamations %}
            <tr>
                <td><strong style="color:var(--accent-teal);">#{{ r.id }}</strong></td>
                <td style="max-width:300px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
                    {{ r.message|slice(0,80) }}{% if r.message|length > 80 %}…{% endif %}
                </td>
                <td>
    {% if reponses[r.id] is defined and reponses[r.id] is not null %}
        <button onclick="voirReponse('{{ reponses[r.id].contenu|e('js') }}')"
                style="display:inline-flex;align-items:center;gap:4px;padding:4px 10px;border-radius:20px;background:rgba(16,185,129,0.12);color:#059669;border:none;font-size:11px;font-weight:700;cursor:pointer;font-family:inherit;">
            💬 Voir réponse
        </button>
    {% else %}
        <span style="color:var(--text-secondary);font-size:12px;font-style:italic;">—</span>
    {% endif %}
</td>
                <td style="color:var(--text-secondary);font-size:12px;">
                    {{ r.dateCreation ? r.dateCreation|date('d/m/Y') : '—' }}
                </td>
                <td style="white-space:nowrap;">
                    {% if r.statut == 'nouveau' %}
                        <button onclick="ouvrirModifier({{ r.id }}, '{{ r.message|e('js') }}')"
                                style="display:inline-flex;align-items:center;gap:4px;padding:6px 12px;border-radius:var(--radius-sm);background:rgba(245,158,11,0.1);color:#d97706;border:none;font-size:12px;font-weight:600;cursor:pointer;font-family:inherit;">
                            ✏️ Modifier
                        </button>
                        <form method="POST" action="{{ path('employe_reclamation_delete', {id: r.id}) }}"
                              style="display:inline;" onsubmit="return confirm('Supprimer cette réclamation ?')">
                            <button style="display:inline-flex;align-items:center;gap:4px;padding:6px 10px;border-radius:var(--radius-sm);background:rgba(239,68,68,0.1);color:#dc2626;border:none;font-size:12px;cursor:pointer;">
                                🗑
                            </button>
                        </form>
                    {% else %}
                        <span style="font-size:12px;color:var(--text-secondary);font-style:italic;">Non modifiable</span>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">
                    <div class="empty-state">
                        <div class="empty-state-icon">📝</div>
                        <div style="font-size:14px;">Aucune réclamation trouvée.</div>
                        <div style="font-size:12px;margin-top:6px;color:var(--text-secondary);">
                            Cliquez sur "Nouvelle réclamation" pour en soumettre une.
                        </div>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}

{% block javascripts %}
{# Modal Nouvelle Réclamation #}
{# Modal Voir Réponse #}
<div class="modal fade" id="modalVoirReponse" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden;box-shadow:0 30px 60px rgba(0,0,0,.15);">
            <div style="background:linear-gradient(135deg,#1e293b,#334155);padding:22px 26px;display:flex;align-items:center;justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div style="background:rgba(255,255,255,.1);border-radius:10px;width:42px;height:42px;display:flex;align-items:center;justify-content:center;font-size:20px;">💬</div>
                    <div>
                        <div style="color:white;font-weight:700;font-size:16px;">Réponse de l'administrateur</div>
                        <div style="color:rgba(255,255,255,.5);font-size:12px;">Réponse officielle à votre réclamation</div>
                    </div>
                </div>
                <button type="button" data-bs-dismiss="modal"
                        style="background:rgba(255,255,255,.1);border:none;color:white;width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;">×</button>
            </div>
            <div style="padding:24px 26px;background:#f8fafc;">
                <div style="background:white;border-radius:var(--radius-md);padding:16px;border-left:4px solid #10b981;box-shadow:var(--shadow-sm);">
                    <div style="font-size:11px;font-weight:700;color:#059669;letter-spacing:1px;text-transform:uppercase;margin-bottom:10px;">✅ Réponse</div>
                    <div id="contenuReponseAdmin" style="font-size:14px;line-height:1.7;color:var(--text-primary);"></div>
                </div>
            </div>
            <div style="padding:14px 26px;background:white;border-top:1px solid var(--border-color);display:flex;justify-content:flex-end;">
                <button type="button" data-bs-dismiss="modal"
                        style="background:#10b981;border:none;border-radius:var(--radius-sm);padding:9px 24px;color:white;font-weight:700;font-size:13px;cursor:pointer;font-family:inherit;">
                    Fermer
                </button>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="modalNouvelle" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden;box-shadow:0 30px 60px rgba(0,0,0,.15);">
            <div class="modal-header-custom">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="modal-icon-box">➕</div>
                    <div>
                        <div style="color:white;font-weight:700;font-size:16px;">Nouvelle réclamation</div>
                        <div style="color:rgba(255,255,255,.5);font-size:12px;">Décrivez votre problème en détail</div>
                    </div>
                </div>
                <button type="button" data-bs-dismiss="modal"
                        style="background:rgba(255,255,255,.1);border:none;color:white;width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;">×</button>
            </div>
            <form method="POST" action="{{ path('employe_reclamation_new') }}">
                <div style="padding:24px 26px;background:#f8fafc;display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div style="font-size:11px;font-weight:700;color:var(--text-secondary);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;">Votre message</div>
                        <textarea name="message" rows="6" class="textarea-custom"
                                  placeholder="Décrivez votre réclamation avec le plus de détails possible..."
                                  required></textarea>
                    </div>
                </div>
                <div style="padding:14px 26px;background:white;border-top:1px solid var(--border-color);display:flex;justify-content:flex-end;gap:10px;">
                    <button type="button" data-bs-dismiss="modal"
                            style="background:none;border:1px solid var(--border-color);border-radius:var(--radius-sm);padding:9px 20px;color:var(--text-secondary);font-weight:600;font-size:13px;cursor:pointer;font-family:inherit;">
                        Annuler
                    </button>
                    <button type="submit"
                            style="background:var(--accent-teal);border:none;border-radius:var(--radius-sm);padding:9px 24px;color:white;font-weight:700;font-size:13px;cursor:pointer;font-family:inherit;">
                        ✅ Soumettre
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

{# Modal Modifier #}
<div class="modal fade" id="modalModifier" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border:none;border-radius:var(--radius-lg);overflow:hidden;box-shadow:0 30px 60px rgba(0,0,0,.15);">
            <div class="modal-header-custom">
                <div style="display:flex;align-items:center;gap:12px;">
                    <div class="modal-icon-box">✏️</div>
                    <div>
                        <div style="color:white;font-weight:700;font-size:16px;">Modifier la réclamation</div>
                        <div style="color:rgba(255,255,255,.5);font-size:12px;">Uniquement pour les réclamations nouvelles</div>
                    </div>
                </div>
                <button type="button" data-bs-dismiss="modal"
                        style="background:rgba(255,255,255,.1);border:none;color:white;width:32px;height:32px;border-radius:50%;font-size:18px;cursor:pointer;">×</button>
            </div>
            <form method="POST" id="formModifier">
                <div style="padding:24px 26px;background:#f8fafc;display:flex;flex-direction:column;gap:16px;">
                    <div>
                        <div style="font-size:11px;font-weight:700;color:var(--text-secondary);letter-spacing:.8px;text-transform:uppercase;margin-bottom:8px;">Votre message</div>
                        <textarea name="message" id="taModifier" rows="6" class="textarea-custom" required></textarea>
                    </div>
                </div>
                <div style="padding:14px 26px;background:white;border-top:1px solid var(--border-color);display:flex;justify-content:flex-end;gap:10px;">
                    <button type="button" data-bs-dismiss="modal"
                            style="background:none;border:1px solid var(--border-color);border-radius:var(--radius-sm);padding:9px 20px;color:var(--text-secondary);font-weight:600;font-size:13px;cursor:pointer;font-family:inherit;">
                        Annuler
                    </button>
                    <button type="submit"
                            style="background:var(--accent-orange);border:none;border-radius:var(--radius-sm);padding:9px 24px;color:white;font-weight:700;font-size:13px;cursor:pointer;font-family:inherit;">
                        💾 Enregistrer
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
function ouvrirModifier(id, message) {
    document.getElementById('formModifier').action = '/employe/reclamations/' + id + '/modifier';
    document.getElementById('taModifier').value = message;
    new bootstrap.Modal(document.getElementById('modalModifier')).show();
}
function voirReponse(contenu) {
    document.getElementById('contenuReponseAdmin').textContent = contenu;
    new bootstrap.Modal(document.getElementById('modalVoirReponse')).show();
}
</script>
{% endblock %}
