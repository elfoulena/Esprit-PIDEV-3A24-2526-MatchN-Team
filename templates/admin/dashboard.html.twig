{# templates/admin/dashboard.html.twig #}
{% extends 'base.html.twig' %}

{% block title %}Tableau de bord — Admin{% endblock %}

{% block stylesheets %}
<style>
    .page { padding: 2rem; max-width: 1100px; margin: 0 auto; }

    .page-header {
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        margin-bottom: 2rem;
        flex-wrap: wrap;
        gap: 1rem;
    }
    .page-title {
        font-size: 24px;
        font-weight: 500;
        color: #1a1a1a;
        font-family: Georgia, serif;
        margin: 0 0 4px;
    }
    .page-sub { font-size: 13px; color: #888; margin: 0; }

    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #1a1a1a;
        color: #fff;
        padding: 10px 18px;
        border-radius: 8px;
        font-size: 14px;
        font-weight: 500;
        text-decoration: none;
        transition: background 0.15s;
    }
    .btn-primary:hover { background: #333; }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 12px;
        margin-bottom: 2rem;
    }
    .stat-card {
        background: #f5f4f0;
        border-radius: 10px;
        padding: 1rem 1.25rem;
    }
    .stat-label { font-size: 12px; color: #888; margin: 0 0 4px; text-transform: uppercase; letter-spacing: 0.5px; }
    .stat-value { font-size: 26px; font-weight: 500; color: #1a1a1a; margin: 0; }

    .section-title {
        font-size: 13px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: #aaa;
        margin: 0 0 0.75rem;
    }

    .table-card {
        background: #fff;
        border: 0.5px solid #ddd;
        border-radius: 12px;
        overflow: hidden;
        margin-bottom: 2rem;
    }
    table {
        width: 100%;
        border-collapse: collapse;
        font-size: 14px;
    }
    thead tr {
        background: #f9f8f5;
        border-bottom: 0.5px solid #eee;
    }
    thead th {
        padding: 10px 16px;
        text-align: left;
        font-size: 12px;
        font-weight: 500;
        color: #888;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        white-space: nowrap;
    }
    tbody tr {
        border-bottom: 0.5px solid #f0f0f0;
        transition: background 0.1s;
    }
    tbody tr:last-child { border-bottom: none; }
    tbody tr:hover { background: #fafafa; }
    td { padding: 12px 16px; color: #1a1a1a; vertical-align: middle; }

    .avatar {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 500;
        flex-shrink: 0;
    }
    .avatar-emp  { background: #e6f1fb; color: #185fa5; }
    .avatar-free { background: #e1f5ee; color: #0f6e56; }

    .user-cell { display: flex; align-items: center; gap: 10px; }
    .user-name  { font-weight: 500; font-size: 14px; color: #1a1a1a; }
    .user-email { font-size: 12px; color: #888; }

    .badge {
        display: inline-block;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 500;
    }
    .badge-actif   { background: #eaf3de; color: #3b6d11; }
    .badge-inactif { background: #fcebeb; color: #791f1f; }
    .badge-contrat { background: #f5f4f0; color: #5f5e5a; }
    .badge-free    { background: #e1f5ee; color: #0f6e56; }

    .actions { display: flex; gap: 8px; align-items: center; }
    .btn-toggle {
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 6px;
        border: 0.5px solid #ddd;
        cursor: pointer;
        background: #fff;
        color: #444;
        text-decoration: none;
        transition: background 0.1s;
    }
    .btn-toggle:hover { background: #f5f4f0; }
    .btn-toggle.desact { border-color: #f09595; color: #a32d2d; }
    .btn-toggle.desact:hover { background: #fcebeb; }

    .empty-state {
        text-align: center;
        padding: 3rem 1rem;
        color: #888;
        font-size: 14px;
    }

    .tab-row {
        display: flex;
        gap: 0;
        margin-bottom: 1.5rem;
        border-bottom: 0.5px solid #eee;
    }
    .tab {
        padding: 10px 20px;
        font-size: 14px;
        color: #888;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -0.5px;
        text-decoration: none;
    }
    .tab.active { color: #1a1a1a; border-bottom-color: #1a1a1a; font-weight: 500; }

    @media (max-width: 700px) {
        .stats-row { grid-template-columns: 1fr 1fr; }
        td.hide-mobile, th.hide-mobile { display: none; }
        .page { padding: 1rem; }
    }
</style>
{% endblock %}

{% block body %}
<div class="page">

    {# Remplace le page-header existant par celui-ci #}
<div class="page-header">
    <div>
        <h1 class="page-title">Tableau de bord</h1>
        <p class="page-sub">Gestion des utilisateurs — {{ "now"|date("d/m/Y") }}</p>
    </div>

    <div style="display: flex; align-items: center; gap: 1rem;">

        {# Infos utilisateur connecté #}
        <div style="text-align: right;">
            <div style="font-size: 14px; font-weight: 500; color: #1a1a1a;">
                {{ app.user.prenom }} {{ app.user.nom }}
            </div>
            <div style="font-size: 12px; color: #888;">Administrateur</div>
        </div>

        {# Bouton créer employé #}
        <a href="{{ path('admin_create_employee') }}" class="btn-primary">
            + Créer un employé
        </a>

        {# Bouton déconnexion #}
        <a href="{{ path('app_logout') }}" class="btn-logout"
           onclick="return confirm('Voulez-vous vous déconnecter ?')">
            Déconnexion
        </a>

    </div>
</div>

    {# Statistiques #}
    <div class="stats-row">
        <div class="stat-card">
            <p class="stat-label">Employés</p>
            <p class="stat-value">{{ employes|length }}</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Freelancers</p>
            <p class="stat-value">{{ freelancers|length }}</p>
        </div>
        <div class="stat-card">
            <p class="stat-label">Total</p>
            <p class="stat-value">{{ employes|length + freelancers|length }}</p>
        </div>
    </div>

    {# Flash messages #}
    {% for msg in app.flashes('success') %}
        <div style="background:#eaf3de;color:#3b6d11;border-radius:8px;padding:10px 16px;font-size:13px;margin-bottom:1.5rem;border:0.5px solid #c0dd97;">
            {{ msg }}
        </div>
    {% endfor %}

    {# --- TABLE EMPLOYÉS --- #}
    <p class="section-title">Employés ({{ employes|length }})</p>
    <div class="table-card">
        {% if employes is empty %}
            <div class="empty-state">Aucun employé pour le moment.</div>
        {% else %}
        <table>
            <thead>
                <tr>
                    <th>Collaborateur</th>
                    <th class="hide-mobile">Poste</th>
                    <th class="hide-mobile">Contrat</th>
                    <th class="hide-mobile">Département</th>
                    <th>Statut</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            {% for emp in employes %}
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="avatar avatar-emp">
                                {{ emp.prenom|first|upper }}{{ emp.nom|first|upper }}
                            </div>
                            <div>
                                <div class="user-name">{{ emp.prenom }} {{ emp.nom }}</div>
                                <div class="user-email">{{ emp.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="hide-mobile">{{ emp.poste ?? '—' }}</td>
                    <td class="hide-mobile">
                        {% if emp.typeContrat %}
                            <span class="badge badge-contrat">{{ emp.typeContrat }}</span>
                        {% else %}—{% endif %}
                    </td>
                    <td class="hide-mobile">{{ emp.departement ?? '—' }}</td>
                    <td>
                        {% if emp.actif %}
                            <span class="badge badge-actif">Actif</span>
                        {% else %}
                            <span class="badge badge-inactif">Inactif</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="actions">
                            <a href="{{ path('admin_toggle_employe', {id: emp.id}) }}"
                               class="btn-toggle {% if emp.actif %}desact{% endif %}"
                               onclick="return confirm('Confirmer cette action ?')">
                                {{ emp.actif ? 'Désactiver' : 'Activer' }}
                            </a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

    {# --- TABLE FREELANCERS --- #}
    <p class="section-title">Freelancers ({{ freelancers|length }})</p>
    <div class="table-card">
        {% if freelancers is empty %}
            <div class="empty-state">Aucun freelancer inscrit.</div>
        {% else %}
        <table>
            <thead>
                <tr>
                    <th>Freelancer</th>
                    <th class="hide-mobile">Description</th>
                    <th>Vérifié</th>
                    <th>Statut</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
            {% for fl in freelancers %}
                <tr>
                    <td>
                        <div class="user-cell">
                            <div class="avatar avatar-free">
                                {{ fl.prenom|first|upper }}{{ fl.nom|first|upper }}
                            </div>
                            <div>
                                <div class="user-name">{{ fl.prenom }} {{ fl.nom }}</div>
                                <div class="user-email">{{ fl.email }}</div>
                            </div>
                        </div>
                    </td>
                    <td class="hide-mobile" style="max-width:200px;">
                        <span style="font-size:13px;color:#555;">
                            {{ fl.description ? fl.description|slice(0,60) ~ '…' : '—' }}
                        </span>
                    </td>
                    <td>
                        {% if fl.verified %}
                            <span class="badge badge-actif">Oui</span>
                        {% else %}
                            <span class="badge badge-inactif">Non</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if fl.actif %}
                            <span class="badge badge-actif">Actif</span>
                        {% else %}
                            <span class="badge badge-inactif">Inactif</span>
                        {% endif %}
                    </td>
                    <td>
                        <div class="actions">
                            <a href="{{ path('admin_toggle_employe', {id: fl.id}) }}"
                               class="btn-toggle {% if fl.actif %}desact{% endif %}"
                               onclick="return confirm('Confirmer cette action ?')">
                                {{ fl.actif ? 'Désactiver' : 'Activer' }}
                            </a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
        {% endif %}
    </div>

</div>
{% endblock %}
