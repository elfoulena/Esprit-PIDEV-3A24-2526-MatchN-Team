{% extends 'base.html.twig' %}

{% block title %}Gestion des Équipes — MatchNTeam{% endblock %}

{% block body_class %}admin-dashboard-page{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
    /* Design tokens (consistent avec login et dashboard) */
    :root {
        --bg-main:        #f0f2f5;
        --bg-surface:     #e8eaf0;
        --card-bg:        #ffffff;
        --border-color:   rgba(0,0,0,0.08);
        --text-primary:   #1e293b;
        --text-secondary: #64748b;
        --accent-blue:    #3b82f6;
        --accent-purple:  #8b5cf6;
        --accent-green:   #10b981;
        --accent-orange:  #f59e0b;
        --radius-sm:      8px;
        --radius-md:      12px;
        --radius-lg:      16px;
        --shadow-sm:      0 1px 4px rgba(0,0,0,0.08);
        --shadow-md:      0 4px 20px rgba(0,0,0,0.10);
        --transition:     0.18s ease;
    }

    /* Layout admin avec sidebar */
    .admin-wrapper {
        display: flex;
        min-height: 100vh;
        background: var(--bg-main);
    }

    /* Sidebar style */
    .admin-sidebar {
        width: 280px;
        background: var(--card-bg);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0;
        left: 0;
        bottom: 0;
        z-index: 100;
        transition: all var(--transition);
        box-shadow: var(--shadow-sm);
    }

    .sidebar-brand {
        padding: 28px 24px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 12px;
    }
    .brand-logo {
        width: 38px; height: 38px;
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        border-radius: var(--radius-sm);
        display: flex;
        align-items: center; justify-content: center;
        font-size: 15px; font-weight: 800; color: #fff;
        letter-spacing: -0.5px;
    }
    .brand-name {
        font-size: 18px;
        font-weight: 700;
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .sidebar-nav {
        flex: 1;
        padding: 24px 16px;
        display: flex;
        flex-direction: column;
        gap: 8px;
    }
    .nav-item {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 16px;
        border-radius: var(--radius-md);
        font-size: 14px;
        font-weight: 500;
        color: var(--text-secondary);
        transition: all var(--transition);
        cursor: pointer;
        text-decoration: none;
    }
    .nav-item svg {
        width: 20px;
        height: 20px;
        stroke-width: 1.7;
    }
    .nav-item:hover {
        background: rgba(59,130,246,0.08);
        color: var(--accent-blue);
    }
    .nav-item.active {
        background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(139,92,246,0.08));
        color: var(--accent-blue);
        font-weight: 600;
        border-left: 3px solid var(--accent-blue);
    }
    .sidebar-footer {
        padding: 20px 24px;
        border-top: 1px solid var(--border-color);
        font-size: 12px;
        color: var(--text-secondary);
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .logout-link {
        display: flex;
        align-items: center;
        gap: 10px;
        color: #ef4444;
        text-decoration: none;
        font-weight: 500;
        font-size: 13px;
    }
    .role-badge-mini {
        background: #f1f5f9;
        padding: 4px 10px;
        border-radius: 20px;
        font-size: 11px;
        display: inline-block;
    }

    /* Main content */
    .admin-main {
        flex: 1;
        margin-left: 280px;
        background: var(--bg-main);
        min-height: 100vh;
    }

    /* Top header */
    .top-header {
        background: var(--card-bg);
        border-bottom: 1px solid var(--border-color);
        padding: 16px 32px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-wrap: wrap;
        gap: 16px;
    }
    .page-title-section h2 {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-primary);
    }
    .page-title-section p {
        font-size: 13px;
        color: var(--text-secondary);
        margin-top: 4px;
    }
    .admin-avatar {
        display: flex;
        align-items: center;
        gap: 14px;
        background: var(--bg-surface);
        padding: 6px 16px 6px 12px;
        border-radius: 40px;
    }
    .avatar-icon {
        width: 38px; height: 38px;
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: white;
        font-weight: bold;
    }

    /* Container */
    .dashboard-container {
        padding: 28px 32px;
    }

    /* Stats cards */
    .stats-grid {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
        margin-bottom: 32px;
    }
    .stat-card {
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        padding: 20px 24px;
        box-shadow: var(--shadow-sm);
        transition: transform var(--transition);
    }
    .stat-card:hover {
        transform: translateY(-2px);
        box-shadow: var(--shadow-md);
    }
    .stat-label {
        font-size: 11px;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.8px;
        margin-bottom: 8px;
    }
    .stat-number {
        font-size: 32px;
        font-weight: 800;
        color: var(--text-primary);
    }
    .stat-number.special-green { color: var(--accent-green); }
    .stat-number.special-blue { color: var(--accent-blue); }
    .stat-number.special-orange { color: var(--accent-orange); }

    /* Section header */
    .section-header {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 20px;
    }
    .section-header h3 {
        font-size: 12px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: var(--text-secondary);
        margin: 0;
    }

    /* Data card / table */
    .data-card {
        background: var(--card-bg);
        border-radius: var(--radius-lg);
        border: 1px solid var(--border-color);
        box-shadow: var(--shadow-sm);
        overflow: hidden;
    }
    .data-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
    }
    .data-table thead {
        background: #f8fafc;
        border-bottom: 1px solid var(--border-color);
    }
    .data-table th {
        padding: 16px 20px;
        font-size: 11px;
        font-weight: 700;
        color: var(--text-secondary);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }
    .data-table td {
        padding: 16px 20px;
        border-bottom: 1px solid var(--border-color);
        font-size: 13px;
        font-weight: 500;
        color: var(--text-primary);
    }

    /* Boutons */
    .btn-primary {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: var(--radius-sm);
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        text-decoration: none;
        transition: all var(--transition);
        box-shadow: 0 4px 12px rgba(59,130,246,0.25);
    }
    .btn-primary:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 18px rgba(59,130,246,0.35);
        opacity: 0.95;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .admin-sidebar { width: 260px; }
        .admin-main { margin-left: 260px; }
    }
    @media (max-width: 768px) {
        .admin-sidebar { transform: translateX(-100%); position: fixed; }
        .admin-main { margin-left: 0; }
        .stats-grid { grid-template-columns: 1fr 1fr; }
    }
</style>
{% endblock %}

{% block body %}
<div class="admin-wrapper">
    <!-- SIDEBAR ADMIN -->
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo">MN</div>
            <span class="brand-name">MatchNTeam</span>
        </div>
        <div class="sidebar-nav">
            <a href="{{ path('app_home') }}" class="nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span>Tableau de bord</span>
            </a>
            <a href="{{ path('app_equipe_index') }}" class="nav-item active">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <span>Gestion des équipes</span>
            </a>
            <a href="#" class="nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span>Employés</span>
            </a>
            <a href="#" class="nav-item">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A8 8 0 0111 21m8-8a8 8 0 11-8-8m8 8H3m8 8V3" />
                </svg>
                <span>Freelancers</span>
            </a>
        </div>
        <div class="sidebar-footer">
            <div style="display: flex; gap: 8px;">
                <span class="role-badge-mini">👑 Admin RH</span>
            </div>
            <a href="{{ path('app_logout') }}" class="logout-link">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Déconnexion
            </a>
            <div style="font-size: 11px; margin-top: 6px;">&copy; MatchNTeam {{ "now"|date("Y") }}</div>
        </div>
    </aside>

    <!-- MAIN CONTENT -->
    <main class="admin-main">
        <div class="top-header">
            <div class="page-title-section">
                <h2>Gestion des Équipes</h2>
                <p>Créer, modifier et suivre toutes les équipes de l'organisation</p>
            </div>
            <div class="admin-avatar">
                <div class="avatar-icon">AD</div>
                <span style="font-weight: 500;">{{ app.user.email|default('Admin@matchnteam.com') }}</span>
            </div>
        </div>

        <div class="dashboard-container">
            {# ─── FLASH MESSAGES ─── #}
            {% for label, messages in app.flashes %}
                {% for message in messages %}
                    <div style="padding: 12px 18px; margin-bottom: 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
                        {% if label == 'success' %}background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2);
                        {% elseif label == 'danger' %}background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2);
                        {% else %}background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.2);{% endif %}">
                        {{ message }}
                    </div>
                {% endfor %}
            {% endfor %}

            {# ─── STATS CARDS ─── #}
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-label">Total Équipes</div>
                    <div class="stat-number">{{ stats.total }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Actives</div>
                    <div class="stat-number special-green">{{ stats.active }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">En Pause</div>
                    <div class="stat-number special-orange">{{ stats.pause }}</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Total Membres</div>
                    <div class="stat-number special-blue">{{ stats.totalMembres }}</div>
                </div>
            </div>

            {# ─── PAGE HEADER ─── #}
            <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
                <div class="section-header">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
                    </svg>
                    <h3>LISTE DES ÉQUIPES</h3>
                </div>
                <a href="{{ path('app_equipe_new') }}" class="btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Nouvelle Équipe
                </a>
            </div>

            {# ─── SEARCH & FILTERS ─── #}
            <div style="background: #fff; border-radius: 12px; border: 1px solid var(--border-color); padding: 20px 24px; margin-bottom: 20px; box-shadow: var(--shadow-sm);">
                <form action="{{ path('app_equipe_index') }}" method="GET" style="display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;">
                    <div style="flex: 2; min-width: 200px;">
                        <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px;">Recherche</label>
                        <input type="text" name="q" value="{{ q }}" placeholder="Nom, description, département..."
                            style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; outline: none; box-sizing: border-box;">
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px;">Statut</label>
                        <select name="statut" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                            <option value="">Tous</option>
                            <option value="Active" {{ statut == 'Active' ? 'selected' }}>Active</option>
                            <option value="Inactive" {{ statut == 'Inactive' ? 'selected' }}>Inactive</option>
                            <option value="En pause" {{ statut == 'En pause' ? 'selected' }}>En pause</option>
                        </select>
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px;">Département</label>
                        <select name="departement" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                            <option value="">Tous</option>
                            {% for dep in departements %}
                                <option value="{{ dep }}" {{ departement == dep ? 'selected' }}>{{ dep }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div style="flex: 1; min-width: 150px;">
                        <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px;">Trier par</label>
                        <select name="sortBy" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                            <option value="dateCreation" {{ sortBy == 'dateCreation' ? 'selected' }}>Date création</option>
                            <option value="nomEquipe" {{ sortBy == 'nomEquipe' ? 'selected' }}>Nom</option>
                            <option value="nbMembresActuel" {{ sortBy == 'nbMembresActuel' ? 'selected' }}>Membres</option>
                            <option value="budget" {{ sortBy == 'budget' ? 'selected' }}>Budget</option>
                            <option value="statut" {{ sortBy == 'statut' ? 'selected' }}>Statut</option>
                        </select>
                    </div>
                    <div style="flex: 1; min-width: 120px;">
                        <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 6px;">Ordre</label>
                        <select name="sortDir" style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                            <option value="DESC" {{ sortDir == 'DESC' ? 'selected' }}>Décroissant</option>
                            <option value="ASC" {{ sortDir == 'ASC' ? 'selected' }}>Croissant</option>
                        </select>
                    </div>
                    <div style="display: flex; gap: 8px;">
                        <button type="submit" style="padding: 10px 18px; background: #64748b; color: #fff; border: none; border-radius: var(--radius-sm); cursor: pointer; font-size: 13px; font-weight: 600;">
                            Filtrer
                        </button>
                        <a href="{{ path('app_equipe_index') }}" style="padding: 10px 14px; background: #f1f5f9; color: #334155; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center;">
                            Reset
                        </a>
                    </div>
                </form>
            </div>

            {# ─── TABLE ─── #}
            <div class="data-card">
                <div style="overflow-x: auto;">
                    <table class="data-table">
                        <thead>
                            <tr>
                                <th>Équipe</th>
                                <th>Département</th>
                                <th>Membres</th>
                                <th>Budget</th>
                                <th>Date Création</th>
                                <th>Statut</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                        {% for equipe in equipes %}
                            <tr>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 12px;">
                                        <div style="width: 36px; height: 36px; border-radius: 8px; background: {{ equipe.couleurEquipe }}22; display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                            <span style="font-size: 14px; font-weight: 800; color: {{ equipe.couleurEquipe }};">{{ equipe.nomEquipe|slice(0,1)|upper }}</span>
                                        </div>
                                        <div>
                                            <div style="font-weight: 700; color: var(--text-primary);">{{ equipe.nomEquipe }}</div>
                                            {% if equipe.description %}
                                                <div style="font-size: 12px; color: var(--text-secondary); margin-top: 2px;">{{ equipe.description|slice(0, 50) }}{% if equipe.description|length > 50 %}...{% endif %}</div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </td>
                                <td style="color: var(--text-secondary);">{{ equipe.departement ?? '-' }}</td>
                                <td>
                                    <div style="display: flex; align-items: center; gap: 8px;">
                                        <span style="font-weight: 700; color: var(--accent-blue);">{{ equipe.nbMembresActuel }}</span>
                                        <span style="color: var(--text-secondary);">/ {{ equipe.nbMembresMax }}</span>
                                        <div style="width: 60px; background: #e2e8f0; border-radius: 4px; height: 4px;">
                                            {% set pct = equipe.nbMembresMax > 0 ? ((equipe.nbMembresActuel / equipe.nbMembresMax) * 100)|round : 0 %}
                                            <div style="background: var(--accent-blue); height: 4px; border-radius: 4px; width: {{ pct > 100 ? 100 : pct }}%;"></div>
                                        </div>
                                    </div>
                                </td>
                                <td style="font-weight: 600;">{{ equipe.budget ? equipe.budget ~ ' DT' : '-' }}</td>
                                <td>{{ equipe.dateCreation ? equipe.dateCreation|date('d/m/Y') : '-' }}</td>
                                <td>
                                    {% if equipe.statut == 'Active' %}
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.12); color: #10b981;">● Active</span>
                                    {% elseif equipe.statut == 'En pause' %}
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(245,158,11,0.12); color: #f59e0b;">● En pause</span>
                                    {% else %}
                                        <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(239,68,68,0.12); color: #ef4444;">● Inactive</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="display: flex; gap: 8px;">
                                        <a href="{{ path('app_equipe_show', {'id_equipe': equipe.idEquipe}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #ebd0f5; color: #8b5cf6;" title="Voir">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                                        </a>
                                        <a href="{{ path('app_membre_equipe_index', {'id_equipe': equipe.idEquipe}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #dcfce7; color: #16a34a;" title="Membres">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                                        </a>
                                        <a href="{{ path('app_equipe_edit', {'id_equipe': equipe.idEquipe}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #e0f2fe; color: #0284c7;" title="Modifier">
                                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                        </a>
                                        <form method="post" action="{{ path('app_equipe_delete', {'id_equipe': equipe.idEquipe}) }}" onsubmit="return confirm('Confirmer la suppression de l\'équipe « {{ equipe.nomEquipe }} » ?');" style="margin:0;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ equipe.idEquipe) }}">
                                            <button type="submit" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: rgba(239,68,68,0.1); color: #ef4444; border: none; cursor: pointer;" title="Supprimer">
                                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="7" style="text-align: center; padding: 40px; color: var(--text-secondary); font-size: 14px;">Aucune équipe trouvée</td>
                            </tr>
                        {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script>
    // Gestion de l'active class sur la sidebar
    document.addEventListener('DOMContentLoaded', function() {
        const currentPath = window.location.pathname;
        const navItems = document.querySelectorAll('.nav-item');
        navItems.forEach(item => {
            const href = item.getAttribute('href');
            if (href && (currentPath === href || currentPath.includes('/admin/equipe'))) {
                item.classList.add('active');
            }
        });
    });
</script>
{% endblock %}