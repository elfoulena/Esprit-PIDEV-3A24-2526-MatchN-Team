{% extends 'back/base_employee.html.twig' %}

{% block page_title %}
    <h1>Membres — {{ equipe.nomEquipe }}</h1>
{% endblock %}

{% block employee_content %}

{# ─── FLASH MESSAGES ─── #}
{% for label, messages in app.flashes %}
    {% for message in messages %}
        <div style="padding: 12px 18px; margin-bottom: 16px; border-radius: 8px; font-size: 13px; font-weight: 600;
            {% if label == 'success' %}background: rgba(16,185,129,0.12); color: #10b981; border: 1px solid rgba(16,185,129,0.2);
            {% elseif label == 'danger' %}background: rgba(239,68,68,0.1); color: #ef4444; border: 1px solid rgba(239,68,68,0.2);
            {% else %}background: rgba(59,130,246,0.1); color: #3b82f6; border: 1px solid rgba(59,130,246,0.2);{% endif %}">
            {{ message }}
        </div>
    {% endfor %}
{% endfor %}

{# ─── EQUIPE MINI CARD ─── #}
<div style="background: #fff; border-radius: 12px; border: 1px solid var(--border-color); padding: 18px 24px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; box-shadow: var(--shadow-sm);">
    <div style="display: flex; align-items: center; gap: 14px;">
        <div style="width: 44px; height: 44px; border-radius: 10px; background: {{ equipe.couleurEquipe }}22; display: flex; align-items: center; justify-content: center; border: 2px solid {{ equipe.couleurEquipe }}44;">
            <span style="font-size: 18px; font-weight: 900; color: {{ equipe.couleurEquipe }};">{{ equipe.nomEquipe|slice(0,1)|upper }}</span>
        </div>
        <div>
            <div style="font-size: 16px; font-weight: 800; color: var(--text-primary);">{{ equipe.nomEquipe }}</div>
            <div style="font-size: 12px; color: var(--text-secondary); margin-top: 2px;">
                {{ equipe.departement ?? 'Aucun département' }} ·
                <span style="font-weight: 600; color: var(--accent-blue);">{{ equipe.nbMembresActuel }} / {{ equipe.nbMembresMax }} membres</span>
            </div>
        </div>
    </div>
    <div style="display: flex; align-items: center; gap: 10px;">
        {% if equipe.statut == 'Active' %}
            <span style="padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.12); color: #10b981;">● Active</span>
        {% elseif equipe.statut == 'En pause' %}
            <span style="padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(245,158,11,0.12); color: #f59e0b;">● En pause</span>
        {% else %}
            <span style="padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(239,68,68,0.12); color: #ef4444;">● Inactive</span>
        {% endif %}
        <a href="{{ path('app_equipe_show', {'id_equipe': equipe.idEquipe}) }}" style="font-size: 12px; font-weight: 600; color: var(--accent-blue); text-decoration: none;">Voir l'équipe →</a>
    </div>
</div>

{# ─── PAGE HEADER ─── #}
<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px;">
    <div style="display: flex; align-items: center; gap: 8px; color: var(--text-secondary);">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        </svg>
        <h3 style="font-size: 13px; font-weight: 700; margin: 0; text-transform: uppercase;">LISTE DES MEMBRES</h3>
    </div>
    <div style="display: flex; gap: 10px; align-items: center;">
        <a href="{{ path('app_equipe_index') }}" style="display: inline-flex; align-items: center; gap: 6px; padding: 9px 16px; background: #f1f5f9; color: #334155; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            Équipes
        </a>
        {% if equipe.nbMembresActuel < equipe.nbMembresMax %}
        <a href="{{ path('app_membre_equipe_new', {'id_equipe': equipe.idEquipe}) }}" style="display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; background: var(--accent-blue); color: #fff; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Ajouter un membre
        </a>
        {% else %}
        <span style="display: inline-flex; align-items: center; gap: 8px; padding: 9px 18px; background: #f1f5f9; color: #94a3b8; border-radius: var(--radius-sm); font-size: 13px; font-weight: 600;" title="Capacité maximale atteinte">
            Équipe complète
        </span>
        {% endif %}
    </div>
</div>

{# ─── FILTERS ─── #}
<div style="background: #fff; border-radius: 12px; border: 1px solid var(--border-color); padding: 16px 20px; margin-bottom: 20px; box-shadow: var(--shadow-sm);">
    <form action="{{ path('app_membre_equipe_index', {'id_equipe': equipe.idEquipe}) }}" method="GET" style="display: flex; gap: 12px; flex-wrap: wrap; align-items: flex-end;">
        <div style="flex: 2; min-width: 180px;">
            <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 5px;">Recherche</label>
            <input type="text" name="q" value="{{ q }}" placeholder="Compétences, notes..."
                style="width: 100%; padding: 9px 12px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; outline: none; box-sizing: border-box;">
        </div>
        <div style="flex: 1; min-width: 140px;">
            <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 5px;">Rôle</label>
            <select name="role" style="width: 100%; padding: 9px 12px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                <option value="">Tous</option>
                <option value="Membre" {{ role == 'Membre' ? 'selected' }}>Membre</option>
                <option value="Chef d'équipe" {{ role == "Chef d'équipe" ? 'selected' }}>Chef d'équipe</option>
                <option value="Coordinateur" {{ role == 'Coordinateur' ? 'selected' }}>Coordinateur</option>
                <option value="Observateur" {{ role == 'Observateur' ? 'selected' }}>Observateur</option>
            </select>
        </div>
        <div style="flex: 1; min-width: 140px;">
            <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 5px;">Statut</label>
            <select name="statut" style="width: 100%; padding: 9px 12px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                <option value="">Tous</option>
                <option value="Actif" {{ statut == 'Actif' ? 'selected' }}>Actif</option>
                <option value="Inactif" {{ statut == 'Inactif' ? 'selected' }}>Inactif</option>
                <option value="En congé" {{ statut == 'En congé' ? 'selected' }}>En congé</option>
            </select>
        </div>
        <div style="flex: 1; min-width: 140px;">
            <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 5px;">Trier par</label>
            <select name="sortBy" style="width: 100%; padding: 9px 12px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                <option value="dateAffectation" {{ sortBy == 'dateAffectation' ? 'selected' }}>Date affectation</option>
                <option value="roleEquipe" {{ sortBy == 'roleEquipe' ? 'selected' }}>Rôle</option>
                <option value="statutMembre" {{ sortBy == 'statutMembre' ? 'selected' }}>Statut</option>
                <option value="tauxParticipation" {{ sortBy == 'tauxParticipation' ? 'selected' }}>Taux participation</option>
            </select>
        </div>
        <div style="flex: 1; min-width: 120px;">
            <label style="display: block; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; margin-bottom: 5px;">Ordre</label>
            <select name="sortDir" style="width: 100%; padding: 9px 12px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13px; background: #fff;">
                <option value="DESC" {{ sortDir == 'DESC' ? 'selected' }}>Décroissant</option>
                <option value="ASC" {{ sortDir == 'ASC' ? 'selected' }}>Croissant</option>
            </select>
        </div>
        <div style="display: flex; gap: 8px;">
            <button type="submit" style="padding: 9px 16px; background: #64748b; color: #fff; border: none; border-radius: var(--radius-sm); cursor: pointer; font-size: 13px; font-weight: 600;">Filtrer</button>
            <a href="{{ path('app_membre_equipe_index', {'id_equipe': equipe.idEquipe}) }}" style="padding: 9px 12px; background: #f1f5f9; color: #334155; border-radius: var(--radius-sm); text-decoration: none; font-size: 13px; font-weight: 600; display: inline-flex; align-items: center;">Reset</a>
        </div>
    </form>
</div>

{# ─── TABLE ─── #}
<div style="background: var(--card-bg); border-radius: var(--radius-lg); border: 1px solid var(--border-color); box-shadow: var(--shadow-sm); overflow: hidden;">
    <div style="overflow-x: auto;">
        <table style="width: 100%; border-collapse: collapse; text-align: left;">
            <thead style="background: #f8fafc; border-bottom: 1px solid var(--border-color);">
                <tr>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Utilisateur</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Rôle</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Date Affectation</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Date Fin</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Taux (%)</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Compétences</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Statut</th>
                    <th style="padding: 16px 20px; font-size: 11px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase;">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for membre in membres %}
                {% set user = userData[membre.idUser] ?? null %}
                <tr style="border-bottom: 1px solid var(--border-color); font-size: 13px; font-weight: 500;">
                    <td style="padding: 16px 20px;">
    <div style="display: flex; align-items: center; gap: 10px;">
        <div style="width: 34px; height: 34px; border-radius: 50%; background: {{ equipe.couleurEquipe }}22; display: flex; align-items: center; justify-content: center; font-size: 12px; font-weight: 800; color: {{ equipe.couleurEquipe }}; flex-shrink: 0;">
            {% set user = userData[membre.idUser] ?? null %}
            {% if user %}
                {{ user.prenom|first|upper }}
            {% else %}
                {{ membre.idUser }}
            {% endif %}
        </div>
        <div>
            <div style="font-weight: 700; color: var(--text-primary);">
                {% if user %}
                    {{ user.prenom }} {{ user.nom }}
                {% else %}
                    Utilisateur #{{ membre.idUser }}
                {% endif %}
            </div>
            {% if user and user.email %}
                <div style="font-size: 11px; color: var(--text-secondary);">{{ user.email }}</div>
            {% endif %}
            {% if membre.notes %}
                <div style="font-size: 11px; color: var(--text-secondary); margin-top: 4px;">{{ membre.notes|slice(0, 40) }}{% if membre.notes|length > 40 %}...{% endif %}</div>
            {% endif %}
        </div>
    </div>
</td>
                    <td style="padding: 16px 20px;">
                        {% if membre.roleEquipe == "Chef d'équipe" %}
                            <span style="padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(245,158,11,0.12); color: #d97706;">{{ membre.roleEquipe }}</span>
                        {% elseif membre.roleEquipe == 'Coordinateur' %}
                            <span style="padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(139,92,246,0.12); color: #7c3aed;">{{ membre.roleEquipe }}</span>
                        {% elseif membre.roleEquipe == 'Observateur' %}
                            <span style="padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: #f1f5f9; color: #64748b;">{{ membre.roleEquipe }}</span>
                        {% else %}
                            <span style="padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(59,130,246,0.10); color: #2563eb;">{{ membre.roleEquipe }}</span>
                        {% endif %}
                    </td>
                    <td style="padding: 16px 20px; color: var(--text-secondary);">{{ membre.dateAffectation ? membre.dateAffectation|date('d/m/Y') : '-' }}</td>
                    <td style="padding: 16px 20px; color: var(--text-secondary);">{{ membre.dateFin ? membre.dateFin|date('d/m/Y') : '—' }}</td>
                    <td style="padding: 16px 20px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                            <div style="width: 50px; background: #e2e8f0; border-radius: 4px; height: 4px;">
                                <div style="background: #10b981; height: 4px; border-radius: 4px; width: {{ membre.tauxParticipation }}%;"></div>
                            </div>
                            <span style="font-weight: 600; font-size: 12px;">{{ membre.tauxParticipation }}%</span>
                        </div>
                    </td>
                    <td style="padding: 16px 20px; color: var(--text-secondary); font-size: 12px;">{{ membre.competencesPrincipales ?? '—' }}</td>
                    <td style="padding: 16px 20px;">
                        {% if membre.statutMembre == 'Actif' %}
                            <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(16,185,129,0.12); color: #10b981;">● Actif</span>
                        {% elseif membre.statutMembre == 'En congé' %}
                            <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(245,158,11,0.12); color: #f59e0b;">● En congé</span>
                        {% else %}
                            <span style="padding: 4px 10px; border-radius: 20px; font-size: 11px; font-weight: 700; background: rgba(239,68,68,0.12); color: #ef4444;">● Inactif</span>
                        {% endif %}
                    </td>
                    <td style="padding: 16px 20px;">
                        <div style="display: flex; gap: 8px;">
                            <a href="{{ path('app_membre_equipe_edit', {'id_equipe': equipe.idEquipe, 'id_membre': membre.idMembre}) }}" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: #e0f2fe; color: #0284c7;" title="Modifier">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                            </a>
                            <form method="post" action="{{ path('app_membre_equipe_delete', {'id_equipe': equipe.idEquipe, 'id_membre': membre.idMembre}) }}" onsubmit="return confirm('Retirer ce membre de l\'équipe ?');" style="margin:0;">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ membre.idMembre) }}">
                                <button type="submit" style="display: inline-flex; align-items: center; justify-content: center; width: 32px; height: 32px; border-radius: 8px; background: rgba(239,68,68,0.1); color: #ef4444; border: none; cursor: pointer;" title="Retirer">
                                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                                </button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="8" style="text-align: center; padding: 48px; color: var(--text-secondary); font-size: 14px;">
                        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" style="display: block; margin: 0 auto 12px; opacity: 0.35;">
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
                        </svg>
                        Aucun membre trouvé
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}