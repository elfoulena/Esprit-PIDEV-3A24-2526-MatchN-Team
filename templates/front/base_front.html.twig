<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=yes">
    <title>Admin Dashboard — MatchNTeam</title>
    <!-- Google Fonts + simple reset (consistent with login/team design tokens) -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,300;14..32,400;14..32,500;14..32,600;14..32,700;14..32,800&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        /* ── Design tokens (exactement ceux utilisés dans login.html.twig et index equipe) ── */
        :root {
            --bg-main:        #f0f2f5;
            --bg-surface:     #e8eaf0;
            --card-bg:        #ffffff;
            --border-color:   rgba(0,0,0,0.08);
            --text-primary:   #1e293b;
            --text-secondary: #64748b;
            --accent-blue:    #3b82f6;
            --accent-purple:  #8b5cf6;
            --accent-green:   #10b981;
            --accent-orange:  #f59e0b;
            --radius-sm:      8px;
            --radius-md:      12px;
            --radius-lg:      16px;
            --shadow-sm:      0 1px 4px rgba(0,0,0,0.08);
            --shadow-md:      0 4px 20px rgba(0,0,0,0.10);
            --transition:     0.18s ease;
        }

        body {
            background: var(--bg-main);
            font-family: 'Inter', system-ui, 'Segoe UI', sans-serif;
            color: var(--text-primary);
        }

        /* Layout principal : side panel + contenu */
        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* ========= SIDEBAR (moderne, inspiré login-left et cartes) ========= */
        .admin-sidebar {
            width: 280px;
            background: var(--card-bg);
            border-right: 1px solid var(--border-color);
            display: flex;
            flex-direction: column;
            position: fixed;
            top: 0;
            left: 0;
            bottom: 0;
            z-index: 20;
            transition: all var(--transition);
            backdrop-filter: blur(0px);
            box-shadow: var(--shadow-sm);
        }

        /* brand / logo */
        .sidebar-brand {
            padding: 28px 24px;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .brand-logo {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center; justify-content: center;
            font-size: 15px; font-weight: 800; color: #fff;
            letter-spacing: -0.5px;
        }
        .brand-name {
            font-size: 18px;
            font-weight: 700;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        /* navigation */
        .sidebar-nav {
            flex: 1;
            padding: 24px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }
        .nav-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 16px;
            border-radius: var(--radius-md);
            font-size: 14px;
            font-weight: 500;
            color: var(--text-secondary);
            transition: all var(--transition);
            cursor: pointer;
            text-decoration: none;
        }
        .nav-item svg {
            width: 20px;
            height: 20px;
            stroke-width: 1.7;
        }
        .nav-item:hover {
            background: rgba(59,130,246,0.08);
            color: var(--accent-blue);
        }
        .nav-item.active {
            background: linear-gradient(135deg, rgba(59,130,246,0.12), rgba(139,92,246,0.08));
            color: var(--accent-blue);
            font-weight: 600;
            border-left: 3px solid var(--accent-blue);
        }
        .sidebar-footer {
            padding: 20px 24px;
            border-top: 1px solid var(--border-color);
            font-size: 12px;
            color: var(--text-secondary);
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .logout-link {
            display: flex;
            align-items: center;
            gap: 10px;
            color: #ef4444;
            text-decoration: none;
            font-weight: 500;
            font-size: 13px;
        }

        /* MAIN CONTENT */
        .admin-main {
            flex: 1;
            margin-left: 280px;
            background: var(--bg-main);
            min-height: 100vh;
        }

        /* header supérieur (inspiré de la fiche dashboard) */
        .top-header {
            background: var(--card-bg);
            border-bottom: 1px solid var(--border-color);
            padding: 16px 32px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 16px;
            backdrop-filter: blur(2px);
        }
        .page-title-section h2 {
            font-size: 22px;
            font-weight: 700;
            color: var(--text-primary);
        }
        .page-title-section p {
            font-size: 13px;
            color: var(--text-secondary);
            margin-top: 4px;
        }
        .admin-avatar {
            display: flex;
            align-items: center;
            gap: 14px;
            background: var(--bg-surface);
            padding: 6px 16px 6px 12px;
            border-radius: 40px;
        }
        .avatar-icon {
            width: 38px; height: 38px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: bold;
        }

        /* container principal */
        .dashboard-container {
            padding: 28px 32px;
        }

        /* ========= STATS CARDS (exactement identiques à index equipe) ========= */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 20px;
            margin-bottom: 32px;
        }
        .stat-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            padding: 20px 24px;
            box-shadow: var(--shadow-sm);
            transition: transform var(--transition);
        }
        .stat-card:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }
        .stat-label {
            font-size: 11px;
            font-weight: 700;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            margin-bottom: 8px;
        }
        .stat-number {
            font-size: 32px;
            font-weight: 800;
            color: var(--text-primary);
        }
        .stat-number.special-green { color: var(--accent-green); }
        .stat-number.special-blue { color: var(--accent-blue); }
        .stat-number.special-orange { color: var(--accent-orange); }

        /* section-header (style dashboard) */
        .section-header {
            display: flex;
            align-items: center;
            gap: 10px;
            margin-bottom: 20px;
        }
        .section-header h3 {
            font-size: 12px;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--text-secondary);
            margin: 0;
        }

        /* Carte de bienvenue (orbe subtile) */
        .welcome-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            padding: 28px 32px;
            margin-bottom: 32px;
            position: relative;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
        }
        .welcome-card::before {
            content: '';
            position: absolute;
            top: -80px;
            right: -80px;
            width: 260px;
            height: 260px;
            background: radial-gradient(circle, rgba(59,130,246,0.08) 0%, transparent 70%);
            pointer-events: none;
        }
        .welcome-title {
            font-size: 26px;
            font-weight: 800;
            margin-bottom: 8px;
        }
        .welcome-title .gradient {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            -webkit-background-clip: text;
            background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        .welcome-sub {
            color: var(--text-secondary);
            font-size: 14px;
        }

        /* Quick actions + bouton gestion equipes (moderne) */
        .action-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 16px;
            margin-top: 20px;
        }
        .btn-primary {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white;
            border: none;
            padding: 12px 28px;
            border-radius: var(--radius-sm);
            font-weight: 700;
            font-size: 14px;
            cursor: pointer;
            text-decoration: none;
            transition: all var(--transition);
            box-shadow: 0 4px 12px rgba(59,130,246,0.25);
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 22px rgba(59,130,246,0.35);
            opacity: 0.96;
        }
        .btn-outline {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            padding: 10px 20px;
            border-radius: var(--radius-sm);
            font-weight: 500;
            text-decoration: none;
            transition: background 0.2s;
        }
        .btn-outline:hover {
            background: rgba(0,0,0,0.02);
            border-color: var(--accent-blue);
        }

        /* tableau style equipe (identique à index equipe) */
        .data-card {
            background: var(--card-bg);
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            box-shadow: var(--shadow-sm);
            overflow: hidden;
            margin-top: 20px;
        }
        .data-table {
            width: 100%;
            border-collapse: collapse;
            text-align: left;
        }
        .data-table thead {
            background: #f8fafc;
            border-bottom: 1px solid var(--border-color);
        }
        .data-table th {
            padding: 16px 20px;
            font-size: 11px;
            font-weight: 700;
            color: var(--text-secondary);
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        .data-table td {
            padding: 16px 20px;
            border-bottom: 1px solid var(--border-color);
            font-size: 13px;
            font-weight: 500;
            color: var(--text-primary);
        }
        .team-badge {
            width: 34px;
            height: 34px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 800;
            font-size: 14px;
            background: rgba(59,130,246,0.1);
        }
        .status-active {
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 700;
            background: rgba(16,185,129,0.12);
            color: #10b981;
        }
        .status-pause {
            background: rgba(245,158,11,0.12);
            color: #f59e0b;
        }
        .action-icons {
            display: flex;
            gap: 10px;
        }
        .action-icon {
            width: 32px;
            height: 32px;
            border-radius: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: #f1f5f9;
            color: #475569;
            transition: 0.15s;
            text-decoration: none;
        }
        .action-icon:hover {
            background: var(--accent-blue);
            color: white;
        }
        @media (max-width: 1024px) {
            .admin-sidebar { width: 260px; }
            .admin-main { margin-left: 260px; }
        }
        @media (max-width: 768px) {
            .admin-sidebar { transform: translateX(-100%); position: fixed; }
            .admin-main { margin-left: 0; }
            .stats-grid { grid-template-columns: 1fr 1fr; }
        }
        .empty-row td {
            text-align: center;
            padding: 40px;
            color: var(--text-secondary);
        }
        .role-badge-mini {
            background: #f1f5f9;
            padding: 4px 10px;
            border-radius: 20px;
            font-size: 11px;
        }
        .flash-message {
            padding: 12px 18px;
            margin-bottom: 16px;
            border-radius: 8px;
            font-size: 13px;
            font-weight: 600;
            background: rgba(59,130,246,0.1);
            color: #3b82f6;
            border: 1px solid rgba(59,130,246,0.2);
        }
    </style>
</head>
<body>
<div class="admin-wrapper">
    <!-- SIDEBAR (dashboard admin complet) -->
    <aside class="admin-sidebar">
        <div class="sidebar-brand">
            <div class="brand-logo">MN</div>
            <span class="brand-name">MatchNTeam</span>
        </div>
        <div class="sidebar-nav">
            <!-- Dashboard (vue interne) -->
            <a href="#" class="nav-item active" data-view="dashboard" id="dashboardNavBtn">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                <span>Tableau de bord</span>
            </a>
            <!-- Gestion des équipes => REDIRECTION VERS LA BONNE ROUTE SYMFONY /admin/equipe/ -->
            <a href="/admin/equipe/" class="nav-item" id="gestionEquipesRealLink">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                </svg>
                <span>Gestion des équipes</span>
            </a>
            <a href="#" class="nav-item" data-view="employes">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
                <span>Employés</span>
            </a>
            <a href="#" class="nav-item" data-view="freelancers">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A8 8 0 0111 21m8-8a8 8 0 11-8-8m8 8H3m8 8V3" />
                </svg>
                <span>Freelancers</span>
            </a>
        </div>
        <div class="sidebar-footer">
            <div class="role-badge-mini" style="display: flex; gap: 8px;">
                <span>👑 Admin RH</span>
            </div>
            <a href="/logout" class="logout-link" id="logoutLink">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
                </svg>
                Déconnexion
            </a>
            <div style="font-size: 11px; margin-top: 6px;">&copy; MatchNTeam 2025</div>
        </div>
    </aside>

    <!-- MAIN CONTENT (dashboard + redirection externe) -->
    <main class="admin-main">
        <div class="top-header">
            <div class="page-title-section">
                <h2 id="mainTitle">Dashboard administrateur</h2>
                <p id="mainSubtitle">Vue d'ensemble & gestion RH / équipes</p>
            </div>
            <div class="admin-avatar">
                <div class="avatar-icon">AD</div>
                <span style="font-weight: 500;" id="userEmail">Admin@matchnteam.com</span>
            </div>
        </div>

        <div class="dashboard-container" id="dashboardContent">
            <!-- Vue Dashboard par défaut -->
            <div id="dashboardView">
                <!-- welcome card -->
                <div class="welcome-card">
                    <div class="welcome-title">Bienvenue, <span class="gradient">Administrateur</span> 👋</div>
                    <div class="welcome-sub">Gérez les équipes, suivez les performances et pilotez les ressources humaines depuis un seul tableau de bord.</div>
                    <div class="action-grid">
                        <!-- Ce bouton redirige aussi vers la page equipe index (route correcte) -->
                        <a href="/admin/equipe/" class="btn-primary" id="quickGestionEquipeBtn">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg>
                            Gestion des équipes →
                        </a>
                        <a href="#" class="btn-outline" id="newEmployeeBtn">+ Nouvel employé</a>
                    </div>
                </div>

                <!-- STATS CARDS (exactement comme dans index equipe) -->
                <div class="stats-grid">
                    <div class="stat-card"><div class="stat-label">Total Équipes</div><div class="stat-number" id="statTotal">12</div></div>
                    <div class="stat-card"><div class="stat-label">Actives</div><div class="stat-number special-green" id="statActive">8</div></div>
                    <div class="stat-card"><div class="stat-label">En Pause</div><div class="stat-number special-orange" id="statPause">3</div></div>
                    <div class="stat-card"><div class="stat-label">Total Membres</div><div class="stat-number special-blue" id="statMembres">94</div></div>
                </div>

                <!-- SECTION HEADER + Liste des équipes (aperçu) style tableau -->
                <div class="section-header">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
                    <h3>DERNIÈRES ÉQUIPES ACTIVES</h3>
                </div>

                <div class="data-card">
                    <table class="data-table">
                        <thead>
                            <tr><th>Équipe</th><th>Département</th><th>Membres</th><th>Budget</th><th>Statut</th><th></th></tr>
                        </thead>
                        <tbody>
                            <tr><td><div style="display: flex; align-items: center; gap: 12px;"><div class="team-badge" style="background:#3b82f622; color:#3b82f6;">I</div><span style="font-weight:600;">Innovation Lab</span></div></td><td>R&D</td><td>8 / 12</td><td>45 000 DT</td><td><span class="status-active">● Active</span></td><td><div class="action-icons"><a href="#" class="action-icon view-action">👁️</a><a href="#" class="action-icon edit-action">✏️</a></div></td></tr>
                            <tr><td><div style="display: flex; align-items: center; gap: 12px;"><div class="team-badge" style="background:#8b5cf622; color:#8b5cf6;">M</div><span style="font-weight:600;">Marketing Pro</span></div></td><td>Marketing</td><td>5 / 8</td><td>28 500 DT</td><td><span class="status-active">● Active</span></td><td><div class="action-icons"><a href="#" class="action-icon view-action">👁️</a><a href="#" class="action-icon edit-action">✏️</a></div></td></tr>
                            <tr><td><div style="display: flex; align-items: center; gap: 12px;"><div class="team-badge" style="background:#f59e0b22; color:#f59e0b;">C</div><span style="font-weight:600;">Customer Success</span></div></td><td>Support</td><td>6 / 10</td><td>19 200 DT</td><td><span class="status-pause">● En pause</span></td><td><div class="action-icons"><a href="#" class="action-icon view-action">👁️</a><a href="#" class="action-icon edit-action">✏️</a></div></td></tr>
                        </tbody>
                    </table>
                    <div style="padding: 14px 20px; border-top: 1px solid var(--border-color); text-align: right;">
                        <a href="/admin/equipe/" id="voirToutesEquipesLink" style="color: var(--accent-blue); font-weight: 600; text-decoration: none;">Voir toutes les équipes →</a>
                    </div>
                </div>

                <!-- badges rôles -->
                <div style="display: flex; gap: 12px; margin-top: 28px; justify-content: flex-start;">
                    <span class="role-badge-mini" style="background: #e0f2fe;">Admin RH</span>
                    <span class="role-badge-mini">Employé</span>
                    <span class="role-badge-mini">Freelancer</span>
                </div>
            </div>

            <!-- Zone d'information pour la redirection (message temporaire) -->
            <div id="redirectMessage" class="flash-message" style="display: none;"></div>
        </div>
    </main>
</div>

<script>
    // Fonction pour afficher un message de redirection (pour les clics qui ne sont pas des liens directs)
    function showRedirectMessageAndGoTo(url, message) {
        const msgDiv = document.getElementById('redirectMessage');
        if(msgDiv) {
            msgDiv.style.display = 'block';
            msgDiv.innerHTML = message || '🔁 Redirection vers la page Gestion des équipes...';
            setTimeout(() => {
                window.location.href = url;
            }, 300);
        } else {
            window.location.href = url;
        }
    }

    // Navigation interne pour le tableau de bord (reste dans la même page)
    const dashboardView = document.getElementById('dashboardView');
    const mainTitle = document.getElementById('mainTitle');
    const mainSubtitle = document.getElementById('mainSubtitle');

    function showDashboard() {
        dashboardView.style.display = 'block';
        mainTitle.innerText = 'Dashboard administrateur';
        mainSubtitle.innerText = 'Vue d\'ensemble & gestion RH / équipes';
        // Masquer tout message éventuel
        const msgDiv = document.getElementById('redirectMessage');
        if(msgDiv) msgDiv.style.display = 'none';
        // Mettre à jour la classe active sur la sidebar
        document.querySelectorAll('.nav-item').forEach(nav => nav.classList.remove('active'));
        const dashboardNav = document.getElementById('dashboardNavBtn');
        if(dashboardNav) dashboardNav.classList.add('active');
    }

    // Initialisation
    showDashboard();

    // ========== GESTION DES REDIRECTIONS CORRECTES VERS /admin/equipe/ ==========
    // Les liens avec href="/admin/equipe/" fonctionnent déjà directement (navigation classique)
    // Pour les boutons qui étaient en JavaScript, on utilise aussi la redirection directe
    
    // S'assurer que le lien "Gestion des équipes" dans la sidebar redirige correctement
    const gestionSidebarLink = document.getElementById('gestionEquipesRealLink');
    if(gestionSidebarLink && gestionSidebarLink.getAttribute('href') === '/admin/equipe/') {
        // Déjà un lien direct, aucun JS nécessaire - mais on peut ajouter un tracking si besoin
        gestionSidebarLink.addEventListener('click', function(e) {
            // Pas de preventDefault pour les liens normaux, ils fonctionnent nativement
            // On laisse le comportement par défaut
        });
    }
    
