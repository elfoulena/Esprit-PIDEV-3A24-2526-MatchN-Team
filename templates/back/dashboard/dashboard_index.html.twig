{# employee/dashboard/index.html.twig #}
{% extends 'base_employee.html.twig' %}

{% block page_title %}<h1>Tableau de Bord</h1>{% endblock %}

{% block employee_content %}

{# ─── WELCOME BANNER ─── #}
<div class="welcome-banner">
    <div class="welcome-text">
        <h2>Bonjour {{ app.user ? app.user.prenom : 'Invité' }} !</h2>
        <p>Voici votre espace de travail</p>
    </div>
    <div class="welcome-illustration">
        <svg xmlns="http://www.w3.org/2000/svg" width="80" height="80" viewBox="0 0 24 24"
             fill="none" stroke="rgba(255,255,255,0.3)" stroke-width="1">
            <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
            <line x1="8" y1="21" x2="16" y2="21"/>
            <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
    </div>
</div>

{# ─── STATS GRID ─── #}
<div class="section-header">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="20" x2="18" y2="10"/>
        <line x1="12" y1="20" x2="12" y2="4"/>
        <line x1="6" y1="20" x2="6" y2="14"/>
    </svg>
    <h3>APERÇU RAPIDE</h3>
</div>

<div class="stats-grid">
    <div class="stat-card stat-blue">
        <div class="stat-label">Mes Tâches</div>
        <div class="stat-value">{{ stats.tasks ?? 5 }}</div>
        <div class="stat-bar" style="--bar-color: var(--accent-blue)"></div>
    </div>
    <div class="stat-card stat-green">
        <div class="stat-label">Projets</div>
        <div class="stat-value">{{ stats.projects ?? 2 }}</div>
        <div class="stat-bar" style="--bar-color: var(--accent-green)"></div>
    </div>
    <div class="stat-card stat-orange">
        <div class="stat-label">Mon Équipe</div>
        <div class="stat-value">{{ stats.teamName ?? 'Aucune' }}</div>
        <div class="stat-bar" style="--bar-color: var(--accent-orange)"></div>
    </div>
    <div class="stat-card stat-purple">
        <div class="stat-label">Membres d'équipe</div>
        <div class="stat-value">{{ stats.teamMembers ?? 0 }}</div>
        <div class="stat-bar" style="--bar-color: var(--accent-purple)"></div>
    </div>
    <div class="stat-card stat-indigo">
        <div class="stat-label">Demandes en attente</div>
        <div class="stat-value">{{ stats.pendingRequests ?? 2 }}</div>
        <div class="stat-bar" style="--bar-color: #6366f1"></div>
    </div>
    <div class="stat-card stat-red">
        <div class="stat-label">Événements</div>
        <div class="stat-value">{{ stats.events ?? 3 }}</div>
        <div class="stat-bar" style="--bar-color: var(--accent-red)"></div>
    </div>
</div>

{# ─── TEAM SECTION ─── #}
<div class="section-header mt-32">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
        <circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/>
        <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
    </svg>
    <h3>MON ÉQUIPE</h3>
</div>

{% if team is defined and team %}
<div class="team-card">
    <div class="team-card-header">
        <div>
            <div class="team-name">{{ team.nom }}</div>
            <div class="team-role">Membre</div>
        </div>
        <span class="team-badge team-badge-active">Active</span>
    </div>

    <div class="team-divider"></div>

    <div class="team-members-label">Membres de l'équipe :</div>
    <div class="team-members-list">
        {% for member in team.membres %}
        <div class="team-member-row">
            <div class="member-avatar">
                {{ member.prenom[0]|upper }}{{ member.nom[0]|upper }}
            </div>
            <div>
                <div class="member-name">{{ member.prenom }} {{ member.nom }}</div>
                <div class="member-role">Membre</div>
            </div>
        </div>
        {% endfor %}
    </div>

    <a href="{{ path('employee_team') }}" class="team-detail-btn">
        Voir les détails de l'équipe
    </a>
</div>
{% else %}
<div class="team-card team-empty">
    <div class="empty-icon">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
            <circle cx="9" cy="7" r="4"/>
            <line x1="19" y1="8" x2="19" y2="14"/><line x1="22" y1="11" x2="16" y2="11"/>
        </svg>
    </div>
    <p>Vous n'êtes pas encore membre d'une équipe.</p>
    <a href="{{ path('employee_join_team') }}" class="btn-join-team">Rejoindre une équipe</a>
</div>
{% endif %}

{# ─── QUICK ACTIONS ─── #}
<div class="section-header mt-32">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"
         fill="none" stroke="currentColor" stroke-width="2">
        <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
    </svg>
    <h3>ACTIONS RAPIDES</h3>
</div>

<div class="quick-actions">
    <a href="{{ path('employee_tasks_new') }}" class="action-btn action-blue">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
        </svg>
        Nouvelle Tâche
    </a>
    <a href="{{ path('employee_requests_new') }}" class="action-btn action-purple">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14 2 14 8 20 8"/>
            <line x1="12" y1="18" x2="12" y2="12"/>
            <line x1="9" y1="15" x2="15" y2="15"/>
        </svg>
        Nouvelle Demande
    </a>
    <a href="{{ path('employee_chat') }}" class="action-btn action-green">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
        </svg>
        Chat Équipe
    </a>
    <a href="{{ path('employee_events') }}" class="action-btn action-orange">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"
             fill="none" stroke="currentColor" stroke-width="2">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/>
            <line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        Voir Événements
    </a>
</div>

{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
/* ===== WELCOME BANNER ===== */
.welcome-banner {
    background: linear-gradient(135deg, #3b82f6 0%, #8b5cf6 60%, #6366f1 100%);
    border-radius: var(--radius-lg);
    padding: 28px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 28px;
    overflow: hidden;
    position: relative;
}
.welcome-banner::before {
    content: '';
    position: absolute;
    top: -40%; right: -10%;
    width: 300px; height: 300px;
    background: rgba(255,255,255,0.07);
    border-radius: 50%;
}
.welcome-text h2 {
    font-size: 26px;
    font-weight: 800;
    color: #fff;
    margin-bottom: 4px;
}
.welcome-text p {
    font-size: 14px;
    color: rgba(255,255,255,0.75);
}
.welcome-illustration { opacity: 0.6; }

/* ===== SECTION HEADERS ===== */
.section-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 16px;
    color: var(--text-secondary);
}
.section-header h3 {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.2px;
    color: var(--text-secondary);
    text-transform: uppercase;
}
.mt-32 { margin-top: 36px; }

/* ===== STATS GRID ===== */
.stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 14px;
}
.stat-card {
    background: var(--card-bg);
    border-radius: var(--radius-md);
    padding: 20px 20px 0;
    border: 1px solid var(--border-color);
    overflow: hidden;
    position: relative;
    transition: transform var(--transition), box-shadow var(--transition);
}
.stat-card:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
}
.stat-card::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--bar-color, var(--accent-blue));
}
.stat-label {
    font-size: 12px;
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: 8px;
}
.stat-value {
    font-size: 28px;
    font-weight: 800;
    color: var(--text-primary);
    margin-bottom: 16px;
}
.stat-bar {
    height: 3px;
    background: var(--bar-color, var(--accent-blue));
    opacity: 0.15;
    margin: 0 -20px;
}

/* ===== TEAM CARD ===== */
.team-card {
    background: var(--card-bg);
    border-radius: var(--radius-lg);
    border: 1px solid var(--border-color);
    padding: 24px;
    box-shadow: var(--shadow-sm);
}
.team-card-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 16px;
}
.team-name {
    font-size: 17px;
    font-weight: 700;
    color: var(--text-primary);
}
.team-role {
    font-size: 12px;
    color: var(--text-secondary);
    margin-top: 3px;
}
.team-badge {
    font-size: 11px;
    font-weight: 600;
    padding: 4px 12px;
    border-radius: 20px;
}
.team-badge-active {
    background: rgba(16, 185, 129, 0.1);
    color: var(--accent-green);
}
.team-divider {
    height: 1px;
    background: var(--border-color);
    margin-bottom: 16px;
}
.team-members-label {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 12px;
}
.team-members-list { display: flex; flex-direction: column; gap: 10px; margin-bottom: 20px; }
.team-member-row {
    display: flex;
    align-items: center;
    gap: 12px;
}
.member-avatar {
    width: 36px; height: 36px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 12px; font-weight: 700; color: #fff;
    flex-shrink: 0;
}
.member-name { font-size: 13px; font-weight: 600; color: var(--text-primary); }
.member-role { font-size: 11px; color: var(--text-secondary); }
.team-detail-btn {
    display: block;
    width: 100%;
    padding: 13px;
    background: var(--accent-blue);
    color: #fff;
    text-align: center;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: all var(--transition);
    margin-top: 8px;
}
.team-detail-btn:hover { background: #2563eb; transform: translateY(-1px); }

/* Empty state */
.team-empty {
    text-align: center;
    padding: 40px;
}
.empty-icon {
    color: var(--border-color);
    margin-bottom: 16px;
    display: flex; justify-content: center;
}
.team-empty p { color: var(--text-secondary); font-size: 14px; margin-bottom: 16px; }
.btn-join-team {
    display: inline-block;
    padding: 10px 24px;
    background: var(--accent-blue);
    color: #fff;
    border-radius: var(--radius-sm);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: all var(--transition);
}
.btn-join-team:hover { background: #2563eb; }

/* ===== QUICK ACTIONS ===== */
.quick-actions {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 12px;
}
.action-btn {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    padding: 20px 12px;
    border-radius: var(--radius-md);
    text-decoration: none;
    font-size: 13px;
    font-weight: 600;
    transition: all var(--transition);
    text-align: center;
}
.action-btn:hover { transform: translateY(-3px); box-shadow: var(--shadow-md); }
.action-blue { background: rgba(59,130,246,0.08); color: var(--accent-blue); border: 1px solid rgba(59,130,246,0.15); }
.action-blue:hover { background: rgba(59,130,246,0.15); }
.action-purple { background: rgba(139,92,246,0.08); color: var(--accent-purple); border: 1px solid rgba(139,92,246,0.15); }
.action-purple:hover { background: rgba(139,92,246,0.15); }
.action-green { background: rgba(16,185,129,0.08); color: var(--accent-green); border: 1px solid rgba(16,185,129,0.15); }
.action-green:hover { background: rgba(16,185,129,0.15); }
.action-orange { background: rgba(245,158,11,0.08); color: var(--accent-orange); border: 1px solid rgba(245,158,11,0.15); }
.action-orange:hover { background: rgba(245,158,11,0.15); }

/* ===== RESPONSIVE ===== */
@media (max-width: 1024px) {
    .stats-grid { grid-template-columns: repeat(2, 1fr); }
    .quick-actions { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 640px) {
    .stats-grid { grid-template-columns: 1fr; }
    .quick-actions { grid-template-columns: repeat(2, 1fr); }
    .welcome-banner { padding: 20px; }
    .welcome-text h2 { font-size: 20px; }
}
</style>
{% endblock %}
