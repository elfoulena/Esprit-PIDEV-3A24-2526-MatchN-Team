{# templates/membre_equipe/_form.html.twig #}
<style>
.form-card { background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); box-shadow: var(--shadow-sm); overflow: hidden; max-width: 680px; }
.form-card-header { padding: 18px 26px; border-bottom: 1px solid var(--border-color); background: #f8fafc; display: flex; align-items: center; gap: 10px; }
.form-card-header h3 { font-size: 12px; font-weight: 700; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; margin: 0; }
.form-card-body { padding: 26px; }
.form-group { margin-bottom: 18px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 18px; }
.form-label { display: block; font-size: 12px; font-weight: 700; color: var(--text-primary); margin-bottom: 6px; }
.form-control { width: 100%; padding: 10px 13px; border: 1px solid var(--border-color); border-radius: var(--radius-sm); font-size: 13.5px; color: var(--text-primary); background: #fff; font-family: inherit; transition: all var(--transition); box-sizing: border-box; }
.form-control:focus { outline: none; border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(59,130,246,0.10); }
textarea.form-control { min-height: 90px; resize: vertical; }
.form-actions { display: flex; justify-content: flex-end; gap: 10px; margin-top: 24px; padding-top: 18px; border-top: 1px solid var(--border-color); }
.btn-cancel { padding: 10px 20px; background: var(--bg-surface); color: var(--text-primary); border: none; border-radius: var(--radius-sm); font-size: 13px; font-weight: 600; cursor: pointer; font-family: inherit; text-decoration: none; display: inline-flex; align-items: center; }
.btn-save { padding: 10px 22px; background: var(--accent-blue); color: #fff; border: none; border-radius: var(--radius-sm); font-size: 13px; font-weight: 700; cursor: pointer; font-family: inherit; transition: background var(--transition); }
.btn-save:hover { background: #2563eb; }
</style>

<div class="form-card">
    <div class="form-card-header">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="8.5" cy="7" r="4"/><line x1="20" y1="8" x2="20" y2="14"/><line x1="23" y1="11" x2="17" y2="11"/></svg>
        <h3>Informations du membre</h3>
    </div>
    <div class="form-card-body">

        {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.user, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.user, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.user) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.roleEquipe, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.roleEquipe, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.roleEquipe) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.dateAffectation, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateAffectation, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateAffectation) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.dateFin, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.dateFin, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.dateFin) }}
                </div>
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.tauxParticipation, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.tauxParticipation, {'attr': {'class': 'form-control', 'min': '0', 'max': '100', 'step': '0.01'}}) }}
                    {{ form_errors(form.tauxParticipation) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.statutMembre, null, {'label_attr': {'class': 'form-label'}}) }}
                    {{ form_widget(form.statutMembre, {'attr': {'class': 'form-control'}}) }}
                    {{ form_errors(form.statutMembre) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.competencesPrincipales, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.competencesPrincipales, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Java, SQL, Communication'}}) }}
                {{ form_errors(form.competencesPrincipales) }}
            </div>

            <div class="form-group">
                {{ form_label(form.notes, null, {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.notes, {'attr': {'class': 'form-control', 'placeholder': 'Remarques éventuelles...'}}) }}
                {{ form_errors(form.notes) }}
            </div>

            <div class="form-actions">
                <a href="{{ path('app_membre_equipe_index', {'id_equipe': equipe.idEquipe}) }}" class="btn-cancel">Annuler</a>
                <button type="submit" class="btn-save">{{ button_label|default('Enregistrer') }}</button>
            </div>

        {{ form_end(form) }}

    </div>
</div>