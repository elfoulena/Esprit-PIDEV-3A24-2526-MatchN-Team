{% extends 'back/base_admin.html.twig' %}

{% block title %}Envoyer rapport - {{ equipe.nomEquipe }}{% endblock %}
{% block page_title %}Envoyer le rapport par email{% endblock %}

{% block content %}
<div style="max-width: 600px; margin: 0 auto;">
    <div style="background: var(--card-bg); border: 1px solid var(--border-color); border-radius: var(--radius-lg); overflow: hidden;">
        <div style="padding: 24px; border-bottom: 1px solid var(--border-color); background: #f8fafc;">
            <h3 style="margin: 0; font-size: 18px;">📧 Envoyer le rapport PDF</h3>
            <p style="margin: 5px 0 0; font-size: 13px; color: var(--text-secondary);">Équipe : {{ equipe.nomEquipe }}</p>
        </div>
        
        <form method="post" style="padding: 24px;">
            <div style="margin-bottom: 20px;">
                <label style="display: block; font-weight: 600; margin-bottom: 8px; font-size: 13px;">Adresse email du destinataire</label>
                <input type="email" name="email" required 
                       value="{{ admin_email }}"
                       style="width: 100%; padding: 10px 14px; border: 1px solid var(--border-color); border-radius: 8px; font-size: 14px;">
                <p style="font-size: 12px; color: var(--text-secondary); margin-top: 5px;">Le rapport PDF sera joint à l'email.</p>
            </div>
            
            <div style="background: #eff6ff; padding: 15px; border-radius: 8px; margin-bottom: 20px;">
                <p style="margin: 0 0 10px; font-size: 13px; font-weight: 600;">📄 Contenu du rapport :</p>
                <ul style="margin: 0; padding-left: 20px; font-size: 13px;">
                    <li>Informations générales de l'équipe</li>
                    <li>Statistiques (membres, budget)</li>
                    <li>Liste des membres</li>
                    <li>Date de génération</li>
                </ul>
            </div>
            
            <div style="display: flex; gap: 10px; justify-content: flex-end;">
                <a href="{{ path('app_equipe_show', {'id_equipe': equipe.idEquipe}) }}" 
                   style="padding: 10px 20px; background: #e2e8f0; color: #475569; text-decoration: none; border-radius: 8px; font-size: 13px; font-weight: 600;">Annuler</a>
                <button type="submit" 
                        style="padding: 10px 24px; background: #3b82f6; color: white; border: none; border-radius: 8px; font-size: 13px; font-weight: 600; cursor: pointer;">
                    📧 Envoyer le rapport
                </button>
            </div>
        </form>
    </div>
</div>
{% endblock %}