{% extends 'back/base_admin.html.twig' %}

{% block title %}Nouvel Événement — MatchNTeam{% endblock %}
{% block page_title %}Gestion des Événements{% endblock %}

{% block content %}
    <div class="page-header" style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <div>
            <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Nouvel Événement</h2>
