{# templates/admin/competences/edit.html.twig #}
{% extends 'back/base_admin.html.twig' %}
{% block title %}Modifier — {{ competence.nomCompetence }}{% endblock %}
{% block page_title %}Modifier une compétence{% endblock %}

{% block extra_styles %}
.form-card { background:var(--card-bg); border:1px solid var(--border-color); border-radius:var(--radius-lg); box-shadow:var(--shadow-sm); padding:32px 36px; max-width:580px; }
.form-card-header { margin-bottom:28px; }
.form-card-header h3 { font-size:17px; font-weight:800; margin-bottom:5px; }
.form-card-header p { font-size:13px; color:var(--text-secondary); }
.form-group { margin-bottom:22px; }
.form-group label { display:block; font-size:11px; font-weight:700; color:var(--text-secondary); text-transform:uppercase; letter-spacing:0.6px; margin-bottom:7px; }
.form-group label .req { color:var(--accent-red); margin-left:2px; }
.form-control { width:100%; padding:10px 14px; border:1.5px solid var(--border-color); border-radius:var(--radius-sm); font-size:13.5px; font-family:inherit; background:var(--card-bg); color:var(--text-primary); outline:none; transition:border-color var(--transition), box-shadow var(--transition); }
.form-control:focus { border-color:var(--accent-blue); box-shadow:0 0 0 3px rgba(59,130,246,0.1); }
textarea.form-control { resize:vertical; min-height:90px; }
.form-group.has-error .form-control { border-color:var(--accent-red); background:rgba(239,68,68,0.03); }
.form-group.has-error .form-control:focus { border-color:var(--accent-red); box-shadow:0 0 0 3px rgba(239,68,68,0.12); }
.field-error { display:flex; align-items:center; gap:5px; font-size:12px; color:#dc2626; font-weight:600; margin-top:6px; }
.field-error svg { flex-shrink:0; }
.type-cards { display:grid; grid-template-columns:1fr 1fr; gap:10px; margin-top:4px; }
.type-card { position:relative; cursor:pointer; list-style:none; }
.type-card input[type=radio] { position:absolute; opacity:0; width:0; height:0; }
.type-card-label { display:flex; flex-direction:column; gap:4px; padding:14px 16px; border:1.5px solid var(--border-color); border-radius:var(--radius-md); cursor:pointer; transition:all var(--transition); }
.type-card input[type=radio]:checked + .type-card-label { border-color:var(--accent-blue); background:rgba(59,130,246,0.05); }
.type-card-label:hover { border-color:#94a3b8; }
.type-card-name { font-size:13.5px; font-weight:700; color:var(--text-primary); }
.type-card-desc { font-size:11.5px; color:var(--text-secondary); }
.type-card-icon { font-size:20px; margin-bottom:4px; }
.form-group.has-error .type-card-label { border-color:rgba(239,68,68,0.4); }
.form-actions { display:flex; gap:12px; align-items:center; margin-top:28px; padding-top:20px; border-top:1px solid var(--border-color); }
.btn-submit { padding:11px 28px; background:linear-gradient(135deg,var(--accent-blue),var(--accent-purple)); color:#fff; border:none; border-radius:var(--radius-md); font-size:13.5px; font-weight:700; cursor:pointer; font-family:inherit; transition:opacity var(--transition); }
.btn-submit:hover { opacity:0.88; }
.btn-cancel { padding:11px 20px; background:var(--bg-surface); color:var(--text-secondary); border:1px solid var(--border-color); border-radius:var(--radius-md); font-size:13.5px; font-weight:600; text-decoration:none; transition:all var(--transition); }
.btn-cancel:hover { background:var(--border-color); }
{% endblock %}

{% block content %}
{% set typeInfo = {
    'Hard skill': {icon: '⚙️', desc: 'Compétence technique mesurable (code, outil, langue…)'},
    'Soft skill': {icon: '🤝', desc: 'Compétence comportementale et interpersonnelle'},
    'Langue':     {icon: '🌐', desc: 'Maîtrise d\'une langue étrangère'},
    'Outil':      {icon: '🛠️', desc: 'Maîtrise d\'un logiciel ou d\'une plateforme'}
} %}

<div style="margin-bottom:20px;">
    <a href="{{ path('admin_competences_index') }}" style="color:var(--text-secondary); text-decoration:none; font-size:13px; font-weight:600; display:inline-flex; align-items:center; gap:6px;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        Retour aux compétences
    </a>
</div>

<div class="form-card">
    <div class="form-card-header">
        <h3>Modifier la compétence</h3>
        <p>Modification de <strong>{{ competence.nomCompetence }}</strong>.</p>
    </div>

    {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

        <div class="form-group {{ form.nomCompetence.vars.errors|length > 0 ? 'has-error' : '' }}">
            <label>Nom de la compétence <span class="req">*</span></label>
            {{ form_widget(form.nomCompetence, {attr: {class: 'form-control'}}) }}
            {% for error in form.nomCompetence.vars.errors %}
                <div class="field-error">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group {{ form.type.vars.errors|length > 0 ? 'has-error' : '' }}">
            <label>Type de compétence <span class="req">*</span></label>
            <div class="type-cards">
                {% for radio in form.type %}
                    <label class="type-card">
                        {{ form_widget(radio) }}
                        <div class="type-card-label">
                            <div class="type-card-icon">{{ typeInfo[radio.vars.value].icon }}</div>
                            <div class="type-card-name">{{ radio.vars.label }}</div>
                            <div class="type-card-desc">{{ typeInfo[radio.vars.value].desc }}</div>
                        </div>
                    </label>
                {% endfor %}
            </div>
            {% for error in form.type.vars.errors %}
                <div class="field-error" style="margin-top:8px;">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                    {{ error.message }}
                </div>
            {% endfor %}
        </div>

        <div class="form-group">
            <label>Description <span style="font-size:10px; color:var(--text-secondary); font-weight:400; text-transform:none;">(optionnel)</span></label>
            {{ form_widget(form.descriptionCompetence, {attr: {class: 'form-control'}}) }}
        </div>

        <div class="form-actions">
            <button type="submit" class="btn-submit">Enregistrer les modifications</button>
            <a href="{{ path('admin_competences_index') }}" class="btn-cancel">Annuler</a>
        </div>

    {{ form_end(form) }}
</div>
{% endblock %}
