{# templates/evaluation/new.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Nouvelle Évaluation — MatchNTeam{% endblock %}
{% block page_title %}Nouvelle Évaluation{% endblock %}

{% block content %}

<div style="margin-bottom: 20px; display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text-secondary);">
    <a href="{{ path('app_evaluation_index') }}" style="color: var(--text-secondary); text-decoration: none;">Évaluations</a>
    <span>/</span>
    <span style="color: var(--text-primary); font-weight: 600;">Nouvelle évaluation</span>
</div>

<div style="margin-bottom: 22px;">
    <h2 style="font-size: 20px; font-weight: 800; color: var(--text-primary);">Créer une évaluation</h2>
    <p style="font-size: 13px; color: var(--text-secondary); margin-top: 3px;">Évaluez la performance d'un freelancer sur une affectation.</p>
</div>

{% include 'evaluation/_form.html.twig' %}

{% endblock %}
