<style>
.custom-form-container {
    background: #ffffff;
    border-radius: 12px;
    box-shadow: 0 4px 16px rgba(0,0,0,0.04);
    padding: 30px;
    max-width: 600px;
    margin: 0 auto 30px auto;
}
.custom-form-header {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    font-weight: 700;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid #f1f5f9;
}
.form-group {
    margin-bottom: 20px;
}
.form-row {
    display: flex;
    gap: 20px;
}
.form-col {
    flex: 1;
}
.form-label {
    display: block;
    font-size: 13px;
    font-weight: 700;
    color: #334155;
    margin-bottom: 8px;
}
.form-control {
    width: 100%;
    padding: 10px 14px;
    border: 1px solid #cbd5e1;
    border-radius: 6px;
    font-size: 14px;
    color: #1e293b;
    transition: all 0.2s;
    background: #fff;
    font-family: inherit;
}
.form-control:focus {
    outline: none;
    border-color: #3ba3e8;
    box-shadow: 0 0 0 3px rgba(59,163,232,0.1);
}
textarea.form-control {
    min-height: 100px;
    resize: vertical;
}
.form-actions {
    display: flex;
    justify-content: flex-end;
    gap: 12px;
    margin-top: 30px;
}
.btn-reset {
    padding: 10px 24px;
    background: #f1f5f9;
    color: #334155;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
}
.btn-reset:hover { background: #e2e8f0; }
.btn-submit {
    padding: 10px 24px;
    background: #3ba3e8; 
    color: #ffffff;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 14px;
    cursor: pointer;
    transition: background 0.2s;
}
.btn-submit:hover { background: #2980b9; }

/* Remove default symfony help/errors raw output styling */
.invalid-feedback { color: #ef4444; font-size: 12px; margin-top: 4px; font-weight: 500; }
/* AI Button Styling */
.ai-improve-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    background: linear-gradient(135deg, #8b5cf6, #6d28d9);
    color: #fff;
    border: none;
    border-radius: 6px;
    font-size: 11px;
    font-weight: 700;
    cursor: pointer;
    transition: all 0.3s ease;
    box-shadow: 0 2px 8px rgba(109,40,217,0.25);
    margin-bottom: 8px;
    text-transform: uppercase;
}
.ai-improve-btn:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(109,40,217,0.35);
    filter: brightness(1.1);
}
.ai-improve-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    background: #94a3b8;
}
.ai-improve-btn .sparkle-icon { width: 14px; height: 14px; }

@keyframes spin {
    from { transform: rotate(0deg); }
    to { transform: rotate(360deg); }
}
.loading-spinner {
    animation: spin 1s linear infinite;
}
</style>

<div class="custom-form-container">
    <div class="custom-form-header">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#64748b" stroke-width="2" style="flex-shrink:0;">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
            <line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/>
            <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
        DÉTAILS DE L'ÉVÉNEMENT
    </div>

    {{ form_start(form, {'attr': {'id': 'evenement_form', 'novalidate': 'novalidate'}}) }}
        
        <div class="form-group">
            {{ form_label(form.titre, 'Titre *', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.titre, {'attr': {'class': 'form-control', 'placeholder': 'Nom de l\'événement'}}) }}
            {{ form_errors(form.titre) }}
        </div>

        <div class="form-group">
            {{ form_label(form.type_evenement, 'Type d\'événement', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.type_evenement, {'attr': {'class': 'form-control'}}) }}
            {{ form_errors(form.type_evenement) }}
        </div>

        <div class="form-row">
            <div class="form-group form-col">
                {{ form_label(form.date_debut, 'Date Début', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.date_debut, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.date_debut) }}
            </div>
            <div class="form-group form-col">
                {{ form_label(form.date_fin, 'Date Fin', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.date_fin, {'attr': {'class': 'form-control'}}) }}
                {{ form_errors(form.date_fin) }}
            </div>
        </div>

        <div class="form-group">
            {{ form_label(form.date_deadline, 'Deadline Inscription', {'label_attr': {'class': 'form-label'}}) }}
            {{ form_widget(form.date_deadline, {'attr': {'class': 'form-control', 'placeholder': 'Dernier délai'}}) }}
            {{ form_errors(form.date_deadline) }}
        </div>

        <div class="form-row">
            <div class="form-group form-col">
                {{ form_label(form.capacite_max, 'Capacité Max', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.capacite_max, {'attr': {'class': 'form-control', 'placeholder': 'Ex: 50'}}) }}
                {{ form_errors(form.capacite_max) }}
            </div>
            <div class="form-group form-col">
                {{ form_label(form.lieu, 'Lieu', {'label_attr': {'class': 'form-label'}}) }}
                {{ form_widget(form.lieu, {'attr': {'class': 'form-control', 'placeholder': 'Ex: Tunis, Salle A'}}) }}
                {{ form_errors(form.lieu) }}
            </div>
        </div>

        <div class="form-group">
            <div style="display: flex; justify-content: space-between; align-items: flex-end;">
                {{ form_label(form.description, 'Description', {'label_attr': {'class': 'form-label'}}) }}
                <button type="button" id="btn-ai-improve" class="ai-improve-btn" title="Améliorer la description avec l'IA">
                    <svg class="sparkle-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 3l1.912 5.813a2 2 0 001.275 1.275L21 12l-5.813 1.912a2 2 0 00-1.275 1.275L12 21l-1.912-5.813a2 2 0 00-1.275-1.275L3 12l5.813-1.912a2 2 0 001.275-1.275L12 3z"/></svg>
                    <span>Améliorer avec l'IA</span>
                </button>
            </div>
            {{ form_widget(form.description, {'attr': {'class': 'form-control', 'placeholder': 'Décrivez l\'événement...'}}) }}
            {{ form_errors(form.description) }}
        </div>

        <div class="form-actions">
            <button type="reset" class="btn-reset" onclick="resetErrors()">Réinitialiser</button>
            <button type="submit" class="btn-submit">{{ button_label|default('Enregistrer') }}</button>
        </div>

    {{ form_end(form) }}
</div>

<style>
.form-control.is-invalid { border-color: #ef4444; box-shadow: 0 0 0 3px rgba(239,68,68,0.1); }
.form-control.is-valid   { border-color: #10b981; box-shadow: 0 0 0 3px rgba(16,185,129,0.1); }
.field-error { color: #ef4444; font-size: 12px; font-weight: 600; margin-top: 5px; display: block; }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
    const form = document.getElementById('evenement_form');
    if (!form) return;

    function getField(name) {
        return form.querySelector('[id$="_' + name + '"]') || form.querySelector('[name$="[' + name + ']"]');
    }

    function showError(field, msg) {
        field.classList.add('is-invalid');
        field.classList.remove('is-valid');
        let err = field.parentNode.querySelector('.field-error');
        if (!err) {
            err = document.createElement('span');
            err.className = 'field-error';
            field.parentNode.appendChild(err);
        }
        err.textContent = msg;
    }

    function clearError(field) {
        field.classList.remove('is-invalid');
        field.classList.add('is-valid');
        const err = field.parentNode.querySelector('.field-error');
        if (err) err.remove();
    }

    function validateField(field) {
        if (!field) return true;
        const val = field.value.trim();
        const name = field.id || '';

        if (field.hasAttribute('required') || field.closest('.form-group')) {
            // Titre
            if (name.includes('titre')) {
                if (!val) { showError(field, 'Le titre est obligatoire.'); return false; }
                if (val.length < 3) { showError(field, 'Minimum 3 caractères.'); return false; }
                if (val.length > 100) { showError(field, 'Maximum 100 caractères.'); return false; }
            }
            // Lieu
            if (name.includes('lieu')) {
                if (!val) { showError(field, 'Le lieu est obligatoire.'); return false; }
                if (val.length < 2) { showError(field, 'Minimum 2 caractères.'); return false; }
            }
            // Capacité
            if (name.includes('capacite_max')) {
                if (!val) { showError(field, 'La capacité est obligatoire.'); return false; }
                if (parseInt(val) < 1) { showError(field, 'La capacité doit être positive.'); return false; }
                if (parseInt(val) > 10000) { showError(field, 'Maximum 10 000 participants.'); return false; }
            }
            // date_debut
            if (name.includes('date_debut') && val) {
                const today = new Date(); today.setHours(0,0,0,0);
                if (new Date(val) < today) { showError(field, 'La date de début doit être aujourd\'hui ou dans le futur.'); return false; }
            }
        }
        clearError(field);
        return true;
    }

    // Validate dates cross-fields
    function validateDates() {
        const debut  = getField('date_debut');
        const fin    = getField('date_fin');
        const ddl    = getField('date_deadline');
        let ok = true;

        if (debut && fin && debut.value && fin.value) {
            if (new Date(fin.value) <= new Date(debut.value)) {
                showError(fin, 'La date de fin doit être après la date de début.');
                ok = false;
            } else { clearError(fin); }
        }
        if (debut && ddl && debut.value && ddl.value) {
            if (new Date(ddl.value) > new Date(debut.value)) {
                showError(ddl, 'La deadline doit être avant ou égale à la date de début.');
                ok = false;
            } else { clearError(ddl); }
        }
        return ok;
    }

    // Live validation on blur
    form.querySelectorAll('.form-control').forEach(function(field) {
        field.addEventListener('blur', function() { validateField(field); });
        field.addEventListener('input', function() {
            if (field.classList.contains('is-invalid')) validateField(field);
        });
    });

    // On submit
    form.addEventListener('submit', function(e) {
        let valid = true;
        form.querySelectorAll('.form-control').forEach(function(f) {
            if (!validateField(f)) valid = false;
        });
        if (!validateDates()) valid = false;

        const titre = getField('titre');
        if (titre && !titre.value.trim()) { showError(titre, 'Le titre est obligatoire.'); valid = false; }

        const lieu = getField('lieu');
        if (lieu && !lieu.value.trim()) { showError(lieu, 'Le lieu est obligatoire.'); valid = false; }

        const cap = getField('capacite_max');
        if (cap && !cap.value.trim()) { showError(cap, 'La capacité est obligatoire.'); valid = false; }

        const debut = getField('date_debut');
        if (debut && !debut.value) { showError(debut, 'La date de début est obligatoire.'); valid = false; }

        const fin = getField('date_fin');
        if (fin && !fin.value) { showError(fin, 'La date de fin est obligatoire.'); valid = false; }

        const ddl = getField('date_deadline');
        if (ddl && !ddl.value) { showError(ddl, 'La deadline est obligatoire.'); valid = false; }

        if (!valid) e.preventDefault();
    });

    // ── AI Improvement Logic ──
    const aiBtn = document.getElementById('btn-ai-improve');
    const descField = getField('description');

    if (aiBtn && descField) {
        aiBtn.addEventListener('click', async function() {
            const originalText = descField.value.trim();
            if (!originalText) {
                alert('Veuillez saisir un début de texte pour que l\'IA puisse l\'améliorer.');
                return;
            }

            const originalBtnContent = aiBtn.innerHTML;
            aiBtn.disabled = true;
            aiBtn.innerHTML = `
                <svg class="sparkle-icon loading-spinner" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83"/></svg>
                <span>Analyse en cours...</span>
            `;

            try {
                const response = await fetch('{{ path("app_evenement_ai_improve") }}', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text: originalText })
                });

                if (!response.ok) throw new Error('Erreur API');

                const data = await response.json();
                
                // Animating text change
                descField.style.transition = 'opacity 0.3s ease';
                descField.style.opacity = '0.4';
                
                setTimeout(() => {
                    descField.value = data.improved_text;
                    descField.style.opacity = '1';
                }, 300);

            } catch (err) {
                console.error(err);
                alert('Désolé, l\'amélioration par IA a échoué. Vérifiez votre clé API dans le .env');
            } finally {
                aiBtn.disabled = false;
                aiBtn.innerHTML = originalBtnContent;
            }
        });
    }
});

function resetErrors() {
    document.querySelectorAll('.form-control').forEach(function(f) {
        f.classList.remove('is-invalid', 'is-valid');
    });
    document.querySelectorAll('.field-error').forEach(function(e) { e.remove(); });
}
</script>

