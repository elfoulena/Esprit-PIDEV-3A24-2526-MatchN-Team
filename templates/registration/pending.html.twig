{# templates/registration/pending.html.twig #}
{% extends 'base.html.twig' %}

{% block body_class %}no-nav{% endblock %}

{% block title %}Vérifiez votre email{% endblock %}

{% block stylesheets %}
<style>
    .verify-wrapper {
        min-height: 100vh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #f5f4f0;
        padding: 2rem 1rem;
    }
    .verify-card {
        background: #fff;
        border: 0.5px solid #ddd;
        border-radius: 16px;
        padding: 2.5rem;
        width: 100%;
        max-width: 440px;
        text-align: center;
    }
    .verify-icon {
        width: 56px;
        height: 56px;
        background: #e1f5ee;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto 1.5rem;
        font-size: 24px;
    }
    .verify-title {
        font-size: 22px;
        font-weight: 500;
        color: #1a1a1a;
        font-family: Georgia, serif;
        margin: 0 0 0.5rem;
    }
    .verify-sub {
        font-size: 14px;
        color: #888;
        margin: 0 0 2rem;
        line-height: 1.6;
    }
    .verify-email-badge {
        display: inline-block;
        background: #f5f4f0;
        color: #444;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 13px;
        font-weight: 500;
        margin-bottom: 2rem;
    }
    .form-group {
        margin-bottom: 1rem;
        text-align: left;
    }
    .form-group label {
        display: block;
        font-size: 13px;
        font-weight: 500;
        color: #444;
        margin-bottom: 5px;
    }
    .code-input {
        width: 100%;
        padding: 12px;
        border: 0.5px solid #ccc;
        border-radius: 8px;
        font-size: 22px;
        font-weight: 500;
        text-align: center;
        letter-spacing: 8px;
        color: #1a1a1a;
        box-sizing: border-box;
        transition: border-color 0.15s;
        font-family: monospace;
    }
    .code-input:focus {
        outline: none;
        border-color: #1d9e75;
        box-shadow: 0 0 0 3px rgba(29,158,117,0.1);
    }
    .btn-verify {
        width: 100%;
        padding: 12px;
        background: #1d9e75;
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 500;
        cursor: pointer;
        transition: background 0.15s;
        font-family: inherit;
    }
    .btn-verify:hover { background: #0f6e56; }
    .divider {
        border: none;
        border-top: 0.5px solid #eee;
        margin: 1.5rem 0;
    }
    .resend-text {
        font-size: 13px;
        color: #888;
    }
    .resend-link {
        color: #1d9e75;
        text-decoration: none;
        font-weight: 500;
    }
    .resend-link:hover { text-decoration: underline; }
    .flash-error {
        background: #fcebeb;
        border: 0.5px solid #f09595;
        color: #791f1f;
        border-radius: 8px;
        padding: 10px 14px;
        font-size: 13px;
        margin-bottom: 1.5rem;
        text-align: left;
    }
</style>
{% endblock %}

{% block body %}
<div class="verify-wrapper">
    <div class="verify-card">

        <div class="verify-icon">✉</div>

        <h1 class="verify-title">Vérifiez votre email</h1>
        <p class="verify-sub">
            Un code de vérification à 6 chiffres a été envoyé à
        </p>

        <span class="verify-email-badge">{{ email }}</span>

        {% for msg in app.flashes('error') %}
            <div class="flash-error">{{ msg }}</div>
        {% endfor %}

        {# Formulaire de saisie du code #}
        <form method="post" action="{{ path('app_verify_email') }}">
            <input type="hidden" name="email" value="{{ email }}">

            <div class="form-group">
                <label for="code">Code de vérification</label>
                <input
                    type="text"
                    id="code"
                    name="code"
                    class="code-input"
                    maxlength="6"
                    placeholder="000000"
                    autocomplete="one-time-code"
                    required
                    autofocus
                >
            </div>

            <button type="submit" class="btn-verify">Vérifier mon compte</button>
        </form>

        <hr class="divider">

    

    </div>
</div>
{% endblock %}