<!DOCTYPE html>
<html>
<head>
    <meta charset="UTF-8">
    <title>Liste des Équipes</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: 'Helvetica', 'Arial', sans-serif;
            font-size: 11px;
            line-height: 1.4;
            color: #1e293b;
            padding: 20px;
        }
        
        .header {
            text-align: center;
            margin-bottom: 25px;
            padding-bottom: 15px;
            border-bottom: 2px solid #3b82f6;
        }
        
        .logo {
            font-size: 22px;
            font-weight: bold;
            color: #3b82f6;
            margin-bottom: 5px;
        }
        
        .title {
            font-size: 16px;
            font-weight: bold;
            margin: 8px 0;
        }
        
        .filters {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 6px;
            padding: 10px 15px;
            margin-bottom: 20px;
            font-size: 10px;
        }
        
        .filters-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
            margin-top: 5px;
        }
        
        .filter-item {
            background: #e2e8f0;
            padding: 3px 8px;
            border-radius: 12px;
        }
        
        .stats {
            margin-bottom: 20px;
            padding: 10px 15px;
            background: #eff6ff;
            border-radius: 6px;
            font-size: 12px;
        }
        
        .equipes-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }
        
        .equipes-table th,
        .equipes-table td {
            padding: 10px 8px;
            text-align: left;
            border-bottom: 1px solid #e2e8f0;
        }
        
        .equipes-table th {
            background: #f1f5f9;
            font-weight: bold;
            color: #64748b;
            font-size: 10px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }
        
        .equipes-table tr:hover {
            background: #f8fafc;
        }
        
        .badge {
            display: inline-block;
            padding: 3px 8px;
            border-radius: 20px;
            font-size: 9px;
            font-weight: bold;
        }
        
        .badge-active { background: #10b98120; color: #059669; }
        .badge-paused { background: #f59e0b20; color: #b45309; }
        .badge-inactive { background: #ef444420; color: #dc2626; }
        
        .team-avatar {
            width: 28px;
            height: 28px;
            border-radius: 6px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            font-weight: bold;
            margin-right: 8px;
        }
        
        .progress-bar {
            width: 50px;
            background: #e2e8f0;
            border-radius: 3px;
            height: 4px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 4px;
            background: #3b82f6;
            border-radius: 3px;
        }
        
        .footer {
            margin-top: 25px;
            padding-top: 15px;
            border-top: 1px solid #e2e8f0;
            text-align: center;
            font-size: 9px;
            color: #94a3b8;
        }
        
        .page-break {
            page-break-before: always;
        }
    </style>
</head>
<body>

<div class="header">
    <div class="logo">MatchNTeam</div>
    <div class="title">Liste des équipes</div>
    <div style="font-size: 10px; color: #64748b;">Généré le {{ generated_at|date('d/m/Y à H:i') }}</div>
</div>

{% if filters.search or filters.statut or filters.departement %}
<div class="filters">
    <strong>Filtres appliqués :</strong>
    <div class="filters-grid">
        {% if filters.search %}
            <span class="filter-item">🔍 Recherche : {{ filters.search }}</span>
        {% endif %}
        {% if filters.statut %}
            <span class="filter-item">📊 Statut : {{ filters.statut }}</span>
        {% endif %}
        {% if filters.departement %}
            <span class="filter-item">🏢 Département : {{ filters.departement }}</span>
        {% endif %}
        <span class="filter-item">📋 Tri : {{ filters.sortBy }} ({{ filters.sortDir == 'ASC' ? 'Croissant' : 'Décroissant' }})</span>
    </div>
</div>
{% endif %}

<div class="stats">
    📊 {{ total }} équipe(s) trouvée(s)
</div>

<table class="equipes-table">
    <thead>
        <tr>
            <th>Équipe</th>
            <th>Département</th>
            <th>Membres</th>
            <th>Budget</th>
            <th>Date création</th>
            <th>Statut</th>
        </tr>
    </thead>
    <tbody>
        {% for equipe in equipes %}
        <tr>
            <td>
                <div style="display: flex; align-items: center;">
                    <div class="team-avatar" style="background: {{ equipe.couleurEquipe }}22; color: {{ equipe.couleurEquipe }};">
                        {{ equipe.nomEquipe|slice(0,1)|upper }}
                    </div>
                    {{ equipe.nomEquipe }}
                </div>
            </td>
            <td>{{ equipe.departement ?? '—' }}</td>
            <td>
                {{ equipe.nbMembresActuel }} / {{ equipe.nbMembresMax }}
                <div class="progress-bar" style="margin-top: 4px;">
                    {% set pct = equipe.nbMembresMax > 0 ? ((equipe.nbMembresActuel / equipe.nbMembresMax) * 100)|round : 0 %}
                    <div class="progress-fill" style="width: {{ pct > 100 ? 100 : pct }}%;"></div>
                </div>
            </td>
            <td>{{ equipe.budget ? equipe.budget ~ ' DT' : '—' }}</td>
            <td>{{ equipe.dateCreation ? equipe.dateCreation|date('d/m/Y') : '—' }}</td>
            <td>
                {% if equipe.statut == 'Active' %}
                    <span class="badge badge-active">Active</span>
                {% elseif equipe.statut == 'En pause' %}
                    <span class="badge badge-paused">En pause</span>
                {% else %}
                    <span class="badge badge-inactive">Inactive</span>
                {% endif %}
            </td>
        </tr>
        {% else %}
        <tr>
            <td colspan="6" style="text-align: center; padding: 40px;">
                Aucune équipe trouvée
            </td>
        </tr>
        {% endfor %}
    </tbody>
</table>

<div class="footer">
    <p>MatchNTeam - Gestion d'équipes professionnelle</p>
    <p>Document généré automatiquement - {{ generated_at|date('d/m/Y') }}</p>
</div>

</body>
</html>