{# templates/admin/users/index.html.twig #}
{% extends 'back/base_admin.html.twig' %}

{% block title %}Gestion des utilisateurs — MatchNTeam{% endblock %}
{% block page_title %}Gestion des utilisateurs{% endblock %}

{% block extra_styles %}
.page-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 24px;
}
.page-header h2 {
    font-size: 20px;
    font-weight: 800;
    color: var(--text-primary);
}
.btn-primary {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 10px 20px;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    color: #fff;
    border-radius: var(--radius-md);
    font-size: 13px;
    font-weight: 700;
    text-decoration: none;
    transition: opacity var(--transition);
}
.btn-primary:hover { opacity: 0.88; }
.btn-primary svg { width: 16px; height: 16px; }

.filters {
    display: flex;
    gap: 10px;
    margin-bottom: 20px;
    flex-wrap: wrap;
}
.filter-btn {
    padding: 6px 16px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 700;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: all var(--transition);
    background: var(--bg-surface);
    color: var(--text-secondary);
}
.filter-btn.active, .filter-btn:hover {
    background: var(--accent-blue);
    color: #fff;
}

.data-card {
    background: var(--card-bg);
    border: 1px solid var(--border-color);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    overflow: hidden;
}
.data-table { width: 100%; border-collapse: collapse; }
.data-table thead th {
    padding: 12px 20px;
    text-align: left;
    font-size: 11px; font-weight: 700;
    color: var(--text-secondary);
    text-transform: uppercase; letter-spacing: 0.8px;
    background: #f8fafc;
    border-bottom: 1px solid var(--border-color);
}
.data-table tbody td {
    padding: 14px 20px;
    font-size: 13.5px;
    border-bottom: 1px solid var(--border-color);
    color: var(--text-primary);
    vertical-align: middle;
}
.data-table tbody tr:last-child td { border-bottom: none; }
.data-table tbody tr:hover { background: #f8fafc; }

.avatar-sm {
    width: 32px; height: 32px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
    display: inline-flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 800; color: #fff;
    flex-shrink: 0;
}

.badge {
    display: inline-flex;
    align-items: center;
    padding: 3px 10px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 700;
    white-space: nowrap;
}
.badge-admin      { background: rgba(139,92,246,0.12); color: #7c3aed; }
.badge-employe    { background: rgba(16,185,129,0.12); color: #059669; }
.badge-freelancer { background: rgba(245,158,11,0.12); color: #d97706; }

.status-dot {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 3px 10px; border-radius: 20px; font-size: 11px; font-weight: 700;
}
.status-dot.active   { background: rgba(16,185,129,0.12); color: #059669; }
.status-dot.inactive { background: rgba(239,68,68,0.10); color: #dc2626; }
.status-dot.pending  { background: rgba(245,158,11,0.12); color: #d97706; }

.actions { display: flex; gap: 6px; align-items: center; }
.action-btn {
    display: inline-flex; align-items: center; justify-content: center;
    width: 30px; height: 30px;
    border-radius: var(--radius-sm);
    border: none; cursor: pointer;
    text-decoration: none;
    transition: all var(--transition);
    font-size: 12px;
}
.action-btn.view   { background: rgba(59,130,246,0.10); color: var(--accent-blue); }
.action-btn.edit   { background: rgba(245,158,11,0.10); color: #d97706; }
.action-btn.toggle { background: rgba(16,185,129,0.10); color: #059669; }
.action-btn.toggle.off { background: rgba(239,68,68,0.10); color: #dc2626; }
.action-btn.delete { background: rgba(239,68,68,0.10); color: #dc2626; }
.action-btn:hover  { filter: brightness(0.88); }
.action-btn svg    { width: 14px; height: 14px; }

.empty-state {
    text-align: center;
    padding: 48px 24px;
    color: var(--text-secondary);
    font-size: 14px;
}
{% endblock %}

{% block content %}

<div class="page-header">
    <h2>
        Utilisateurs
        <span style="font-size:13px; font-weight:600; color:var(--text-secondary); margin-left:8px;">{{ users|length }} au total</span>
    </h2>
    <a href="{{ path('admin_users_new_employe') }}" class="btn-primary">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        Créer un compte Employé
    </a>
</div>

<div class="data-card">
    <table class="data-table">
        <thead>
            <tr>
                <th>Utilisateur</th>
                <th>Email</th>
                <th>Rôle</th>
                <th>Statut</th>
                <th>Vérifié</th>
                <th>Créé le</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for user in users %}
            <tr>
                <td>
                    <div style="display:flex; align-items:center; gap:10px;">
                        <div class="avatar-sm">
                            {{ (user.nom|slice(0,1) ~ user.prenom|slice(0,1))|upper }}
                        </div>
                        <div>
                            <div style="font-weight:700;">{{ user.nom }} {{ user.prenom }}</div>
                            {% if user.telephone %}
                                <div style="font-size:11px; color:var(--text-secondary);">{{ user.telephone }}</div>
                            {% endif %}
                        </div>
                    </div>
                </td>
                <td style="color:var(--text-secondary); font-size:12.5px;">{{ user.email }}</td>
                <td>
                    {% if user.role.value == 'ADMIN_RH' %}
                        <span class="badge badge-admin">Administrateur</span>
                    {% elseif user.role.value == 'EMPLOYE' %}
                        <span class="badge badge-employe">Employé</span>
                    {% else %}
                        <span class="badge badge-freelancer">Freelancer</span>
                    {% endif %}
                </td>
                <td>
                    <span class="status-dot {{ user.actif ? 'active' : 'inactive' }}">
                        ● {{ user.actif ? 'Actif' : 'Inactif' }}
                    </span>
                </td>
                <td>
                    {% if user.verified %}
                        <span class="status-dot active">✓ Vérifié</span>
                    {% elseif user.role.value == 'ADMIN_RH' %}
                        <span class="status-dot active">✓ Admin</span>
                    {% else %}
                        <span class="status-dot pending">⏳ En attente</span>
                    {% endif %}
                </td>
                <td style="font-size:12px; color:var(--text-secondary);">
                    {{ user.createdAt ? user.createdAt|date('d/m/Y') : '—' }}
                </td>
                <td>
                    <div class="actions">
                        <a href="{{ path('admin_users_show', {'id': user.id}) }}" class="action-btn view" title="Voir">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </a>
                        <a href="{{ path('admin_users_edit', {'id': user.id}) }}" class="action-btn edit" title="Modifier">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        </a>
                        <form method="post" action="{{ path('admin_users_toggle', {'id': user.id}) }}" style="margin:0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('toggle_user_' ~ user.id) }}">
                            <button type="submit" class="action-btn toggle {{ user.actif ? 'off' : '' }}" title="{{ user.actif ? 'Désactiver' : 'Activer' }}">
                                {% if user.actif %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="16" cy="12" r="3" fill="currentColor" stroke="none"/></svg>
                                {% else %}
                                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="1" y="5" width="22" height="14" rx="7"/><circle cx="8" cy="12" r="3" fill="currentColor" stroke="none"/></svg>
                                {% endif %}
                            </button>
                        </form>
                        {% if not user.verified and user.role.value != 'ADMIN_RH' %}
                        <form method="post" action="{{ path('admin_users_resend_code', {'id': user.id}) }}" style="margin:0;">
                            <input type="hidden" name="_token" value="{{ csrf_token('resend_' ~ user.id) }}">
                            <button type="submit" class="action-btn view" title="Renvoyer le code" style="background:rgba(16,185,129,0.10); color:#059669;">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="1 4 1 10 7 10"/><path d="M3.51 15a9 9 0 1 0 .49-3"/></svg>
                            </button>
                        </form>
                        {% endif %}
                        {% if user != app.user %}
                        <form method="post" action="{{ path('admin_users_delete', {'id': user.id}) }}" style="margin:0;"
                              onsubmit="return confirm('Supprimer {{ user.nom }} {{ user.prenom }} ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete_user_' ~ user.id) }}">
                            <button type="submit" class="action-btn delete" title="Supprimer">
                                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4h6v2"/></svg>
                            </button>
                        </form>
                        {% endif %}
                    </div>
                </td>
            </tr>
        {% else %}
            <tr><td colspan="7" class="empty-state">Aucun utilisateur trouvé.</td></tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
